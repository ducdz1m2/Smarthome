@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using MudBlazor
@using System.Text.Json
@using Web.Services
@using System.Net.Http.Headers

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Chuyển kho</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="int" Label="Kho nguồn" @bind-Value="_fromWarehouseId" Required="true">
                    @foreach (var warehouse in _warehouses)
                    {
                        var stock = GetWarehouseStock(warehouse.Id);
                        var hasStock = stock > 0;
                        <MudSelectItem T="int" Value="@warehouse.Id">
                            @warehouse.Name (@warehouse.Code) - Tồn: @stock
                            @if (!hasStock)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error"> (Không đủ)</MudText>
                            }
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="int" Label="Kho đích" @bind-Value="_toWarehouseId" Required="true">
                    @foreach (var warehouse in (DestinationWarehouses ?? AvailableWarehouses ?? _warehouses ?? new List<WarehouseResponse>()))
                    {
                        <MudSelectItem T="int" Value="@warehouse.Id">@warehouse.Name (@warehouse.Code)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
        
        <MudTextField T="string" Label="Lý do" @bind-Value="_reason" Class="mt-3" />
        
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-3">Vật tư cần chuyển</MudText>
        
        @if (_materials.Any())
        {
            <MudTable Items="_materials" Dense="true" Hover="true" Class="mt-3">
                <HeaderContent>
                    <MudTh>Chọn</MudTh>
                    <MudTh>Vật tư</MudTh>
                    <MudTh>Số lượng đã lấy</MudTh>
                    <MudTh>Số lượng chuyển</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudCheckBox @bind-Value="@_selectedMaterials[context.Id]" Color="Color.Primary" />
                    </MudTd>
                    <MudTd>@context.ProductName</MudTd>
                    <MudTd>@context.QuantityTaken</MudTd>
                    <MudTd>
                        <MudNumericField T="int" @bind-Value="@context.QuantityTaken" Required="true" Min="1" Dense="true" 
                                       Variant="Variant.Outlined" Class="mt-n2" Disabled="@(!_selectedMaterials[context.Id])" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Error">Không có vật tư nào cần chuyển</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" StartIcon="@Icons.Material.Filled.Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!HasSelectedMaterials())" StartIcon="@Icons.Material.Filled.Send">Tạo phiếu chuyển</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int FromWarehouseId { get; set; }
    [Parameter] public int SelectedProductId { get; set; }
    [Parameter] public int ToWarehouseId { get; set; }
    [Parameter] public List<WarehouseResponse>? AvailableWarehouses { get; set; }
    [Parameter] public List<WarehouseResponse>? DestinationWarehouses { get; set; }
    [Parameter] public List<InstallationMaterialResponse>? BookingMaterials { get; set; }
    
    private List<WarehouseResponse> _warehouses = new();
    private List<ProductInventoryResponse> _products = new();
    private List<InstallationMaterialResponse> _materials = new();
    private Dictionary<int, bool> _selectedMaterials = new(); // Track which materials are selected for transfer
    private Dictionary<int, int> _productQuantities = new();
    private Dictionary<int, int> _warehouseStock = new(); // Warehouse ID -> Available stock
    
    private int _fromWarehouseId = 0;
    private int _toWarehouseId = 0;
    private string _reason = "";
    
    [Inject] private IInventoryService InventoryService { get; set; } = null!;
    [Inject] private IWarehouseService WarehouseService { get; set; } = null!;
    [Inject] private HttpClient Http { get; set; } = null!;
    [Inject] private NavigationManager NavigationManager { get; set; } = null!;
    [Inject] private JwtTokenHandler TokenHandler { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    
    protected override async Task OnInitializedAsync()
    {
        // Pre-fill from warehouse if provided
        if (FromWarehouseId > 0)
        {
            _fromWarehouseId = FromWarehouseId;
        }
        
        // Pre-fill to warehouse if provided
        if (ToWarehouseId > 0)
        {
            _toWarehouseId = ToWarehouseId;
        }
        
        await LoadData();
    }
    
    private async Task LoadData()
    {
        try
        {
            // Use available warehouses if provided, otherwise load all
            if (AvailableWarehouses != null && AvailableWarehouses.Any())
            {
                _warehouses = AvailableWarehouses;
            }
            else
            {
                _warehouses = await WarehouseService.GetAllAsync();
            }
            
            _products = await InventoryService.GetProductInventoryAsync();

            // Use booking materials if provided
            if (BookingMaterials != null && BookingMaterials.Any())
            {
                _materials = BookingMaterials;
                // Initialize all materials as selected by default
                foreach (var material in _materials)
                {
                    _selectedMaterials[material.Id] = true;
                }
            }
            else if (SelectedProductId > 0)
            {
                // Only show the selected product
                var selectedProduct = _products.FirstOrDefault(p => p.ProductId == SelectedProductId);
                if (selectedProduct != null)
                {
                    _materials = new List<InstallationMaterialResponse>
                    {
                        new InstallationMaterialResponse
                        {
                            ProductId = selectedProduct.ProductId,
                            ProductName = selectedProduct.ProductName,
                            QuantityTaken = 1
                        }
                    };
                    _selectedMaterials[_materials[0].Id] = true;
                }
            }
            else
            {
                // Convert products to materials format for backward compatibility
                _materials = _products.Select(p => new InstallationMaterialResponse
                {
                    ProductId = p.ProductId,
                    ProductName = p.ProductName,
                    QuantityTaken = 1
                }).ToList();
                // Initialize all materials as selected by default
                foreach (var material in _materials)
                {
                    _selectedMaterials[material.Id] = true;
                }
            }

            // Load stock for each material
            foreach (var material in _materials)
            {
                var productId = material.ProductId;
                await LoadWarehouseStockForProduct(productId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải dữ liệu: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadWarehouseStockForProduct(int productId)
    {
        try
        {
            Console.WriteLine($"[LoadWarehouseStockForProduct] ProductId: {productId}");
            Console.WriteLine($"[LoadWarehouseStockForProduct] Loading stock for {_warehouses.Count} warehouses");
            
            // Use InventoryService to get stock for each warehouse
            foreach (var warehouse in _warehouses)
            {
                Console.WriteLine($"[LoadWarehouseStockForProduct] Checking warehouse {warehouse.Id}");
                
                var productInventory = await InventoryService.GetProductInventoryByIdAsync(productId, warehouse.Id);
                
                if (productInventory != null)
                {
                    var totalAvailable = productInventory.AvailableStock;
                    _warehouseStock[warehouse.Id] = totalAvailable;
                    Console.WriteLine($"[LoadWarehouseStockForProduct] Warehouse {warehouse.Id}: {totalAvailable} available");
                }
                else
                {
                    _warehouseStock[warehouse.Id] = 0;
                    Console.WriteLine($"[LoadWarehouseStockForProduct] Warehouse {warehouse.Id}: 0 (no inventory data)");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadWarehouseStockForProduct] Exception: {ex.Message}");
            Console.WriteLine($"[LoadWarehouseStockForProduct] Stack trace: {ex.StackTrace}");
            Snackbar.Add($"Lỗi khi tải tồn kho: {ex.Message}", Severity.Error);
            // Set all to 0 on error
            foreach (var warehouse in _warehouses)
            {
                _warehouseStock[warehouse.Id] = 0;
            }
        }
    }

    private int GetWarehouseStock(int warehouseId)
    {
        return _warehouseStock.TryGetValue(warehouseId, out var stock) ? stock : 0;
    }

    private bool HasSelectedMaterials()
    {
        return _selectedMaterials.Values.Any(selected => selected);
    }
    
    private async Task Submit()
    {
        try
        {
            // Validate warehouses
            if (_fromWarehouseId == 0 || _toWarehouseId == 0)
            {
                Snackbar.Add("Vui lòng chọn kho nguồn và kho đích", Severity.Warning);
                return;
            }

            if (_fromWarehouseId == _toWarehouseId)
            {
                Snackbar.Add("Kho nguồn và kho đích không được giống nhau", Severity.Warning);
                return;
            }

            // Build product quantities from selected materials only
            _productQuantities.Clear();
            foreach (var material in _materials)
            {
                if (_selectedMaterials.TryGetValue(material.Id, out var isSelected) && isSelected && material.QuantityTaken > 0)
                {
                    _productQuantities[material.ProductId] = material.QuantityTaken;
                }
            }

            if (!_productQuantities.Any())
            {
                Snackbar.Add("Vui lòng nhập số lượng chuyển cho ít nhất một vật tư", Severity.Warning);
                return;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi chuyển kho: {ex.Message}", Severity.Error);
            return;
        }

        try
        {
            // Add auth token
            var token = await TokenHandler.GetTokenAsync();
            
            var request = new InitiateTransferRequest
            {
                FromWarehouseId = _fromWarehouseId,
                ToWarehouseId = _toWarehouseId,
                ProductQuantities = _productQuantities,
                Reason = _reason
            };
            
            var url = $"{NavigationManager.BaseUri}api/warehouse/transfer/initiate";
            
            var httpRequest = new HttpRequestMessage(HttpMethod.Post, url);
            if (!string.IsNullOrEmpty(token))
            {
                httpRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }
            httpRequest.Content = JsonContent.Create(request);
            
            var response = await Http.SendAsync(httpRequest);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<dynamic>();
                int transferId = result.GetProperty("transferId").GetInt32();
                
                // Execute the transfer immediately
                var executeRequest = new ExecuteTransferRequest { TransferId = transferId };
                var executeUrl = $"{NavigationManager.BaseUri}api/warehouse/transfer/execute";
                
                var executeHttpRequest = new HttpRequestMessage(HttpMethod.Post, executeUrl);
                if (!string.IsNullOrEmpty(token))
                {
                    executeHttpRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                }
                executeHttpRequest.Content = JsonContent.Create(executeRequest);
                
                var executeResponse = await Http.SendAsync(executeHttpRequest);
                
                if (executeResponse.IsSuccessStatusCode)
                {
                    Snackbar.Add("Đã chuyển kho thành công", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var error = await executeResponse.Content.ReadAsStringAsync();
                    Console.WriteLine($"[WarehouseTransferDialog] Execute transfer failed: {error}");
                    Snackbar.Add($"Lỗi khi thực hiện chuyển kho: {error}", Severity.Error);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[WarehouseTransferDialog] Initiate transfer failed: {error}");
                Snackbar.Add($"Lỗi: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WarehouseTransferDialog] Exception: {ex.Message}");
            Console.WriteLine($"[WarehouseTransferDialog] StackTrace: {ex.StackTrace}");
            Snackbar.Add($"Lỗi khi chuyển kho: {ex.Message}", Severity.Error);
        }
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
