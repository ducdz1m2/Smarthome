@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Hủy Phiếu Chuyển Kho</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">Vui lòng nhập lý do hủy phiếu chuyển kho:</MudText>
        <MudTextField T="string" Label="Lý do" @bind-Value="_reason" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Error" OnClick="Submit">Xác nhận hủy</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter] public int TransferId { get; set; }
    
    private string _reason = "";
    
    [Inject] private HttpClient Http { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private NavigationManager NavigationManager { get; set; } = null!;
    
    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_reason))
        {
            Snackbar.Add("Vui lòng nhập lý do hủy", Severity.Warning);
            return;
        }
        
        try
        {
            var request = new { TransferId = TransferId, Reason = _reason };
            var url = $"{NavigationManager.BaseUri}api/warehouse/transfer/cancel";
            var response = await Http.PostAsJsonAsync(url, request);
            
            if (response.IsSuccessStatusCode)
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Lỗi: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi hủy phiếu chuyển kho: {ex.Message}", Severity.Error);
        }
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
