@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Services
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject LocalAuthStateProvider LocalAuthStateProvider
@inject CurrentUserService CurrentUserService
@implements IDisposable

<HeadContent>
    <script src="/js/fileDownload.js"></script>
</HeadContent>

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="3" Class="navbar-gradient" Fixed="true">
        <div class="navbar-brand">
            <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Large" Class="brand-icon" />
            <MudText Typo="Typo.h5" Color="Color.Inherit" Class="brand-text">Smarthome Store</MudText>
        </div>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" Class="nav-icon-btn" />
        </MudHidden>

        @if (CurrentUserService.Roles.Contains("Admin"))
        {
            <MudButton href="/admin" Variant="Variant.Text" Color="Color.Inherit" Class="nav-link">Quản trị</MudButton>
        }
        else if (CurrentUserService.Roles.Contains("Technician"))
        {
            <MudButton href="/technician" Variant="Variant.Text" Color="Color.Inherit" Class="nav-link">Kỹ thuật viên</MudButton>
        }
        else
        {
            <MudButton href="/" Variant="Variant.Text" Color="Color.Inherit" Class="nav-link">Trang chủ</MudButton>
            <MudButton href="/products" Variant="Variant.Text" Color="Color.Inherit" Class="nav-link">Sản phẩm</MudButton>
        }

        @* Giỏ hàng với số lượng động - chỉ hiển thị cho customer *@
        @if (!CurrentUserService.Roles.Contains("Admin") && !CurrentUserService.Roles.Contains("Technician"))
        {
            @if (_cartCount > 0)
            {
                <MudBadge Content="@_cartCount" Color="Color.Secondary" Overlap="true" Class="cart-badge mx-3">
                    <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" Href="/cart" Class="nav-icon-btn" />
                </MudBadge>
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" Href="/cart" Class="nav-icon-btn mx-3" />
            }
        }

        @* Push Notification Manager *@
        @if (CurrentUserService.IsAuthenticated)
        {
            <PushNotificationManager Class="mx-2" />
        }

        @* Nút tài khoản với avatar *@
        <MudIconButton Href="/profile" Title="Quản lý tài khoản" Class="avatar-btn">
            @if (!string.IsNullOrEmpty(_avatarUrl))
            {
                <MudAvatar Size="Size.Medium" Class="nav-avatar">
                    <MudImage Src="@_avatarUrl" ObjectFit="ObjectFit.Cover" />
                </MudAvatar>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Size="Size.Large" />
            }
        </MudIconButton>
    </MudAppBar>
    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.Large" Class="content-container">
            @Body
        </MudContainer>
    </MudMainContent>
    <div class="footer" style="background: linear-gradient(135deg, #1565C0 0%, #1976D2 100%) !important; color: white !important; padding: 3rem 0 1.5rem 0; min-height: 200px; position: relative; z-index: 1000;">
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudGrid Class="footer-grid">
                <MudItem xs="12" sm="6" md="3">
                    <div class="footer-section">
                        <MudText Typo="Typo.h6" Class="footer-title">Smarthome Store</MudText>
                        <MudText Typo="Typo.body2" Class="footer-text">Giải pháp nhà thông minh toàn diện cho cuộc sống hiện đại</MudText>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <div class="footer-section">
                        <MudText Typo="Typo.h6" Class="footer-title">Sản phẩm</MudText>
                        <MudText Class="footer-link">Đèn thông minh</MudText>
                        <MudText Class="footer-link">Cảm biến</MudText>
                        <MudText Class="footer-link">Camera</MudText>
                        <MudText Class="footer-link">Thiết bị an ninh</MudText>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <div class="footer-section">
                        <MudText Typo="Typo.h6" Class="footer-title">Hỗ trợ</MudText>
                        <MudText Class="footer-link">Trung tâm trợ giúp</MudText>
                        <MudText Class="footer-link">Chính sách bảo hành</MudText>
                        <MudText Class="footer-link">Hướng dẫn sử dụng</MudText>
                        <MudText Class="footer-link">Liên hệ</MudText>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <div class="footer-section">
                        <MudText Typo="Typo.h6" Class="footer-title">Liên hệ</MudText>
                        <MudText Typo="Typo.body2" Class="footer-text">
                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> 1900-1234
                        </MudText>
                        <MudText Typo="Typo.body2" Class="footer-text">
                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> support@smarthome.vn
                        </MudText>
                    </div>
                </MudItem>
            </MudGrid>
            <MudDivider Class="footer-divider" />
            <div class="footer-bottom">
                <MudText Typo="Typo.body2" Class="footer-copyright">
                    2026 Smarthome Store. All rights reserved.
                </MudText>
            </div>
        </MudContainer>
    </div>
    <ChatWidget />
</MudLayout>

@code {
    private int _cartCount = 0;
    private string? _avatarUrl;

    protected override async Task OnInitializedAsync()
    {
        await UpdateCartCount();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize authentication state
            Console.WriteLine($"[MainLayout] Initializing authentication state");
            try
            {
                await LocalAuthStateProvider.GetAuthenticationStateAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[MainLayout] Error initializing auth state: {ex.Message}");
            }

            // Listen for storage changes
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", @"
                    window.addEventListener('storage', function(e) {
                        if (e.key === 'cart') {
                            window.dotNetHelper?.invokeMethodAsync('UpdateCartCountFromJs');
                        }
                        if (e.key === 'userAvatar') {
                            // Reload page to update avatar across all layouts
                            window.location.reload();
                        }
                    });
                ");
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // Ignore - circuit is disconnecting
                Console.WriteLine("[MainLayout] Circuit disconnected, skipping JS interop");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[MainLayout] Error setting up storage listener: {ex.Message}");
            }
            await LoadAvatar();
        }
    }

    [JSInvokable]
    public async Task UpdateAvatar()
    {
        await LoadAvatar();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAvatar()
    {
        try
        {
            _avatarUrl = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "userAvatar");
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task UpdateCartCount()
    {
        try
        {
            var cartJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "cart");
            if (!string.IsNullOrEmpty(cartJson))
            {
                var cartItems = System.Text.Json.JsonSerializer.Deserialize<List<CartItem>>(cartJson);
                _cartCount = cartItems?.Sum(i => i.Quantity) ?? 0;
            }
            else
            {
                _cartCount = 0;
            }
            StateHasChanged();
        }
        catch { }
    }

    public class CartItem
    {
        public int Id { get; set; }
        public int Quantity { get; set; }
    }

    public void Dispose()
    {
        // Cleanup if needed
    }

    [JSInvokable]
    public async Task UpdateCartCountFromJs()
    {
        await UpdateCartCount();
    }
}