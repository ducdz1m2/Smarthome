@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Services
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject LocalAuthStateProvider LocalAuthStateProvider
@inject CurrentUserService CurrentUserService
@implements IDisposable

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary" Fixed="true">
        <MudText Typo="Typo.h5" Color="Color.Inherit" Class="fw-bold">Smarthome Store</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" />
        </MudHidden>
        
        @if (CurrentUserService.Roles.Contains("Admin"))
        {
            <MudButton href="/admin" Variant="Variant.Text" Color="Color.Secondary">Quản trị</MudButton>
        }
        else if (CurrentUserService.Roles.Contains("Technician"))
        {
            <MudButton href="/technician" Variant="Variant.Text" Color="Color.Secondary">Kỹ thuật viên</MudButton>
        }
        else
        {
            <MudButton href="/" Variant="Variant.Text">Trang chủ</MudButton>
            <MudButton href="/products" Variant="Variant.Text">Sản phẩm</MudButton>
        }
        
        @* Giỏ hàng với số lượng động - chỉ hiển thị cho customer *@
        @if (!CurrentUserService.Roles.Contains("Admin") && !CurrentUserService.Roles.Contains("Technician"))
        {
            <MudBadge Content="@_cartCount" Color="Color.Secondary" Overlap="true" Class="mx-4" Visible="@(_cartCount > 0)">
                <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" Href="/cart" />
            </MudBadge>
        }

        @* Notification widget - hiển thị cho tất cả user đã đăng nhập *@
        @if (CurrentUserService.IsAuthenticated)
        {
            <NotificationWidget Class="mx-2" />
        }

        @* Nút tài khoản với avatar *@
        <MudIconButton Href="/profile" Title="Quản lý tài khoản">
            @if (!string.IsNullOrEmpty(_avatarUrl))
            {
                <MudAvatar Size="Size.Medium">
                    <MudImage Src="@_avatarUrl" ObjectFit="ObjectFit.Cover" />
                </MudAvatar>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
            }
        </MudIconButton>
    </MudAppBar>
    <MudMainContent Class="mt-16 pa-4">
        <MudContainer MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>
    <ChatWidget />
</MudLayout>

@code {
    private int _cartCount = 0;
    private string? _avatarUrl;

    protected override async Task OnInitializedAsync()
    {
        await UpdateCartCount();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize authentication state
            Console.WriteLine($"[MainLayout] Initializing authentication state");
            try
            {
                await LocalAuthStateProvider.GetAuthenticationStateAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[MainLayout] Error initializing auth state: {ex.Message}");
            }

            // Listen for storage changes
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", @"
                    window.addEventListener('storage', function(e) {
                        if (e.key === 'cart') {
                            window.dotNetHelper?.invokeMethodAsync('UpdateCartCountFromJs');
                        }
                        if (e.key === 'userAvatar') {
                            // Reload page to update avatar across all layouts
                            window.location.reload();
                        }
                    });
                ");
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // Ignore - circuit is disconnecting
                Console.WriteLine("[MainLayout] Circuit disconnected, skipping JS interop");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[MainLayout] Error setting up storage listener: {ex.Message}");
            }
            await LoadAvatar();
        }
    }

    [JSInvokable]
    public async Task UpdateAvatar()
    {
        await LoadAvatar();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAvatar()
    {
        try
        {
            _avatarUrl = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "userAvatar");
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task UpdateCartCount()
    {
        try
        {
            var cartJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "cart");
            if (!string.IsNullOrEmpty(cartJson))
            {
                var cartItems = System.Text.Json.JsonSerializer.Deserialize<List<CartItem>>(cartJson);
                _cartCount = cartItems?.Sum(i => i.Quantity) ?? 0;
            }
            else
            {
                _cartCount = 0;
            }
            StateHasChanged();
        }
        catch { }
    }

    public class CartItem
    {
        public int Id { get; set; }
        public int Quantity { get; set; }
    }

    public void Dispose()
    {
        // Cleanup if needed
    }

    [JSInvokable]
    public async Task UpdateCartCountFromJs()
    {
        await UpdateCartCount();
    }
}