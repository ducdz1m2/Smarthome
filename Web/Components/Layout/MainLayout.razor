@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Surface" Fixed="true">
        <MudText Typo="Typo.h5" Color="Color.Primary" Class="fw-bold">MY-STORE</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" />
        </MudHidden>
        <MudButton href="/" Variant="Variant.Text">Trang chủ</MudButton>
        <MudButton href="/products" Variant="Variant.Text">Sản phẩm</MudButton>
        <MudBadge Content="3" Color="Color.Secondary" Overlap="true" Class="mx-4">
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" />
        </MudBadge>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Href="/profile">Hồ sơ</MudMenuItem>
                <MudMenuItem Href="/orders">Đơn hàng</MudMenuItem>
                <MudDivider />
                <MudMenuItem OnClick="Logout" Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">Đăng xuất</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>
    <MudMainContent Class="mt-16 pa-4">
        <MudContainer MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private void Logout()
    {
        NavigationManager.NavigateTo("/login", forceLoad: true);
        Snackbar.Add("Đã đăng xuất", Severity.Success);
    }
}