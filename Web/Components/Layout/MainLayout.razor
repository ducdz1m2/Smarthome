@inherits LayoutComponentBase
<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Surface" Fixed="true">
        <MudText Typo="Typo.h5" Color="Color.Primary" Class="fw-bold">MY-STORE</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Inherit" />
        </MudHidden>
        <MudButton href="/" Variant="Variant.Text">Trang chủ</MudButton>
        <MudButton href="/products" Variant="Variant.Text">Sản phẩm</MudButton>
        <MudBadge Content="3" Color="Color.Secondary" Overlap="true" Class="mx-4">
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Inherit" />
        </MudBadge>
    </MudAppBar>
    <MudMainContent Class="mt-16 pa-4">
        <MudContainer MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>