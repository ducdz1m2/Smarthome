@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Services
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="3" Class="admin-navbar-gradient">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" Class="admin-menu-btn" />
        <div class="admin-navbar-brand">
            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" Class="admin-brand-icon" />
            <MudText Typo="Typo.h6" Class="admin-brand-text">Smarthome Admin</MudText>
        </div>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Class="admin-icon-btn" />
        @* Avatar button *@
        <MudIconButton Href="/profile" Title="Quản lý tài khoản" Class="admin-avatar-btn">
            @if (!string.IsNullOrEmpty(_avatarUrl))
            {
                <MudAvatar Size="Size.Medium" Class="admin-nav-avatar">
                    <MudImage Src="@_avatarUrl" ObjectFit="ObjectFit.Cover" />
                </MudAvatar>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Size="Size.Large" />
            }
        </MudIconButton>
    </MudAppBar>
    <MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="3" Variant="DrawerVariant.Mini" OpenMiniOnHover="true" Class="admin-drawer">
        <AdminNavMenu />
    </MudDrawer>
    <MudMainContent Class="admin-main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="admin-content-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    private string? _avatarUrl;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Console.WriteLine($"[AdminLayout] OnAfterRenderAsync - checking authorization");
            
            // Check authorization
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            Console.WriteLine($"[AdminLayout] User.Identity?.IsAuthenticated: {user.Identity?.IsAuthenticated}");
            Console.WriteLine($"[AdminLayout] User.Identity?.Name: {user.Identity?.Name}");
            
            // Check if user has Admin role first (regardless of authentication status)
            var roles = user.FindAll("role").Select(c => c.Value).ToList();
            Console.WriteLine($"[AdminLayout] User roles: [{string.Join(", ", roles)}]");
            
            if (!roles.Contains("Admin"))
            {
                Console.WriteLine($"[AdminLayout] User does not have Admin role");
                // If authenticated but wrong role, redirect to access-denied
                if (user.Identity?.IsAuthenticated ?? false)
                {
                    Console.WriteLine($"[AdminLayout] User authenticated but wrong role, redirecting to access-denied");
                    NavigationManager.NavigateTo("/access-denied", forceLoad: true);
                }
                else
                {
                    Console.WriteLine($"[AdminLayout] User not authenticated, redirecting to login");
                    NavigationManager.NavigateTo("/login", forceLoad: true);
                }
                return;
            }

            // Check if user is authenticated
            if (!user.Identity?.IsAuthenticated ?? true)
            {
                Console.WriteLine($"[AdminLayout] User not authenticated, redirecting to login");
                NavigationManager.NavigateTo("/login", forceLoad: true);
                return;
            }

            Console.WriteLine($"[AdminLayout] User authorized as Admin");
            
            await LoadAvatar();
        }
    }

    private async Task LoadAvatar()
    {
        try
        {
            _avatarUrl = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "userAvatar");
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
