@using Web.Services
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IAuthService AuthService

<MudNavMenu>
    <MudNavLink Href="/technician" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Tổng quan</MudNavLink>

    <MudNavGroup Title="Lịch công việc" Expanded="true" Icon="@Icons.Material.Filled.EventNote">
        <MudNavLink Href="/technician/bookings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CalendarMonth">Tất cả</MudNavLink>
        <MudNavLink Href="/technician/bookings?type=installation" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Build">Lắp đặt</MudNavLink>
        <MudNavLink Href="/technician/bookings?type=warranty" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Handyman">Bảo hành</MudNavLink>
        <MudNavLink Href="/technician/bookings?type=uninstall" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Delete">Tháo dỡ</MudNavLink>
    </MudNavGroup>

    <MudNavLink Href="/technician/chat" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Chat">Tin nhắn</MudNavLink>

    <MudDivider Class="my-2" />

    <MudNavLink OnClick="Logout" Icon="@Icons.Material.Filled.Logout" Color="Color.Error">Đăng xuất</MudNavLink>
</MudNavMenu>

@code {
    private async Task Logout()
    {
        // Clear JWT token from localStorage and session
        await AuthService.SignOutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
        Snackbar.Add("Đã đăng xuất", Severity.Success);
    }
}
