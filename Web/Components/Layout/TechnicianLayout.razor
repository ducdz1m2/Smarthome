@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">Kỹ thuật viên</MudText>
        <MudSpacer />
        <MudIconButton Href="/profile" Title="Quản lý tài khoản">
            @if (!string.IsNullOrEmpty(_avatarUrl))
            {
                <MudAvatar Size="Size.Medium">
                    <MudImage Src="@_avatarUrl" ObjectFit="ObjectFit.Cover" />
                </MudAvatar>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" />
            }
        </MudIconButton>
    </MudAppBar>
    <MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Mini" OpenMiniOnHover="true">
        <TechnicianNavMenu />
    </MudDrawer>
    <MudMainContent Class="pt-16 px-4 pb-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    private string? _avatarUrl;
    private bool _isAuthorized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Console.WriteLine($"[TechnicianLayout] OnAfterRenderAsync - checking authorization");
            
            // Check authorization
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            Console.WriteLine($"[TechnicianLayout] User.Identity?.IsAuthenticated: {user.Identity?.IsAuthenticated}");
            Console.WriteLine($"[TechnicianLayout] User.Identity?.Name: {user.Identity?.Name}");
            
            // Check if user has Technician role first (regardless of authentication status)
            var roles = user.FindAll("role").Select(c => c.Value).ToList();
            Console.WriteLine($"[TechnicianLayout] User roles: [{string.Join(", ", roles)}]");
            
            if (!roles.Contains("Technician"))
            {
                Console.WriteLine($"[TechnicianLayout] User does not have Technician role");
                // If authenticated but wrong role, redirect to access-denied
                if (user.Identity?.IsAuthenticated ?? false)
                {
                    Console.WriteLine($"[TechnicianLayout] User authenticated but wrong role, redirecting to access-denied");
                    NavigationManager.NavigateTo("/access-denied", forceLoad: true);
                }
                else
                {
                    Console.WriteLine($"[TechnicianLayout] User not authenticated, redirecting to login");
                    NavigationManager.NavigateTo("/login", forceLoad: true);
                }
                return;
            }

            // Check if user is authenticated
            if (!user.Identity?.IsAuthenticated ?? true)
            {
                Console.WriteLine($"[TechnicianLayout] User not authenticated, redirecting to login");
                NavigationManager.NavigateTo("/login", forceLoad: true);
                return;
            }

            Console.WriteLine($"[TechnicianLayout] User authorized as Technician");
            _isAuthorized = true;
            
            await LoadAvatar();
        }
    }

    private async Task LoadAvatar()
    {
        try
        {
            _avatarUrl = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "userAvatar");
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
