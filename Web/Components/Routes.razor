@inject NavigationManager Navigation

<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <LayoutView Layout="@GetLayout()">
            <RouteView RouteData="@routeData" />
        </LayoutView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private Type GetLayout()
    {
        var uri = Navigation.Uri;
        var baseUri = Navigation.BaseUri;
        var relativeUri = uri.Replace(baseUri, "").TrimStart('/');
        
        if (relativeUri.StartsWith("admin", StringComparison.OrdinalIgnoreCase))
        {
            return typeof(Layout.AdminLayout);
        }
        return typeof(Layout.MainLayout);
    }
}
