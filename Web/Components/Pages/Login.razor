@page "/login"
@layout EmptyLayout
@using Application.DTOs.Requests
@using Application.Interfaces.Services
@using Web.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject IIdentityService IdentityService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <MudPaper Elevation="3" Class="pa-6" Style="width: 400px;">
        <MudText Typo="Typo.h4" Class="mb-4 text-center">Đăng nhập</MudText>
        
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string" 
                          @bind-Value="_request.UserName" 
                          Label="Tên đăng nhập" 
                          Required="true" 
                          RequiredError="Vui lòng nhập tên đăng nhập"
                          Variant="Variant.Outlined" 
                          Class="mb-3"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />
            
            <MudTextField T="string" 
                          @bind-Value="_request.Password" 
                          Label="Mật khẩu" 
                          Required="true" 
                          RequiredError="Vui lòng nhập mật khẩu"
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password"
                          Class="mb-3"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock" />
            
            <MudCheckBox @bind-Value="_request.RememberMe" 
                         Label="Ghi nhớ đăng nhập" 
                         Color="Color.Primary" 
                         Class="mb-4" />
            
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true"
                       OnClick="Submit"
                       Disabled="!_isValid || _loading"
                       Class="mb-3">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
                    <span>Đang đăng nhập...</span>
                }
                else
                {
                    <span>Đăng nhập</span>
                }
            </MudButton>
            
            <MudDivider Class="my-4" />
            
            <MudText Align="Align.Center">
                Chưa có tài khoản? 
                <MudLink Href="/register">Đăng ký ngay</MudLink>
            </MudText>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private LoginRequest _request = new();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _loading = true;
        try
        {
            Console.WriteLine($"[Login] Attempting login for user: {_request.UserName}");
            
            // Validate credentials and get JWT token
            var response = await IdentityService.LoginAsync(_request);

            Console.WriteLine($"[Login] Token received: {response.Token?.Substring(0, Math.Min(50, response.Token?.Length ?? 0))}...");
            Console.WriteLine($"[Login] User: {response.User?.UserName}, Roles: [{string.Join(", ", response.User?.Roles ?? [])}]");

            // Store JWT token in localStorage for API calls
            await AuthService.SetTokenAsync(response.Token);

            // Verify token was saved
            var savedToken = await AuthService.GetTokenAsync();
            Console.WriteLine($"[Login] Token saved: {(savedToken != null ? "yes" : "no")}");

            Snackbar.Add("Đăng nhập thành công!", Severity.Success);

            // Redirect based on role
            string redirectUrl = "/";
            if (response.User!.Roles.Contains("Admin"))
            {
                Console.WriteLine($"[Login] Redirecting to /admin");
                redirectUrl = "/admin";
            }
            else if (response.User!.Roles.Contains("Technician"))
            {
                Console.WriteLine($"[Login] Redirecting to /technician");
                redirectUrl = "/technician";
            }
            else
            {
                Console.WriteLine($"[Login] Redirecting to /");
            }

            NavigationManager.NavigateTo(redirectUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Login] Error: {ex.Message}");
            Console.WriteLine($"[Login] Stack trace: {ex.StackTrace}");
            Snackbar.Add($"Đăng nhập thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
