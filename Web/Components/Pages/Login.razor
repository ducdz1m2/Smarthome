@page "/login"
@layout EmptyLayout
@using Application.DTOs.Requests
@using Application.Interfaces.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject IIdentityService IdentityService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IHttpContextAccessor HttpContextAccessor

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <MudPaper Elevation="3" Class="pa-6" Style="width: 400px;">
        <MudText Typo="Typo.h4" Class="mb-4 text-center">Đăng nhập</MudText>
        
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string" 
                          @bind-Value="_request.UserName" 
                          Label="Tên đăng nhập" 
                          Required="true" 
                          RequiredError="Vui lòng nhập tên đăng nhập"
                          Variant="Variant.Outlined" 
                          Class="mb-3"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />
            
            <MudTextField T="string" 
                          @bind-Value="_request.Password" 
                          Label="Mật khẩu" 
                          Required="true" 
                          RequiredError="Vui lòng nhập mật khẩu"
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password"
                          Class="mb-3"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock" />
            
            <MudCheckBox @bind-Value="_request.RememberMe" 
                         Label="Ghi nhớ đăng nhập" 
                         Color="Color.Primary" 
                         Class="mb-4" />
            
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true"
                       OnClick="Submit"
                       Disabled="!_isValid || _loading"
                       Class="mb-3">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
                    <span>Đang đăng nhập...</span>
                }
                else
                {
                    <span>Đăng nhập</span>
                }
            </MudButton>
            
            <MudDivider Class="my-4" />
            
            <MudText Align="Align.Center">
                Chưa có tài khoản? 
                <MudLink Href="/register">Đăng ký ngay</MudLink>
            </MudText>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private LoginRequest _request = new();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _loading = true;
        try
        {
            // Validate credentials
            var response = await IdentityService.LoginAsync(_request);
            
            // Set cookie using HttpContext (only works during initial request)
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext != null && !httpContext.Response.HasStarted)
            {
                var claims = new List<Claim>
                {
                    new(ClaimTypes.NameIdentifier, response.User.Id.ToString()),
                    new(ClaimTypes.Name, response.User.UserName),
                    new(ClaimTypes.Email, response.User.Email),
                    new(ClaimTypes.GivenName, response.User.FullName)
                };

                foreach (var role in response.User.Roles)
                {
                    claims.Add(new Claim(ClaimTypes.Role, role));
                }

                var claimsIdentity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
                var claimsPrincipal = new ClaimsPrincipal(claimsIdentity);

                var authProperties = new AuthenticationProperties
                {
                    IsPersistent = _request.RememberMe,
                    ExpiresUtc = DateTimeOffset.UtcNow.AddHours(8)
                };

                await httpContext.SignInAsync(
                    CookieAuthenticationDefaults.AuthenticationScheme,
                    claimsPrincipal,
                    authProperties);
            }
            
            Snackbar.Add("Đăng nhập thành công!", Severity.Success);
            
            // Redirect based on role
            var redirectUrl = response.User.Roles.Contains("Admin") ? "/admin" : "/";
            NavigationManager.NavigateTo(redirectUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Đăng nhập thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
