@page "/technician/warranty-claims"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Web.Services
@using Web.Helpers
@inject IInstallationService InstallationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IAuthService AuthService

<MudText Typo="Typo.h4" Class="mb-4">Đơn bảo hành của tôi</MudText>

@if (_loading)
{
    <MudProgressCircular Class="ma-auto" Color="Color.Primary" Indeterminate="true" />
}
else if (!_warrantyBookings.Any())
{
    <MudAlert Severity="Severity.Info" Class="my-4">Không có đơn bảo hành nào.</MudAlert>
}
else
{
    <MudTable Items="_warrantyBookings" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Mã đơn</MudTh>
            <MudTh>Khách hàng</MudTh>
            <MudTh>Ngày làm</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh>Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.OrderNumber</MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@context.CustomerName</MudText>
                <MudText Typo="Typo.caption">@context.CustomerPhone</MudText>
            </MudTd>
            <MudTd>@context.ScheduledDate.ToLocalTime().ToString("dd/MM/yyyy")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="StatusHelper.GetInstallationStatusColor(context.Status)">@StatusHelper.GetInstallationStatusText(context.Status)</MudChip>
            </MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           Href="@($"/technician/bookings/{context.Id}")">Chi tiết</MudButton>
                @if (context.Status == "Assigned")
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="ml-2"
                               OnClick="() => AcceptBooking(context.Id)">Tiếp nhận</MudButton>
                }
                @if (context.Status == "Confirmed")
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="ml-2"
                               OnClick="() => StartWarranty(context.Id)">Bắt đầu bảo hành</MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<InstallationBookingListResponse> _warrantyBookings = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadWarrantyBookings();
    }

    private async Task LoadWarrantyBookings()
    {
        try
        {
            _loading = true;
            var technicianId = await GetCurrentTechnicianId();
            if (technicianId == 0) return;

            var allBookings = await InstallationService.GetByTechnicianAsync(technicianId);
            _warrantyBookings = allBookings.Where(b => b.IsWarranty).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<int> GetCurrentTechnicianId()
    {
        var technicianId = await AuthService.GetTechnicianIdAsync();
        return technicianId ?? 0;
    }

    private async Task AcceptBooking(int id)
    {
        try
        {
            var technicianId = await GetCurrentTechnicianId();
            await InstallationService.AcceptBookingAsync(id, technicianId);
            Snackbar.Add("Đã tiếp nhận đơn bảo hành", Severity.Success);
            await LoadWarrantyBookings();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task StartWarranty(int id)
    {
        try
        {
            await InstallationService.StartWarrantyAsync(id);
            Snackbar.Add("Đã bắt đầu bảo hành", Severity.Success);
            await LoadWarrantyBookings();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

}
