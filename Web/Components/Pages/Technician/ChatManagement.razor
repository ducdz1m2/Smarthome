@page "/technician/chat"
@using Application.DTOs.Responses
@using Application.DTOs.Requests
@using Application.Interfaces.Services
@using Domain.Enums
@using Web.Services
@inject IChatService ChatService
@inject SignalRService SignalRService
@inject CurrentUserService CurrentUser
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="technician-chat-container">
    <div class="technician-chat-sidebar">
        <div class="technician-chat-sidebar-header">
            <MudText Typo="Typo.h6" Class="mb-0">Chat Đơn Lắp Đặt</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_chatRooms.Count cuộc hội thoại</MudText>
        </div>
        
        <div class="technician-chat-rooms-list">
            @if (_chatRooms.Count == 0)
            {
                <div class="text-center py-4">
                    <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline" Size="Size.Large" Class="mb-3" Color="Color.Secondary" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa có cuộc hội thoại nào</MudText>
                </div>
            }
            else
            {
                @foreach (var room in _chatRooms)
                {
                    var customerParticipant = room.Participants.FirstOrDefault(p => p.UserType == "Customer");
                    var customerName = customerParticipant?.UserName ?? room.Title;
                    var technicianParticipant = room.Participants.FirstOrDefault(p => p.UserType == "Technician");
                    var unreadCount = technicianParticipant?.UnreadCount ?? 0;

                    <div class="@($"technician-chat-room-item {(SelectedChatRoomId == room.Id ? "selected" : "")}")"
                         @onclick="() => SelectChatRoom(room.Id)">
                        <div class="technician-chat-room-avatar">@GetInitials(customerName)</div>
                        <div class="technician-chat-room-info">
                            <div class="technician-chat-room-name">@customerName</div>
                            <div class="technician-chat-room-installation">
                                @if (room.RelatedInstallationId.HasValue)
                                {
                                    <span>Đơn #@room.RelatedInstallationId</span>
                                }
                            </div>
                            <div class="technician-chat-room-last-message">@room.LastMessage?.Content ?? ""</div>
                        </div>
                        @if (unreadCount > 0)
                        {
                            <div class="technician-chat-room-badge">@unreadCount</div>
                        }
                    </div>
                }
            }
        </div>
    </div>
    
    <div class="technician-chat-main">
        @if (SelectedChatRoomId == 0)
        {
            <div class="technician-chat-empty-state">
                <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline" Size="Size.Large" Class="mb-4" Color="Color.Secondary" />
                <MudText Typo="Typo.h5" Class="mb-2">Chọn cuộc hội thoại</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center">
                    Vui lòng chọn một cuộc hội thoại từ danh sách bên trái để bắt đầu trò chuyện
                </MudText>
            </div>
        }
        else
        {
            <div class="technician-chat-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="technician-chat-header-avatar">@GetInitials(GetSelectedRoomName())</div>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="mb-0">@GetSelectedRoomName()</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Đang hoạt động</MudText>
                        @if (_selectedRoom?.RelatedInstallationId.HasValue == true)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Primary">Đơn lắp đặt #@_selectedRoom.RelatedInstallationId</MudText>
                        }
                    </div>
                </div>
            </div>
            
            <div class="technician-chat-messages" @ref="_messagesContainer">
                @if (_loadingMessages)
                {
                    <div class="text-center py-4">
                        <MudProgressCircular Color="Color.Primary" Size="Size.Medium" />
                    </div>
                }
                else if (_messages.Count == 0)
                {
                    <div class="text-center py-4">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa có tin nhắn nào. Hãy bắt đầu cuộc trò chuyện!</MudText>
                    </div>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        var separatorTime = _lastReadAt ?? _roomOpenTime;
                        var shouldShowSeparator = separatorTime != null && msg.SentAt > separatorTime && !_separatorShown;
                        
                        if (shouldShowSeparator)
                        {
                            <div class="technician-message-separator">
                                <div class="separator-line"></div>
                                <div class="separator-text">Tin nhắn mới</div>
                                <div class="separator-line"></div>
                            </div>
                            _separatorShown = true;
                        }

                        <div class="@($"technician-message {(msg.IsFromMe ? "sent" : "received")}")">
                            @if (!msg.IsFromMe)
                            {
                                <div class="technician-message-avatar">@GetInitials(msg.SenderId.ToString())</div>
                            }
                            <div class="technician-message-content">
                                <div class="technician-message-bubble">
                                    <MudText Typo="Typo.body2">@msg.Content</MudText>
                                </div>
                                <div class="technician-message-time">@msg.SentAt.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                }
            </div>
            
            <div class="technician-chat-input-area">
                <div class="d-flex gap-2">
                    <MudTextField T="string" 
                                 @bind-Value="_message" 
                                 Placeholder="Nhập tin nhắn..." 
                                 Variant="Variant.Outlined" 
                                 OnKeyDown="OnKeyPress"
                                 Class="technician-chat-input-field" />
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               OnClick="async () => await SendMessage()" 
                               Disabled="@string.IsNullOrWhiteSpace(_message)"
                               Class="technician-chat-send-button">
                        <MudIcon Icon="@Icons.Material.Filled.Send" />
                    </MudButton>
                </div>
            </div>
        }
    </div>
</div>

<style>
.technician-chat-container {
    display: flex;
    height: calc(100vh - 64px);
    background: #f5f5f5;
}

.technician-chat-sidebar {
    width: 350px;
    background: white;
    border-right: 1px solid #e0e0e0;
    display: flex;
    flex-direction: column;
}

.technician-chat-sidebar-header {
    padding: 20px;
    border-bottom: 1px solid #e0e0e0;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
}

.technician-chat-rooms-list {
    flex: 1;
    overflow-y: auto;
    padding: 10px;
}

.technician-chat-room-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 4px;
}

.technician-chat-room-item:hover {
    background: #f5f5f5;
}

.technician-chat-room-item.selected {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
}

.technician-chat-room-item.selected .technician-chat-room-last-message {
    color: rgba(255,255,255,0.8);
}

.technician-chat-room-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 18px;
    flex-shrink: 0;
}

.technician-chat-room-info {
    flex: 1;
    min-width: 0;
}

.technician-chat-room-name {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
}

.technician-chat-room-installation {
    font-size: 11px;
    color: #757575;
    margin-bottom: 4px;
}

.technician-chat-room-item.selected .technician-chat-room-installation {
    color: rgba(255,255,255,0.9);
}

.technician-chat-room-last-message {
    font-size: 12px;
    color: #757575;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.technician-chat-room-badge {
    background: #f44336;
    color: white;
    border-radius: 50%;
    min-width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: bold;
    padding: 0 6px;
}

.technician-chat-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: white;
}

.technician-chat-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
}

.technician-chat-header {
    padding: 16px 24px;
    border-bottom: 1px solid #e0e0e0;
    background: white;
}

.technician-chat-header-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.technician-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    background: #f5f5f5;
}

.technician-message {
    display: flex;
    margin-bottom: 16px;
    gap: 8px;
}

.technician-message.received {
    justify-content: flex-start;
}

.technician-message.sent {
    justify-content: flex-end;
}

.technician-message-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
    flex-shrink: 0;
}

.technician-message-content {
    max-width: 70%;
}

.technician-message-bubble {
    padding: 12px 16px;
    border-radius: 18px;
    margin-bottom: 4px;
}

.technician-message.received .technician-message-bubble {
    background: white;
    border-bottom-left-radius: 4px;
}

.technician-message.sent .technician-message-bubble {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    border-bottom-right-radius: 4px;
}

.technician-message-time {
    font-size: 11px;
    color: #757575;
    text-align: right;
}

.technician-message.sent .technician-message-time {
    color: rgba(255,255,255,0.8);
}

.technician-message-separator {
    display: flex;
    align-items: center;
    margin: 16px 0;
    gap: 12px;
}

.separator-line {
    flex: 1;
    height: 1px;
    background: #e0e0e0;
}

.separator-text {
    font-size: 12px;
    color: #999;
    font-weight: 500;
    white-space: nowrap;
}

.technician-chat-input-area {
    padding: 16px 24px;
    border-top: 1px solid #e0e0e0;
    background: white;
}

.technician-chat-input-field {
    flex: 1;
}

.technician-chat-send-button {
    min-width: 48px;
    height: 48px;
    border-radius: 50%;
}
</style>

@code {
    private List<ChatRoomResponse> _chatRooms = new();
    private List<ChatMessageResponse> _messages = new();
    private ChatRoomResponse? _selectedRoom;
    private int SelectedChatRoomId = 0;
    private string _message = "";
    private bool _loadingMessages = false;
    private bool _sending = false;
    private ElementReference _messagesContainer;
    private bool _initialized = false;
    private DateTime? _lastReadAt = null;
    private DateTime? _roomOpenTime = null;
    private bool _separatorShown = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        Console.WriteLine($"[TechnicianChatManagement] OnAfterRenderAsync called: firstRender={firstRender}, _initialized={_initialized}");
        
        if (firstRender && !_initialized)
        {
            try
            {
                Console.WriteLine("[TechnicianChatManagement] Initializing SignalR...");
                await SignalRService.InitializeAsync();
                SignalRService.OnChatMessageReceived += async (msg) => await OnMessageReceived(msg);
                await InvokeAsync(async () => await LoadChatRooms());
                _initialized = true;
                Console.WriteLine("[TechnicianChatManagement] Initialization completed successfully");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[TechnicianChatManagement] Initialization failed: {ex.Message}");
                await InvokeAsync(async () => await LoadChatRooms());
            }
        }
    }

    private async Task OnMessageReceived(object messageObj)
    {
        try
        {
            var messageJson = System.Text.Json.JsonSerializer.Serialize(messageObj);
            using var doc = System.Text.Json.JsonDocument.Parse(messageJson);
            if (doc.RootElement.TryGetProperty("chatRoomId", out var chatRoomIdElement) &&
                doc.RootElement.TryGetProperty("userId", out var userIdElement))
            {
                var messageRoomId = chatRoomIdElement.GetInt32();
                var senderId = userIdElement.GetInt32();
                var currentUserId = CurrentUser.UserId ?? 0;
                
                await InvokeAsync(async () => await LoadChatRooms());

                if (SelectedChatRoomId > 0 && messageRoomId == SelectedChatRoomId)
                {
                    if (senderId == currentUserId)
                    {
                        Console.WriteLine("[TechnicianChatManagement] Received own message - skipping reload");
                    }
                    else
                    {
                        await InvokeAsync(async () => await LoadMessages());
                        await ScrollToBottom();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Error processing message: {ex.Message}");
            await InvokeAsync(async () => await LoadChatRooms());
            if (SelectedChatRoomId > 0)
            {
                await InvokeAsync(async () => await LoadMessages());
            }
        }
    }

    private async Task LoadChatRooms()
    {
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            Console.WriteLine($"[TechnicianChatManagement] Loading chat rooms for technician user ID: {userId}");
            
            var rooms = await ChatService.GetInstallationChatRoomsAsync(userId);
            Console.WriteLine($"[TechnicianChatManagement] Found {rooms.Count} installation chat rooms");
            
            _chatRooms = rooms.Select(r => new ChatRoomResponse
            {
                Id = r.Id,
                Title = r.Title,
                Type = r.Type,
                IsActive = r.IsActive,
                CreatedAt = r.CreatedAt,
                ClosedAt = r.ClosedAt,
                RelatedOrderId = r.RelatedOrderId,
                RelatedInstallationId = r.RelatedInstallationId,
                RelatedWarrantyClaimId = r.RelatedWarrantyClaimId,
                Participants = r.Participants.Select(p => new ChatParticipantResponse
                {
                    Id = p.Id,
                    UserId = p.UserId,
                    UserType = p.UserType,
                    UserName = p.UserName,
                    UserAvatar = p.UserAvatar,
                    JoinedAt = p.JoinedAt,
                    IsActive = p.IsActive,
                    IsBlocked = p.IsBlocked,
                    UnreadCount = p.UnreadCount,
                    LastActivityAt = p.LastActivityAt,
                    LastReadAt = p.LastReadAt
                }).ToList(),
                LastMessage = r.LastMessage,
                UnreadCount = r.UnreadCount
            }).ToList();
            
            foreach (var room in _chatRooms)
            {
                Console.WriteLine($"[TechnicianChatManagement] Joining SignalR group for room {room.Id}");
                await SignalRService.JoinChatRoom(room.Id);
            }
            
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to load chat rooms: {ex.Message}");
        }
    }

    private async Task SelectChatRoom(int roomId)
    {
        SelectedChatRoomId = roomId;
        _roomOpenTime = DateTime.Now;
        _separatorShown = false;
        _selectedRoom = _chatRooms.FirstOrDefault(r => r.Id == roomId);
        await InvokeAsync(StateHasChanged);
        
        try
        {
            await SignalRService.JoinChatRoom(roomId);
            await InvokeAsync(async () => await LoadMessages());
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Error in SelectChatRoom: {ex.Message}");
        }
    }

    private async Task LoadMessages()
    {
        if (SelectedChatRoomId == 0) return;

        _loadingMessages = true;
        _separatorShown = false;
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            _messages = await ChatService.GetChatMessagesAsync(SelectedChatRoomId, userId, UserType.Technician);
            
            if (_selectedRoom != null)
            {
                var technicianParticipant = _selectedRoom.Participants.FirstOrDefault(p => p.UserType == "Technician");
                _lastReadAt = technicianParticipant?.LastReadAt;
            }
            
            await InvokeAsync(async () => await MarkAsRead());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to load messages: {ex.Message}");
        }
        finally
        {
            _loadingMessages = false;
            await InvokeAsync(StateHasChanged);
            try
            {
                await ScrollToBottom();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                Console.WriteLine("[TechnicianChatManagement] JS disconnected, skipping scroll");
            }
        }
    }

    private async Task MarkAsRead()
    {
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            await ChatService.MarkChatAsReadAsync(SelectedChatRoomId, userId);
            await InvokeAsync(async () => await LoadChatRooms());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to mark as read: {ex.Message}");
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_message) || SelectedChatRoomId == 0 || _sending) 
            return;

        var content = _message;
        var userId = CurrentUser.UserId ?? 0;
        _sending = true;

        try
        {
            var tempMessage = new ChatMessageResponse
            {
                Id = _messages.Count > 0 ? _messages.Max(m => m.Id) + 1 : 1,
                ChatRoomId = SelectedChatRoomId,
                SenderId = userId,
                SenderType = "Technician",
                SenderName = CurrentUser.UserName,
                Content = content,
                SentAt = DateTime.Now,
                IsFromMe = true
            };
            _messages.Add(tempMessage);
            _message = "";
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();

            await SignalRService.SendMessage(SelectedChatRoomId, userId, "Technician", content);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to send message: {ex.Message}");
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ');
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    private string GetSelectedRoomName()
    {
        var room = _chatRooms.FirstOrDefault(r => r.Id == SelectedChatRoomId);
        return room?.Title ?? "";
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("eval", @"
            const element = document.querySelector('.technician-chat-messages');
            if (element) {
                element.scrollTop = element.scrollHeight;
            }
        ");
    }
}
