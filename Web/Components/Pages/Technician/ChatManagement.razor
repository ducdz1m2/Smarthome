@code {
    private List<ChatRoomResponse> _chatRooms = new();
    private List<ChatMessageResponse> _messages = new();
    private ChatRoomResponse? _selectedRoom = null;
    private int SelectedChatRoomId = 0;
    private string _message = "";
    private bool _loadingMessages = false;
    private bool _sending = false;
    private ElementReference _messagesContainer;
    private bool _initialized = false;
    private DateTime? _lastReadAt = null;
    private DateTime? _roomOpenTime = null;
    private bool _separatorShown = false;
    private Action<object>? _onMessageReceivedHandler;
    private IBrowserFile? _selectedFile;
    private string _filePreviewUrl = "";
    private bool _isRecording = false;
    private bool _isTranscribing = false;
    private static readonly SemaphoreSlim _chatServiceLock = new SemaphoreSlim(1, 1);

    private bool CanSendMessage => !_sending && !_isRecording && !_isTranscribing && (!string.IsNullOrWhiteSpace(_message) || _selectedFile != null);

    public async ValueTask DisposeAsync()
    {
        Console.WriteLine("[TechnicianChatManagement] DisposeAsync called - unsubscribing from events");
        if (_onMessageReceivedHandler != null)
        {
            SignalRService.OnChatMessageReceived -= _onMessageReceivedHandler;
            Console.WriteLine("[TechnicianChatManagement] OnChatMessageReceived event unsubscribed");
        }
        if (_isRecording)
        {
            _ = SpeechRecognitionService.CancelRecordingAsync();
        }
        await Task.CompletedTask;
    }

    private async Task ToggleRecording()
    {
        if (_isRecording)
        {
            // Stop recording - JavaScript will automatically stop and invoke callback
            _isTranscribing = true;
            await InvokeAsync(StateHasChanged);
            await SpeechRecognitionService.CancelRecordingAsync();
        }
        else
        {
            // Start recording with callback
            _isRecording = true;
            await InvokeAsync(StateHasChanged);

            try
            {
                await SpeechRecognitionService.StartRecordingAsync(async (text) =>
                {
                    _isRecording = false;
                    _isTranscribing = false;

                    if (!string.IsNullOrWhiteSpace(text))
                    {
                        _message += (string.IsNullOrEmpty(_message) ? "" : " ") + text;
                    }

                    await InvokeAsync(StateHasChanged);
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[TechnicianChatManagement] Recording failed: {ex.Message}");
                _isRecording = false;
                _isTranscribing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        Console.WriteLine($"[TechnicianChatManagement] OnAfterRenderAsync called: firstRender={firstRender}, _initialized={_initialized}");
        
        if (firstRender && !_initialized)
        {
            try
            {
                Console.WriteLine("[TechnicianChatManagement] Initializing SignalR...");
                await SignalRService.InitializeAsync();
                _onMessageReceivedHandler = (msg) => _ = OnMessageReceived(msg);
                SignalRService.OnChatMessageReceived += _onMessageReceivedHandler;
                Console.WriteLine("[TechnicianChatManagement] OnChatMessageReceived event subscribed");
                await LoadChatRooms();
                _initialized = true;
                Console.WriteLine("[TechnicianChatManagement] Initialization completed successfully");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[TechnicianChatManagement] Initialization failed: {ex.Message}");
                await LoadChatRooms();
            }
        }
    }

    private async Task OnMessageReceived(object messageObj)
    {
        try
        {
            var messageJson = System.Text.Json.JsonSerializer.Serialize(messageObj);
            using var doc = System.Text.Json.JsonDocument.Parse(messageJson);
            if (doc.RootElement.TryGetProperty("chatRoomId", out var chatRoomIdElement) &&
                doc.RootElement.TryGetProperty("userId", out var userIdElement))
            {
                var messageRoomId = chatRoomIdElement.GetInt32();
                var senderId = userIdElement.GetInt32();
                var currentUserId = CurrentUser.UserId ?? 0;
                
                // If message is from someone else and NOT currently viewing that room, increment badge
                if (senderId != currentUserId && SelectedChatRoomId != messageRoomId)
                {
                    Console.WriteLine($"[TechnicianChatManagement] Trying to increment badge for room {messageRoomId}. Total rooms: {_chatRooms.Count}");
                    var room = _chatRooms.FirstOrDefault(r => r.Id == messageRoomId);
                    if (room != null)
                    {
                        Console.WriteLine($"[TechnicianChatManagement] Found room {messageRoomId}, checking participants...");
                        var technicianParticipant = room.Participants.FirstOrDefault(p => p.UserType == "Technician");
                        if (technicianParticipant != null)
                        {
                            technicianParticipant.UnreadCount++;
                            Console.WriteLine($"[TechnicianChatManagement] *** INCREMENTED BADGE *** for room {messageRoomId} to {technicianParticipant.UnreadCount}");
                            await InvokeAsync(StateHasChanged);
                            Console.WriteLine($"[TechnicianChatManagement] StateHasChanged called for badge update");
                        }
                        else
                        {
                            Console.WriteLine($"[TechnicianChatManagement] Technician participant not found in room {messageRoomId}");
                        }
                    }
                    else
                    {
                        Console.WriteLine($"[TechnicianChatManagement] Room {messageRoomId} not found in _chatRooms");
                    }
                }
                else if (senderId != currentUserId && SelectedChatRoomId == messageRoomId)
                {
                    // Currently viewing the room - mark as read immediately
                    Console.WriteLine($"[TechnicianChatManagement] Currently viewing room {messageRoomId}, marking as read without badge");
                    _ = MarkAsRead();
                }

                if (SelectedChatRoomId > 0 && messageRoomId == SelectedChatRoomId)
                {
                    if (senderId == currentUserId)
                    {
                        Console.WriteLine("[TechnicianChatManagement] Received own message - skipping reload");
                    }
                    else
                    {
                        await LoadMessages();
                        await ScrollToBottom();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Error processing message: {ex.Message}");
            await LoadChatRooms();
            if (SelectedChatRoomId > 0)
            {
                await LoadMessages();
            }
        }
    }

    private async Task LoadChatRooms()
    {
        await _chatServiceLock.WaitAsync();
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            Console.WriteLine($"[TechnicianChatManagement] Loading chat rooms for technician user ID: {userId}");
            
            var rooms = await ChatService.GetInstallationChatRoomsAsync(userId);
            Console.WriteLine($"[TechnicianChatManagement] Found {rooms.Count} installation chat rooms");
            
            _chatRooms = rooms.Select(r => new ChatRoomResponse
            {
                Id = r.Id,
                Title = r.Title,
                Type = r.Type,
                IsActive = r.IsActive,
                CreatedAt = r.CreatedAt,
                ClosedAt = r.ClosedAt,
                RelatedOrderId = r.RelatedOrderId,
                RelatedInstallationId = r.RelatedInstallationId,
                RelatedWarrantyClaimId = r.RelatedWarrantyClaimId,
                Participants = r.Participants.Select(p => new ChatParticipantResponse
                {
                    Id = p.Id,
                    UserId = p.UserId,
                    UserType = p.UserType,
                    UserName = p.UserName,
                    UserAvatar = p.UserAvatar,
                    JoinedAt = p.JoinedAt,
                    IsActive = p.IsActive,
                    IsBlocked = p.IsBlocked,
                    UnreadCount = p.UnreadCount,
                    LastActivityAt = p.LastActivityAt,
                    LastReadAt = p.LastReadAt
                }).ToList(),
                LastMessage = r.LastMessage,
                UnreadCount = r.UnreadCount
            }).ToList();
            
            foreach (var room in _chatRooms)
            {
                Console.WriteLine($"[TechnicianChatManagement] Joining SignalR group for room {room.Id}");
                await SignalRService.JoinChatRoom(room.Id);
            }
            
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to load chat rooms: {ex.Message}");
        }
        finally
        {
            _chatServiceLock.Release();
        }
    }

    private async Task SelectChatRoom(int roomId)
    {
        SelectedChatRoomId = roomId;
        _roomOpenTime = DateTime.Now;
        _separatorShown = false;
        _selectedRoom = _chatRooms.FirstOrDefault(r => r.Id == roomId);
        await InvokeAsync(StateHasChanged);
        
        try
        {
            await SignalRService.JoinChatRoom(roomId);
            
            // Mark chat as read to reset unread count when opening the room
            var userId = CurrentUser.UserId ?? 0;
            if (userId > 0)
            {
                await _chatServiceLock.WaitAsync();
                try
                {
                    Console.WriteLine($"[TechnicianChatManagement] Marking chat room {roomId} as read for user {userId}");
                    await ChatService.MarkChatAsReadAsync(roomId, userId);
                }
                finally
                {
                    _chatServiceLock.Release();
                }
            }
            
            // Reload chat rooms to update badge, then load messages
            await LoadChatRooms();
            await LoadMessages();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Error in SelectChatRoom: {ex.Message}");
        }
    }

    private async Task LoadMessages()
    {
        if (SelectedChatRoomId == 0) return;

        await _chatServiceLock.WaitAsync();
        try
        {
            _loadingMessages = true;
            _separatorShown = false;
            var userId = CurrentUser.UserId ?? 0;
            _messages = await ChatService.GetChatMessagesAsync(SelectedChatRoomId, userId, UserType.Technician);
            
            if (_selectedRoom != null)
            {
                var technicianParticipant = _selectedRoom.Participants.FirstOrDefault(p => p.UserType == "Technician");
                _lastReadAt = technicianParticipant?.LastReadAt;
            }
            
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to load messages: {ex.Message}");
        }
        finally
        {
            _loadingMessages = false;
            _chatServiceLock.Release();
            await InvokeAsync(StateHasChanged);
            try
            {
                await ScrollToBottom();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                Console.WriteLine("[TechnicianChatManagement] JS disconnected, skipping scroll");
            }
            // Mark as read after releasing lock
            _ = MarkAsRead();
        }
    }

    private async Task MarkAsRead()
    {
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            await _chatServiceLock.WaitAsync();
            try
            {
                await ChatService.MarkChatAsReadAsync(SelectedChatRoomId, userId);
            }
            finally
            {
                _chatServiceLock.Release();
            }
            // Note: LoadChatRooms should be called separately if needed
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to mark as read: {ex.Message}");
        }
    }

    private async Task SendMessage()
    {
        if (SelectedChatRoomId == 0 || _sending) 
            return;

        if (string.IsNullOrWhiteSpace(_message) && _selectedFile == null)
            return;

        var content = _message;
        var userId = CurrentUser.UserId ?? 0;
        _sending = true;

        // Upload file if selected
        string? fileUrl = null;
        string? fileName = null;
        string? fileType = null;
        long? fileSize = null;

        if (_selectedFile != null)
        {
            fileUrl = await UploadFileAsync(_selectedFile);
            if (fileUrl != null)
            {
                fileName = _selectedFile.Name;
                fileType = _selectedFile.ContentType;
                fileSize = _selectedFile.Size;
            }
            else
            {
                Console.WriteLine("[TechnicianChatManagement] File upload failed");
                if (string.IsNullOrWhiteSpace(_message))
                {
                    Console.WriteLine("[TechnicianChatManagement] Cannot send message: no content and file upload failed");
                    _sending = false;
                    return;
                }
            }
        }

        try
        {
            var tempMessage = new ChatMessageResponse
            {
                Id = _messages.Count > 0 ? _messages.Max(m => m.Id) + 1 : 1,
                ChatRoomId = SelectedChatRoomId,
                SenderId = userId,
                SenderType = "Technician",
                SenderName = CurrentUser.UserName,
                Content = content,
                SentAt = DateTime.Now,
                IsFromMe = true,
                Attachments = fileUrl != null ? new List<ChatAttachmentResponse>
                {
                    new ChatAttachmentResponse
                    {
                        FileUrl = fileUrl,
                        FileName = fileName ?? string.Empty,
                        FileType = fileType ?? string.Empty,
                        FileSize = fileSize ?? 0
                    }
                } : new()
            };
            _messages.Add(tempMessage);
            _message = "";
            _selectedFile = null;
            _filePreviewUrl = "";
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();

            await SignalRService.SendMessage(SelectedChatRoomId, userId, "Technician", content, fileUrl, fileName, fileType, fileSize);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Failed to send message: {ex.Message}");
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task TriggerFileSelect()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.technician-chat-file-input').click()");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            _selectedFile = file;
            
            if (_isImageFile(file))
            {
                using var stream = file.OpenReadStream(file.Size);
                using var ms = new System.IO.MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();
                _filePreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            }
            
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RemoveFile()
    {
        _selectedFile = null;
        _filePreviewUrl = "";
    }

    private bool _isImageFile(IBrowserFile file)
    {
        var imageExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        return imageExtensions.Contains(extension);
    }

    private async Task<string?> UploadFileAsync(IBrowserFile file)
    {
        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var token = await JwtTokenHandler.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                httpClient.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream());
            content.Add(fileContent, "file", file.Name);

            var uploadUrl = $"{Navigation.BaseUri}api/chat/upload";
            var response = await httpClient.PostAsync(uploadUrl, content);
            
            if (response.IsSuccessStatusCode)
            {
                var responseContent = await response.Content.ReadAsStringAsync();
                using var doc = System.Text.Json.JsonDocument.Parse(responseContent);
                return doc.RootElement.TryGetProperty("fileUrl", out var fileUrlElem) ? fileUrlElem.GetString() : null;
            }
            
            return null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatManagement] Upload failed: {ex.Message}");
            return null;
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ');
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    private string GetSelectedRoomName()
    {
        var room = _chatRooms.FirstOrDefault(r => r.Id == SelectedChatRoomId);
        return room?.Title ?? "";
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("eval", @"
            const element = document.querySelector('.technician-chat-messages');
            if (element) {
                element.scrollTop = element.scrollHeight;
            }
        ");
    }
