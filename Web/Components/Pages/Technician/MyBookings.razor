@page "/technician/bookings"
@page "/technician/bookings/{type}"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Web.Services
@using Web.Helpers
@inject IInstallationService InstallationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IAuthService AuthService
@inject HttpClient Http

<MudText Typo="Typo.h4" Class="mb-4">Lịch công việc của tôi</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" ActiveTab="@_activeTabIndex" ActiveTabChanged="OnTabChanged">
    <MudTabPanel Text="Lắp đặt" Icon="@Icons.Material.Filled.Build">
        @RenderBookingTable(_installationBookings, "installation")
    </MudTabPanel>
    <MudTabPanel Text="Bảo hành" Icon="@Icons.Material.Filled.Handyman">
        @RenderBookingTable(_warrantyBookings, "warranty")
    </MudTabPanel>
    <MudTabPanel Text="Tháo dỡ" Icon="@Icons.Material.Filled.Delete">
        @RenderBookingTable(_uninstallBookings, "uninstall")
    </MudTabPanel>
</MudTabs>

<!-- Prepare Materials Dialog Overlay -->
@if (_prepareMaterialsDialogOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <MudCard Style="width: 400px; max-width: 90%;">
            <MudCardHeader>
                <MudText Typo="Typo.h6">Chuẩn bị vật tư từ kho</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudSelect T="int" Label="Chọn kho" @bind-SelectedValue="_selectedWarehouseId">
                    @if (_warehouses.Any())
                    {
                        @foreach (var warehouse in _warehouses)
                        {
                            <MudSelectItem T="int" Value="@warehouse.Id">@warehouse.Name (@warehouse.Code)</MudSelectItem>
                        }
                    }
                    else
                    {
                        <MudSelectItem T="int" Value="0">Đang tải...</MudSelectItem>
                    }
                </MudSelect>
            </MudCardContent>
            <MudCardActions>
                <MudButton OnClick="(() => _prepareMaterialsDialogOpen = false)" Variant="Variant.Text">Hủy</MudButton>
                <MudButton OnClick="PrepareMaterials" Color="Color.Primary" Variant="Variant.Filled" Disabled="@_preparingMaterials">
                    @(_preparingMaterials ? "Đang chuẩn bị..." : "Xác nhận")
                </MudButton>
            </MudCardActions>
        </MudCard>
    </div>
}

@code {
    [Parameter]
    public string? type { get; set; }

    private List<InstallationBookingListResponse> _allBookings = new();
    private List<InstallationBookingListResponse> _installationBookings = new();
    private List<InstallationBookingListResponse> _warrantyBookings = new();
    private List<InstallationBookingListResponse> _uninstallBookings = new();
    private int _activeTabIndex = 0;
    private int _currentPageValue = 1;
    private int _pageSize = 5;
    
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    
    // For prepare materials dialog
    private int _selectedBookingId = 0;
    private bool _prepareMaterialsDialogOpen = false;
    private List<WarehouseResponse> _warehouses = new();
    private int _selectedWarehouseId = 0;
    private bool _preparingMaterials = false;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Set active tab based on URL parameter
        if (!string.IsNullOrEmpty(type))
        {
            _activeTabIndex = type.ToLower() switch
            {
                "installation" => 0,
                "warranty" => 1,
                "uninstall" => 2,
                _ => 0
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadBookings();
        }
    }

    private async Task LoadBookings()
    {
        if (_isLoading) return;
        _isLoading = true;

        try
        {
            var technicianId = await GetCurrentTechnicianId();
            if (technicianId == 0) return;

            Console.WriteLine($"[LoadBookings] Loading bookings for technician ID: {technicianId}");
            _allBookings = await InstallationService.GetByTechnicianAsync(technicianId);
            Console.WriteLine($"[LoadBookings] Loaded {_allBookings.Count} bookings");
            
            // Log status of the selected booking
            var selectedBooking = _allBookings.FirstOrDefault(b => b.Id == _selectedBookingId);
            if (selectedBooking != null)
            {
                Console.WriteLine($"[LoadBookings] Selected booking {_selectedBookingId} status: {selectedBooking.Status}");
            }

            // Filter by type
            _installationBookings = _allBookings.Where(b => !b.IsWarranty && !b.IsUninstall).ToList();
            _warrantyBookings = _allBookings.Where(b => b.IsWarranty).ToList();
            _uninstallBookings = _allBookings.Where(b => b.IsUninstall).ToList();

            Console.WriteLine($"[LoadBookings] Installation: {_installationBookings.Count}, Warranty: {_warrantyBookings.Count}, Uninstall: {_uninstallBookings.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadBookings] Error: {ex.Message}");
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<int> GetCurrentTechnicianId()
    {
        Console.WriteLine($"[GetCurrentTechnicianId] Getting technician ID...");
        var technicianId = await AuthService.GetTechnicianIdAsync();
        Console.WriteLine($"[GetCurrentTechnicianId] Technician ID: {technicianId}");
        return technicianId ?? 0;
    }

    private void OnTabChanged(int index)
    {
        _activeTabIndex = index;
        _currentPageValue = 1; // Reset to first page when changing tabs
        var type = index switch
        {
            0 => "installation",
            1 => "warranty",
            2 => "uninstall",
            _ => ""
        };
        NavigationManager.NavigateTo($"/technician/bookings/{type}");
    }

    private int GetTotalPages(List<InstallationBookingListResponse> bookings)
    {
        return (int)Math.Ceiling(bookings.Count / (double)_pageSize);
    }

    private List<InstallationBookingListResponse> GetPagedBookings(List<InstallationBookingListResponse> bookings)
    {
        var skip = (_currentPageValue - 1) * _pageSize;
        return bookings.Skip(skip).Take(_pageSize).ToList();
    }

    private void ChangePage(int page)
    {
        _currentPageValue = page;
        StateHasChanged();
    }

    private RenderFragment RenderBookingTable(List<InstallationBookingListResponse> bookings, string bookingType)
    {
        var pagedBookings = GetPagedBookings(bookings);
        var totalPages = GetTotalPages(bookings);
        
        return @<text>
            @if (!bookings.Any())
            {
                <MudAlert Severity="Severity.Info" Class="my-4">Không có lịch @(bookingType == "installation" ? "lắp đặt" : bookingType == "warranty" ? "bảo hành" : "tháo dỡ") nào.</MudAlert>
            }
            else
            {
                <MudTable Items="pagedBookings" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Mã đơn</MudTh>
                        <MudTh>Khách hàng</MudTh>
                        <MudTh>Ngày làm</MudTh>
                        <MudTh>Khung giờ</MudTh>
                        <MudTh>Trạng thái</MudTh>
                        <MudTh>Thao tác</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.OrderNumber</MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2">@context.CustomerName</MudText>
                            <MudText Typo="Typo.caption">@context.CustomerPhone</MudText>
                        </MudTd>
                        <MudTd>@context.ScheduledDate.Date.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd>@context.StartTime?.ToString("hh\\:mm") - @context.EndTime?.ToString("hh\\:mm")</MudTd>
                        <MudTd>
                            @{
                                var isUninstall = bookingType == "uninstall";
                            }
                            <MudChip T="string" Size="Size.Small" Color="StatusHelper.GetInstallationStatusColor(context.Status, isUninstall)">@StatusHelper.GetInstallationStatusText(context.Status, isUninstall)</MudChip>
                        </MudTd>
                        <MudTd>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       Href="@($"/technician/bookings/{context.Id}")">Chi tiết</MudButton>
                            @if (context.Status == "Assigned")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="ml-2"
                                           OnClick="() => AcceptBooking(context.Id)">Tiếp nhận</MudButton>
                            }
                            @if (context.Status == "Confirmed")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="ml-2"
                                           OnClick="() => OpenPrepareMaterialsDialog(context.Id)">Chuẩn bị vật tư</MudButton>
                            }
                            @if (context.Status == "Preparing")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="ml-2"
                                           OnClick="() => StartTravel(context.Id)">Bắt đầu đi</MudButton>
                            }
                            @if (context.Status == "OnTheWay")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" Class="ml-2"
                                           OnClick="() => StartInstallation(context.Id)">Bắt đầu làm</MudButton>
                            }
                            @if (context.Status == "Installing")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="ml-2"
                                           OnClick="() => CompleteBooking(context.Id)">Hoàn thành</MudButton>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                @if (totalPages > 1)
                {
                    <div class="d-flex justify-center align-center mt-4 gap-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   Disabled="@(_currentPageValue == 1)"
                                   OnClick="() => ChangePage(_currentPageValue - 1)">
                            Trang trước
                        </MudButton>
                        <MudText Typo="Typo.body2" Class="mx-2">
                            Trang @_currentPageValue / @totalPages
                        </MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   Disabled="@(_currentPageValue == totalPages)"
                                   OnClick="() => ChangePage(_currentPageValue + 1)">
                            Trang sau
                        </MudButton>
                    </div>
                }
            }
        </text>;
    }

    private async Task AcceptBooking(int bookingId)
    {
        try
        {
            var technicianId = await GetCurrentTechnicianId();
            await InstallationService.AcceptBookingAsync(bookingId, technicianId);
            Snackbar.Add("Đã tiếp nhận lịch lắp đặt", Severity.Success);
            await LoadBookings();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task StartTravel(int bookingId)
    {
        try
        {
            await InstallationService.StartTravelAsync(bookingId);
            Snackbar.Add("Đã bắt đầu di chuyển", Severity.Success);
            await LoadBookings();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task StartInstallation(int bookingId)
    {
        try
        {
            await InstallationService.StartInstallationAsync(bookingId);
            Snackbar.Add("Đã bắt đầu lắp đặt", Severity.Success);
            await LoadBookings();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task CompleteBooking(int bookingId)
    {
        Console.WriteLine($"[CompleteBooking] ========== METHOD CALLED for booking ID: {bookingId} ==========");
        try
        {
            Console.WriteLine($"[CompleteBooking] Starting complete for booking ID: {bookingId}");
            var completeRequest = new CompleteInstallationRequest
            {
                CustomerSignature = "",
                CustomerRating = 5,
                Notes = ""
            };
            Console.WriteLine($"[CompleteBooking] About to call InstallationService.CompleteAsync");
            await InstallationService.CompleteAsync(bookingId, completeRequest);
            Console.WriteLine($"[CompleteBooking] InstallationService.CompleteAsync finished successfully");
            Snackbar.Add("Đã hoàn thành lắp đặt", Severity.Success);
            await LoadBookings();
            Console.WriteLine($"[CompleteBooking] LoadBookings finished");
            StateHasChanged();
            Console.WriteLine($"[CompleteBooking] StateHasChanged called");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CompleteBooking] Error: {ex.Message}");
            Console.WriteLine($"[CompleteBooking] Stack trace: {ex.StackTrace}");
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenPrepareMaterialsDialog(int bookingId)
    {
        Console.WriteLine($"[OpenPrepareMaterialsDialog] Opening dialog for booking ID: {bookingId}");
        _selectedBookingId = bookingId;
        await LoadWarehouses();
        Console.WriteLine($"[OpenPrepareMaterialsDialog] Warehouses loaded: {_warehouses.Count}");
        _prepareMaterialsDialogOpen = true;
        Console.WriteLine($"[OpenPrepareMaterialsDialog] Dialog open: {_prepareMaterialsDialogOpen}");
        StateHasChanged();
    }

    private async Task LoadWarehouses()
    {
        try
        {
            Console.WriteLine($"[LoadWarehouses] Loading warehouses from /api/warehouses");
            var response = await Http.GetFromJsonAsync<List<WarehouseResponse>>("/api/warehouses");
            Console.WriteLine($"[LoadWarehouses] Response: {response?.Count ?? 0} warehouses");
            if (response != null)
            {
                _warehouses = response;
                _selectedWarehouseId = _warehouses.FirstOrDefault()?.Id ?? 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadWarehouses] Error: {ex.Message}");
            Snackbar.Add($"Lỗi tải danh sách kho: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrepareMaterials()
    {
        if (_selectedWarehouseId == 0)
        {
            Snackbar.Add("Vui lòng chọn kho", Severity.Warning);
            return;
        }

        try
        {
            _preparingMaterials = true;
            
            // Get booking details to get products
            var bookingDetails = await InstallationService.GetByIdAsync(_selectedBookingId);
            if (bookingDetails == null)
            {
                Snackbar.Add("Không tìm thấy lịch lắp đặt", Severity.Error);
                return;
            }

            var request = new PrepareMaterialsRequest
            {
                WarehouseId = _selectedWarehouseId,
                Items = bookingDetails.Products.Select(p => new MaterialPreparationItem
                {
                    ProductId = p.ProductId,
                    VariantId = null,
                    Quantity = p.Quantity
                }).ToList()
            };

            await InstallationService.PrepareMaterialsFromWarehouseAsync(_selectedBookingId, request);
            Snackbar.Add("Đã chuẩn bị vật tư thành công", Severity.Success);
            _prepareMaterialsDialogOpen = false;
            Console.WriteLine($"[PrepareMaterials] About to reload bookings");
            await LoadBookings();
            Console.WriteLine($"[PrepareMaterials] Bookings reloaded");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _preparingMaterials = false;
        }
    }

    private class WarehouseResponse
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Code { get; set; } = string.Empty;
    }
}
