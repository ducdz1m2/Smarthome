@page "/admin/categories"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using MudBlazor
@using Web.Components.Shared
@using Web.Components.Shared.Common
@layout AdminLayout
@inject ICategoryService CategoryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageHeader Title="Quản lý Danh mục" AddButtonText="Thêm danh mục" OnAddClick="@(() => OpenCategoryDialog(null))" />

<DataTable Items="_categories" Title="Danh sách danh mục" Loading="_loading"
           FilterFunc="@FilterCategories">
    <HeaderContent>
        <MudTh width="60px"><MudTableSortLabel T="CategoryResponse" SortBy="@(c => c.Id)">ID</MudTableSortLabel></MudTh>
        <MudTh width="250px"><MudTableSortLabel T="CategoryResponse" SortBy="@(c => c.Name)">Tên danh mục</MudTableSortLabel></MudTh>
        <MudTh width="150px">Danh mục cha</MudTh>
        <MudTh width="100px"><MudTableSortLabel T="CategoryResponse" SortBy="@(c => c.SortOrder)">Thứ tự</MudTableSortLabel></MudTh>
        <MudTh width="120px"><MudTableSortLabel T="CategoryResponse" SortBy="@(c => c.IsActive)">Trạng thái</MudTableSortLabel></MudTh>
        <MudTh width="100px"><MudTableSortLabel T="CategoryResponse" SortBy="@(c => c.ProductCount)">Số SP</MudTableSortLabel></MudTh>
        <MudTh width="100px">Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Tên">
            <div style="padding-left: @(GetIndentLevel(context) * 20)px">
                @if (context.Children?.Any() == true)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-2" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" Class="mr-2" />
                }
                @context.Name
            </div>
        </MudTd>
        <MudTd DataLabel="Danh mục cha">@context.ParentName</MudTd>
        <MudTd DataLabel="Thứ tự">@context.SortOrder</MudTd>
        <MudTd DataLabel="Trạng thái">
            <StatusSwitch IsActive="@context.IsActive" ItemId="@context.Id" OnToggle="@(async (id, isActive) => await ToggleStatus(id, isActive))" />
        </MudTd>
        <MudTd DataLabel="Số SP">@context.ProductCount</MudTd>
        <MudTd>
            <ActionButtons ShowAdd="false" ShowView="false" 
                          DeleteDisabled="@(context.ProductCount > 0 || context.Children?.Any() == true)"
                          OnEdit="@(() => OpenCategoryDialog(context))" 
                          OnDelete="@(() => DeleteCategory(context))" />
        </MudTd>
    </RowTemplate>
</DataTable>

@code {
    private List<CategoryResponse> _categories = new();
    private List<CategoryResponse> _flatCategories = new();
    private bool _loading = true;
    private string _searchString = "";

    private bool FilterCategories(CategoryResponse category)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        
        return category.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               (category.Description?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (category.ParentName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        _loading = true;
        try
        {
            _flatCategories = await CategoryService.GetAllAsync();
            // Chỉ lấy root categories (không có ParentId) để flatten, tránh trùng lặp
            var rootCategories = _flatCategories.Where(c => c.ParentId == null).ToList();
            _categories = FlattenHierarchy(rootCategories);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải danh sách: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private List<CategoryResponse> FlattenHierarchy(List<CategoryResponse> categories, int level = 0)
    {
        var result = new List<CategoryResponse>();
        foreach (var cat in categories.OrderBy(c => c.SortOrder))
        {
            result.Add(cat);
            if (cat.Children?.Any() == true)
            {
                result.AddRange(FlattenHierarchy(cat.Children, level + 1));
            }
        }
        return result;
    }

    private int GetIndentLevel(CategoryResponse category)
    {
        int level = 0;
        var parent = _flatCategories.FirstOrDefault(c => c.Id == category.ParentId);
        while (parent != null)
        {
            level++;
            parent = _flatCategories.FirstOrDefault(c => c.Id == parent.ParentId);
        }
        return level;
    }

    private async Task OpenCategoryDialog(CategoryResponse? category)
    {
        var parameters = new DialogParameters<CategoryDialog>();
        if (category != null)
        {
            parameters.Add(x => x.CategoryId, category.Id);
        }
        parameters.Add(x => x.Categories, _flatCategories);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CategoryDialog>(category == null ? "Thêm danh mục" : "Sửa danh mục", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadCategories();
        }
    }

    private async Task ToggleStatus(int id, bool isActive)
    {
        try
        {
            if (isActive)
                await CategoryService.ActivateAsync(id);
            else
                await CategoryService.DeactivateAsync(id);
            
            Snackbar.Add($"Đã {(isActive ? "kích hoạt" : "vô hiệu hóa")} danh mục", Severity.Success);
            await LoadCategories();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
            await LoadCategories();
        }
    }

    private async Task DeleteCategory(CategoryResponse category)
    {
        if (category.ProductCount > 0 || category.Children?.Any() == true)
        {
            Snackbar.Add("Không thể xóa danh mục đã có sản phẩm hoặc danh mục con", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters
        {
            { "Title", "Xác nhận xóa" },
            { "Content", $"Bạn có chắc muốn xóa danh mục \"{category.Name}\"?" },
            { "ConfirmText", "Xóa" },
            { "CancelText", "Hủy" }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                await CategoryService.DeleteAsync(category.Id);
                Snackbar.Add("Đã xóa danh mục", Severity.Success);
                await LoadCategories();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi khi xóa: {ex.Message}", Severity.Error);
            }
        }
    }
}
