@page "/admin/installations"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using Web.Helpers
@using Web.Components.Shared.Common
@using Web.Services

@inject IInstallationService InstallationService
@inject ITechnicianProfileService TechnicianService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IWarehouseService WarehouseService
@inject InstallationApiService InstallationApiService

<PageHeader Title="Quản lý Lịch Lắp đặt" AddButtonText="Thêm lịch lắp đặt" OnAddClick="@(() => OpenDialog(null))" />

@if (_awaitingMaterialCount > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        <MudText Typo="Typo.body1">
            <b>Đang chờ xử lý:</b> Có @_awaitingMaterialCount lịch bảo hành đang chờ vật tư (hết sản phẩm thay thế).
            Vui lòng chuyển đến tab "Bảo hành" và lọc theo trạng thái "Chờ vật tư" để xử lý.
        </MudText>
    </MudAlert>
}

<MudTabs Elevation="2" Rounded="true" ApplyEffects="true">
    <MudTabPanel Text="Lắp đặt">
        <FilterBar>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" @bind-Value="_statusFilter" Label="Trạng thái"
                           Clearable="true" Dense="true" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="string" Value="@("Assigned")">Chờ KT xác nhận</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Preparing")">KT chuẩn bị</MudSelectItem>
                    <MudSelectItem T="string" Value="@("OnTheWay")">Đang di chuyển</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Installing")">Đang lắp</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">Hoàn thành</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cancelled")">Đã hủy</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadData">
                    Lọc
                </MudButton>
            </MudItem>
        </FilterBar>

        <DataTable Items="_installBookings" Title="Danh sách lịch lắp đặt" Loading="_loading"
                   FilterFunc="@FilterItems">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Đơn hàng</MudTh>
                <MudTh>Kỹ thuật viên</MudTh>
                <MudTh><MudTableSortLabel T="InstallationBookingListResponse" SortBy="@(b => b.ScheduledDate)">Ngày lắp</MudTableSortLabel></MudTh>
                <MudTh>Khung giờ</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Thao tác</MudTh>
            </HeaderContent>
            <RowTemplate Context="booking">
                <MudTd DataLabel="ID">@booking.Id</MudTd>
                <MudTd DataLabel="Đơn hàng">#@booking.OrderId</MudTd>
                <MudTd DataLabel="Kỹ thuật viên">@(booking.TechnicianName ?? "Chưa phân công")</MudTd>
                <MudTd DataLabel="Ngày lắp">@booking.ScheduledDate.ToLocalTime().ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Khung giờ">
                    @if (booking.StartTime.HasValue && booking.EndTime.HasValue)
                    {
                        <span>@booking.StartTime.Value.ToString(@"hh\:mm") - @booking.EndTime.Value.ToString(@"hh\:mm")</span>
                    }
                    else
                    {
                        <span>--:--</span>
                    }
                </MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Color="@StatusHelper.GetInstallationStatusColor(booking.Status, booking.IsUninstall)" Size="Size.Small">
                        @StatusHelper.GetInstallationStatusText(booking.Status, booking.IsUninstall)
                    </MudChip>
                </MudTd>
                <MudTd>
                    <ActionButtons ShowView="false" ShowAdd="false"
                                  OnEdit="@(() => OpenDialog(booking))"
                                  OnDelete="@(() => DeleteItem(booking))" />
                </MudTd>
            </RowTemplate>
        </DataTable>
    </MudTabPanel>

    <MudTabPanel Text="Bảo hành">
        <FilterBar>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" @bind-Value="_statusFilter" Label="Trạng thái"
                           Clearable="true" Dense="true" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="string" Value="@("Assigned")">Chờ KT xác nhận</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Preparing")">KT chuẩn bị</MudSelectItem>
                    <MudSelectItem T="string" Value="@("OnTheWay")">Đang di chuyển</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Installing")">Đang bảo hành</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">Hoàn thành</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cancelled")">Đã hủy</MudSelectItem>
                    <MudSelectItem T="string" Value="@("AwaitingMaterial")">Chờ vật tư</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadData">
                    Lọc
                </MudButton>
            </MudItem>
        </FilterBar>

        <DataTable Items="_warrantyBookings" Title="Danh sách lịch bảo hành" Loading="_loading"
                   FilterFunc="@FilterItems">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Đơn hàng</MudTh>
                <MudTh>Kỹ thuật viên</MudTh>
                <MudTh><MudTableSortLabel T="InstallationBookingListResponse" SortBy="@(b => b.ScheduledDate)">Ngày bảo hành</MudTableSortLabel></MudTh>
                <MudTh>Khung giờ</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Thao tác</MudTh>
            </HeaderContent>
            <RowTemplate Context="booking">
                <MudTd DataLabel="ID">@booking.Id</MudTd>
                <MudTd DataLabel="Đơn hàng">#@booking.OrderId</MudTd>
                <MudTd DataLabel="Kỹ thuật viên">@(booking.TechnicianName ?? "Chưa phân công")</MudTd>
                <MudTd DataLabel="Ngày bảo hành">@booking.ScheduledDate.ToLocalTime().ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Khung giờ">
                    @if (booking.StartTime.HasValue && booking.EndTime.HasValue)
                    {
                        <span>@booking.StartTime.Value.ToString(@"hh\:mm") - @booking.EndTime.Value.ToString(@"hh\:mm")</span>
                    }
                    else
                    {
                        <span>--:--</span>
                    }
                </MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Color="@StatusHelper.GetInstallationStatusColor(booking.Status, booking.IsUninstall)" Size="Size.Small">
                        @StatusHelper.GetInstallationStatusText(booking.Status, booking.IsUninstall)
                    </MudChip>
                </MudTd>
                <MudTd>
                    @if (booking.Status == "AwaitingMaterial")
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenTransferDialog(booking))">
                            Chuyển kho
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" OnClick="@(() => OpenDialog(booking))" Class="ml-1">
                            Sửa
                        </MudButton>
                    }
                    else
                    {
                        <ActionButtons ShowView="false" ShowAdd="false"
                                      OnEdit="@(() => OpenDialog(booking))"
                                      OnDelete="@(() => DeleteItem(booking))" />
                    }
                </MudTd>
            </RowTemplate>
        </DataTable>
    </MudTabPanel>

    <MudTabPanel Text="Tháo dỡ">
        <FilterBar>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string" @bind-Value="_statusFilter" Label="Trạng thái"
                           Clearable="true" Dense="true" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="string" Value="@("Assigned")">Chờ KT xác nhận</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Preparing")">KT chuẩn bị</MudSelectItem>
                    <MudSelectItem T="string" Value="@("OnTheWay")">Đang di chuyển</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Installing")">Đang tháo dỡ</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">Hoàn thành</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cancelled")">Đã hủy</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadData">
                    Lọc
                </MudButton>
            </MudItem>
        </FilterBar>

        <DataTable Items="_uninstallBookings" Title="Danh sách lịch tháo dỡ" Loading="_loading"
                   FilterFunc="@FilterItems">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Đơn hàng</MudTh>
                <MudTh>Kỹ thuật viên</MudTh>
                <MudTh><MudTableSortLabel T="InstallationBookingListResponse" SortBy="@(b => b.ScheduledDate)">Ngày tháo dỡ</MudTableSortLabel></MudTh>
                <MudTh>Khung giờ</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Thao tác</MudTh>
            </HeaderContent>
            <RowTemplate Context="booking">
                <MudTd DataLabel="ID">@booking.Id</MudTd>
                <MudTd DataLabel="Đơn hàng">#@booking.OrderId</MudTd>
                <MudTd DataLabel="Kỹ thuật viên">@(booking.TechnicianName ?? "Chưa phân công")</MudTd>
                <MudTd DataLabel="Ngày tháo dỡ">@booking.ScheduledDate.ToLocalTime().ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Khung giờ">
                    @if (booking.StartTime.HasValue && booking.EndTime.HasValue)
                    {
                        <span>@booking.StartTime.Value.ToString(@"hh\:mm") - @booking.EndTime.Value.ToString(@"hh\:mm")</span>
                    }
                    else
                    {
                        <span>--:--</span>
                    }
                </MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Color="@StatusHelper.GetInstallationStatusColor(booking.Status, booking.IsUninstall)" Size="Size.Small">
                        @StatusHelper.GetInstallationStatusText(booking.Status, booking.IsUninstall)
                    </MudChip>
                </MudTd>
                <MudTd>
                    <ActionButtons ShowView="false" ShowAdd="false"
                                  OnEdit="@(() => OpenDialog(booking))"
                                  OnDelete="@(() => DeleteItem(booking))" />
                </MudTd>
            </RowTemplate>
        </DataTable>
    </MudTabPanel>
</MudTabs>

@code {
    private List<InstallationBookingListResponse> _bookings = new();
    private List<InstallationBookingListResponse> _installBookings = new();
    private List<InstallationBookingListResponse> _warrantyBookings = new();
    private List<InstallationBookingListResponse> _uninstallBookings = new();
    private List<TechnicianResponse> _technicians = new();
    private bool _loading = true;
    private string _searchString = "";
    private string? _statusFilter;
    private int _awaitingMaterialCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadTechnicians();
        await LoadData();
    }

    private async Task LoadTechnicians()
    {
        try
        {
            _technicians = await TechnicianService.GetAvailableAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải kỹ thuật viên: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _bookings = await InstallationService.GetAllAsync();

            // Filter into 3 categories
            _installBookings = _bookings.Where(b => !b.IsWarranty && !b.IsUninstall).ToList();
            _warrantyBookings = _bookings.Where(b => b.IsWarranty && !b.IsUninstall).ToList();
            _uninstallBookings = _bookings.Where(b => b.IsUninstall).ToList();

            // Count bookings waiting for materials
            _awaitingMaterialCount = _warrantyBookings.Count(b => b.Status == "AwaitingMaterial");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải dữ liệu: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterItems(InstallationBookingListResponse booking)
    {
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            return booking.OrderId.ToString().Contains(_searchString) ||
                   (booking.TechnicianName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
        }

        if (!string.IsNullOrWhiteSpace(_statusFilter))
        {
            return booking.Status == _statusFilter;
        }

        return true;
    }

    private async Task OpenDialog(InstallationBookingListResponse? booking)
    {
        var parameters = new DialogParameters<InstallationBookingDialog>();
        if (booking != null)
        {
            parameters.Add(x => x.BookingId, booking.Id);
        }

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<InstallationBookingDialog>(booking == null ? "Thêm lịch lắp đặt" : "Sửa lịch lắp đặt", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteItem(InstallationBookingListResponse booking)
    {
        var parameters = new DialogParameters
        {
            { "Title", "Xác nhận xóa" },
            { "Content", $"Bạn có chắc muốn xóa lịch lắp đặt #{booking.Id}?" },
            { "ConfirmText", "Xóa" },
            { "CancelText", "Hủy" }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                await InstallationService.DeleteAsync(booking.Id);
                Snackbar.Add("Đã xóa lịch lắp đặt", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi khi xóa: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenTransferDialog(InstallationBookingListResponse booking)
    {
        try
        {
            var bookingDetails = await InstallationService.GetByIdAsync(booking.Id);
            if (bookingDetails == null || !bookingDetails.Products.Any())
            {
                Snackbar.Add("Không tìm thấy sản phẩm trong booking", Severity.Warning);
                return;
            }

            // Get all warehouses for source (show all that have stock)
            var allWarehouses = await WarehouseService.GetAllAsync();

            // Filter destination warehouses to only show those in same district/city as booking
            List<WarehouseResponse> destinationWarehouses;
            if (!string.IsNullOrWhiteSpace(bookingDetails.District))
            {
                destinationWarehouses = allWarehouses.Where(w => w.AddressDistrict == bookingDetails.District).ToList();
            }
            else if (!string.IsNullOrWhiteSpace(bookingDetails.City))
            {
                destinationWarehouses = allWarehouses.Where(w => w.AddressCity == bookingDetails.City).ToList();
            }
            else
            {
                destinationWarehouses = allWarehouses;
            }

            // Auto-select first destination warehouse as default
            int toWarehouseId = destinationWarehouses.FirstOrDefault()?.Id ?? 0;

            var parameters = new DialogParameters<WarehouseTransferDialog>
            {
                { x => x.AvailableWarehouses, allWarehouses }, // Source: all warehouses
                { x => x.DestinationWarehouses, destinationWarehouses } // Destination: filtered by location
            };

            // Pass booking materials if available (materials already taken by technician)
            // Otherwise, pass booking products (products that need to be installed)
            if (bookingDetails.Materials.Any())
            {
                var materialsNeedingTransfer = bookingDetails.Materials.Where(m => m.QuantityTaken > 0).ToList();
                if (materialsNeedingTransfer.Any())
                {
                    parameters.Add(x => x.BookingMaterials, materialsNeedingTransfer);
                }
            }
            else
            {
                // For bookings with no materials prepared (e.g., reported out of stock),
                // convert Products to InstallationMaterialResponse format
                var productsAsMaterials = bookingDetails.Products.Select(p => new InstallationMaterialResponse
                {
                    Id = p.ProductId, // Use ProductId as temporary Id for selection tracking
                    ProductId = p.ProductId,
                    VariantId = p.VariantId,
                    ProductName = p.ProductName,
                    QuantityTaken = p.Quantity, // Default to required quantity
                    QuantityUsed = null
                }).ToList();
                parameters.Add(x => x.BookingMaterials, productsAsMaterials);
            }

            if (toWarehouseId > 0)
            {
                parameters.Add(x => x.ToWarehouseId, toWarehouseId);
            }

            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<WarehouseTransferDialog>("Chuyển kho", parameters, options);
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                // Prompt admin to select a date for rescheduling
                var dateDialog = await DialogService.ShowAsync<DateSelectionDialog>("Chọn ngày thực hiện",
                    new DialogParameters { },
                    new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
                var dateResult = await dateDialog.Result;

                if (!dateResult.Canceled && dateResult.Data != null)
                {
                    var selectedDate = (DateTime)dateResult.Data;

                    // Reset booking status to Assigned with selected date
                    await InstallationService.ResetFromAwaitingMaterialAsync(booking.Id, selectedDate);

                    // For warranty bookings without a slot (no time assigned), prompt admin to assign a slot
                    if (booking.IsWarranty && booking.StartTime == null && booking.EndTime == null)
                    {
                        Snackbar.Add("Đã chuyển kho. Vui lòng xếp lịch cho kỹ thuật viên.", Severity.Info);
                        await OpenDialog(booking);
                    }
                    else
                    {
                        Snackbar.Add("Đã chuyển kho và reset trạng thái booking", Severity.Success);
                    }
                    await LoadData();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi mở dialog chuyển kho: {ex.Message}", Severity.Error);
        }
    }
}
