@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@inject IInstallationService InstallationService
@inject ITechnicianProfileService TechnicianService
@inject IInstallationSlotService SlotService
@inject IOrderService OrderService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_request.OrderId"
                             Label="Đơn hàng *"
                             Required="true" RequiredError="Chọn đơn hàng"
                             Variant="Variant.Outlined" Class="mb-3"
                             Disabled="_isEdit">
                        @foreach (var order in _orders)
                        {
                            <MudSelectItem T="int" Value="@order.Id">
                                #@order.OrderNumber - @order.ReceiverName (@order.Status)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_scheduledDate" 
                                   Label="Ngày lắp đặt *"
                                   Required="true" RequiredError="Chọn ngày lắp đặt"
                                   Variant="Variant.Outlined" Class="mb-3"
                                   MinDate="DateTime.Today" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSelect T="int" Value="_request.TechnicianId" 
                               Label="Kỹ thuật viên *"
                               Required="true" RequiredError="Chọn kỹ thuật viên"
                               Variant="Variant.Outlined" Class="mb-3"
                               ValueChanged="OnTechnicianChanged">
                        @foreach (var tech in _technicians)
                        {
                            <MudSelectItem T="int" Value="@tech.Id">@tech.FullName (@string.Join(", ", tech.Districts))</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_request.SlotId" 
                               Label="Khung giờ *"
                               Required="true" RequiredError="Chọn khung giờ"
                               Variant="Variant.Outlined" Class="mb-3"
                               Disabled="!_selectedTechnicianId.HasValue || _availableSlots.Count == 0">
                        @foreach (var slot in _availableSlots)
                        {
                            <MudSelectItem T="int" Value="@slot.Id">
                                @slot.StartTime.ToString("hh\\:mm") - @slot.EndTime.ToString("hh\\:mm")
                            </MudSelectItem>
                        }
                    </MudSelect>
                    @if (_selectedTechnicianId.HasValue && _availableSlots.Count == 0)
                    {
                        <MudText Color="Color.Warning" Typo="Typo.caption">
                            Không có slot trống cho ngày này
                        </MudText>
                    }
                </MudItem>
                
                @if (_isEdit && _booking != null)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-4" />
                        
                        <MudAlert Severity="Severity.Info" Class="mb-3">
                            <b>Thông tin:</b> Bạn có thể thay đổi kỹ thuật viên hoặc khung giờ lắp đặt. 
                            Trạng thái lắp đặt sẽ được kỹ thuật viên tự cập nhật.
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">
            @(_isEdit ? "Cập nhật" : "Thêm mới")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int? BookingId { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isEdit => BookingId.HasValue;
    
    private List<TechnicianResponse> _technicians = new();
    private List<InstallationSlotResponse> _availableSlots = new();
    private List<OrderResponse> _orders = new();
    private InstallationBookingResponse? _booking;

    private CreateInstallationBookingRequest _request = new()
    {
        OrderId = 0,
        TechnicianId = 0,
        SlotId = 0,
        ScheduledDate = DateTime.Today
    };

    private DateTime? _scheduledDate = DateTime.Today;
    private int? _selectedTechnicianId;

    protected override async Task OnInitializedAsync()
    {
        await LoadTechnicians();
        await LoadOrders();
        if (_isEdit)
        {
            await LoadBooking();
        }
        else
        {
            // Set default values for new booking
            var firstTech = _technicians.FirstOrDefault();
            if (firstTech != null)
            {
                _selectedTechnicianId = firstTech.Id;
                _request.TechnicianId = firstTech.Id;
                await LoadAvailableSlots();
            }
        }
    }

    private async Task LoadTechnicians()
    {
        try
        {
            _technicians = await TechnicianService.GetAvailableAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải kỹ thuật viên: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadOrders()
    {
        try
        {
            _orders = await OrderService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải đơn hàng: {ex.Message}", Severity.Error);
        }
    }

    private void OnOrderChanged(int orderId)
    {
        _request.OrderId = orderId;
    }

    private async Task LoadBooking()
    {
        try
        {
            _booking = await InstallationService.GetByIdAsync(BookingId!.Value);
            if (_booking != null)
            {
                _request = new CreateInstallationBookingRequest
                {
                    OrderId = _booking.OrderId,
                    TechnicianId = _booking.TechnicianId ?? 0,
                    SlotId = _booking.SlotId ?? 0,
                    ScheduledDate = _booking.ScheduledDate
                };
                _scheduledDate = _booking.ScheduledDate;
                _selectedTechnicianId = _booking.TechnicianId;

                await LoadAvailableSlots();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải lịch lắp đặt: {ex.Message}", Severity.Error);
            MudDialog.Cancel();
        }
    }

    private async Task OnTechnicianChanged(int technicianId)
    {
        _selectedTechnicianId = technicianId;
        _request.TechnicianId = technicianId;
        _request.SlotId = 0;
        await LoadAvailableSlots();
    }

    private async Task LoadAvailableSlots()
    {
        if (!_selectedTechnicianId.HasValue || !_scheduledDate.HasValue)
            return;

        try
        {
            // Use GetAvailableSlotsAsync to trigger auto-generation of slots if needed
            var availableSlots = await SlotService.GetAvailableSlotsAsync(_selectedTechnicianId.Value, _scheduledDate.Value);
            
            // In edit mode, also include the current booking's slot even if it's booked
            if (_isEdit && _booking?.SlotId > 0)
            {
                var allSlots = await SlotService.GetByTechnicianAndDateAsync(_selectedTechnicianId.Value, _scheduledDate.Value);
                var currentSlot = allSlots.FirstOrDefault(s => s.Id == _booking.SlotId);
                if (currentSlot != null && !availableSlots.Any(s => s.Id == currentSlot.Id))
                {
                    availableSlots.Add(currentSlot);
                }
            }
            
            _availableSlots = availableSlots;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải slots: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        if (!_scheduledDate.HasValue)
        {
            Snackbar.Add("Vui lòng chọn ngày lắp đặt", Severity.Warning);
            return;
        }

        _request.ScheduledDate = _scheduledDate.Value;

        try
        {
            if (_isEdit)
            {
                var updateRequest = new UpdateInstallationBookingRequest
                {
                    TechnicianId = _request.TechnicianId,
                    SlotId = _request.SlotId,
                    ScheduledDate = _request.ScheduledDate
                };
                await InstallationService.UpdateAsync(BookingId!.Value, updateRequest);
                Snackbar.Add("Đã cập nhật lịch lắp đặt", Severity.Success);
            }
            else
            {
                await InstallationService.CreateAsync(_request);
                Snackbar.Add("Đã tạo lịch lắp đặt mới", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
