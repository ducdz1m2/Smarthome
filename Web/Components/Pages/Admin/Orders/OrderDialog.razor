@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using Web.Helpers

@inject IOrderService OrderService
@inject ISnackbar Snackbar
@inject IWarehouseService WarehouseService
@inject IInventoryService InventoryService

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else if (_order == null)
        {
            <MudAlert Severity="Severity.Error">Không tìm thấy đơn hàng</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Thông tin đơn hàng</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudField Label="Mã đơn" Variant="Variant.Text">@_order.OrderNumber</MudField>
                            <MudField Label="Ngày tạo" Variant="Variant.Text">@_order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudField>
                            <MudField Label="Trạng thái" Variant="Variant.Text">
                                <MudChip T="string" Color="@StatusHelper.GetOrderStatusColor(_order.Status)" Size="Size.Small">
                                    @StatusHelper.GetOrderStatusText(_order.Status)
                                </MudChip>
                            </MudField>
                            <MudField Label="Phương thức thanh toán" Variant="Variant.Text">@_order.PaymentMethod</MudField>
                            <MudField Label="Phương thức giao hàng" Variant="Variant.Text">@_order.ShippingMethod</MudField>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Thông tin khách hàng</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudField Label="Tên người nhận" Variant="Variant.Text">@_order.ReceiverName</MudField>
                            <MudField Label="Điện thoại" Variant="Variant.Text">@_order.ReceiverPhone</MudField>
                            <MudField Label="Địa chỉ giao hàng" Variant="Variant.Text">@_order.ShippingAddress</MudField>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Chi tiết sản phẩm</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTable Items="_order.Items" Dense="true" Hover="true" Striped="true" Bordered="true">
                                <HeaderContent>
                                    <MudTh>Sản phẩm</MudTh>
                                    <MudTh>SKU</MudTh>
                                    <MudTh>Phân loại</MudTh>
                                    <MudTh>Số lượng</MudTh>
                                    <MudTh>Đơn giá</MudTh>
                                    <MudTh>Thành tiền</MudTh>
                                    <MudTh>Cần lắp đặt</MudTh>
                                    <MudTh>Kho</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.ProductName</MudTd>
                                    <MudTd>
                                        @if (!string.IsNullOrEmpty(context.VariantSku))
                                        {
                                            @context.VariantSku
                                        }
                                        else
                                        {
                                            @context.Sku
                                        }
                                    </MudTd>
                                    <MudTd>
                                        @if (!string.IsNullOrEmpty(context.VariantName))
                                        {
                                            @context.VariantName
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                                        }
                                    </MudTd>
                                    <MudTd>@context.Quantity</MudTd>
                                    <MudTd>@context.UnitPrice.ToString("N0") đ</MudTd>
                                    <MudTd>@context.TotalPrice.ToString("N0") đ</MudTd>
                                    <MudTd>
                                        @if (context.RequiresInstallation)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" />
                                        }
                                        else
                                        {
                                            <MudText>-</MudText>
                                        }
                                    </MudTd>
                                    <MudTd>
                                        @if (_order.Status == "Pending" && !context.RequiresInstallation)
                                        {
                                            <div style="max-width: 400px;">
                                                @if (_availableStockByWarehouse.ContainsKey(context.Id) && _availableStockByWarehouse[context.Id].Any())
                                                {
                                                    @foreach (var warehouse in _warehouses.Where(w => _availableStockByWarehouse[context.Id].ContainsKey(w.Id)))
                                                    {
                                                        var availableStock = _availableStockByWarehouse[context.Id][warehouse.Id];
                                                        <div class="d-flex align-center mb-2 flex-wrap">
                                                            <MudCheckBox Value="@_checkboxStates[context.Id][warehouse.Id]" 
                                                                         Color="Color.Primary" Class="mr-2"
                                                                         @onclick="() => ToggleWarehouse(context.Id, warehouse.Id)" />
                                                            <div style="min-width: 150px;">
                                                                <MudText Class="mr-2">@warehouse.Name</MudText>
                                                                <MudText Typo="Typo.caption" Class="text-secondary">Có sẵn: @availableStock</MudText>
                                                            </div>
                                                            @if (_checkboxStates[context.Id][warehouse.Id])
                                                            {
                                                                var allocation = _warehouseAllocations[context.Id].FirstOrDefault(a => a.WarehouseId == warehouse.Id);
                                                                if (allocation != null)
                                                                {
                                                                    <MudNumericField T="int" Variant="Variant.Outlined" Dense="true" 
                                                                                   @bind-Value="@allocation.Quantity"
                                                                                   Min="1" Max="@Math.Min(context.Quantity, availableStock)" Label="Số lượng" Class="ml-2" Style="min-width: 120px;" />
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Warning">Không có kho nào có sẵn sản phẩm này</MudText>
                                                }
                                            </div>
                                        }
                                        else if (!context.RequiresInstallation)
                                        {
                                            <div style="max-width: 400px;">
                                                @if (_warehouseAllocations.ContainsKey(context.Id) && _warehouseAllocations[context.Id].Any())
                                                {
                                                    @foreach (var allocation in _warehouseAllocations[context.Id])
                                                    {
                                                        var warehouse = _warehouses.FirstOrDefault(w => w.Id == allocation.WarehouseId);
                                                        var currentStock = _availableStockByWarehouse.ContainsKey(context.Id) && 
                                                                           _availableStockByWarehouse[context.Id].ContainsKey(allocation.WarehouseId)
                                                                           ? _availableStockByWarehouse[context.Id][allocation.WarehouseId]
                                                                           : 0;
                                                        if (warehouse != null)
                                                        {
                                                            <div class="mb-2">
                                                                <MudText>@warehouse.Name: <strong>@currentStock</strong> <MudText Typo="Typo.caption" Color="Color.Secondary">(đã phân bổ @allocation.Quantity)</MudText></MudText>
                                                            </div>
                                                        }
                                                    }
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Chưa phân bổ kho</MudText>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <MudText>-</MudText>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @if (_order.Shipments?.Any() == true)
                {
                    <MudItem xs="12">
                        <MudCard Elevation="0" Class="mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Thông tin vận chuyển</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTable Items="_order.Shipments" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Mã vận đơn</MudTh>
                                        <MudTh>Trạng thái</MudTh>
                                        <MudTh>Đơn vị vận chuyển</MudTh>
                                        <MudTh>Mã tracking</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.TrackingNumber</MudTd>
                                        <MudTd>@context.Status</MudTd>
                                        <MudTd>@context.Carrier</MudTd>
                                        <MudTd>@context.TrackingNumber</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
                
                <MudItem xs="12">
                    <MudCard Elevation="0">
                        <MudCardContent>
                            <MudGrid Justify="Justify.FlexEnd">
                                <MudItem>
                                    <MudText Typo="Typo.body2">Tạm tính: <strong>@_order.SubTotal.ToString("N0") đ</strong></MudText>
                                </MudItem>
                                @if (_order.DiscountAmount > 0)
                                {
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.body2" Color="Color.Success">Giảm giá: -@_order.DiscountAmount.ToString("N0") đ</MudText>
                                    </MudItem>
                                }
                                <MudItem xs="12">
                                    <MudText Typo="Typo.body2">Phí vận chuyển: @_order.ShippingFee.ToString("N0") đ</MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Color="Color.Primary">
                                        Tổng cộng: @_order.TotalAmount.ToString("N0") đ
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @if (!string.IsNullOrEmpty(_order.CancelReason))
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Error">
                            <strong>Lý do hủy:</strong> @_order.CancelReason
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Đóng</MudButton>
        
        @if (_order != null && !IsReadOnly)
        {
            @if (_order.Status == "Pending")
            {
                <MudButton Color="Color.Primary" OnClick="ConfirmOrder" StartIcon="@Icons.Material.Filled.CheckCircle">
                    Xác nhận
                </MudButton>
            }

            @if (_order.Status == "AwaitingPickup")
            {
                <MudButton Color="Color.Primary" OnClick="StartShipping" StartIcon="@Icons.Material.Filled.LocalShipping">
                    Bắt đầu giao
                </MudButton>
            }

            @if (_order.Status == "Shipping")
            {
                <MudButton Color="Color.Success" OnClick="MarkDelivered" StartIcon="@Icons.Material.Filled.Done">
                    Đã giao
                </MudButton>
            }

            @if (CanCancel(_order.Status))
            {
                <MudButton Color="Color.Error" OnClick="CancelOrder" StartIcon="@Icons.Material.Filled.Cancel">
                    Hủy đơn
                </MudButton>
            }

            @if (_order.Status is "Installing" or "Testing" or "Delivered")
            {
                <MudButton Color="Color.Success" OnClick="CompleteOrder" StartIcon="@Icons.Material.Filled.DoneAll">
                    Hoàn tất
                </MudButton>
            }
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int OrderId { get; set; }
    
    [Parameter]
    public bool IsReadOnly { get; set; } = true;

    private OrderResponse? _order;
    private bool _loading = true;
    private List<WarehouseResponse> _warehouses = new();
    private Dictionary<int, List<WarehouseAllocationItem>> _warehouseAllocations = new();
    private Dictionary<int, Dictionary<int, int>> _availableStockByWarehouse = new();
    private Dictionary<int, Dictionary<int, bool>> _checkboxStates = new();

    private class WarehouseAllocationItem
    {
        public int WarehouseId { get; set; }
        public int Quantity { get; set; }
        public int AvailableStock { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadWarehouses();
        await LoadOrder();
    }

    private async Task LoadWarehouses()
    {
        try
        {
            _warehouses = await WarehouseService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải danh sách kho: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadOrder()
    {
        _loading = true;
        try
        {
            _order = await OrderService.GetByIdAsync(OrderId);
            
            // Initialize warehouse allocations dictionary and load available warehouses
            if (_order != null)
            {
                // Load warehouses once before the loop
                List<WarehouseResponse> allWarehouses;
                try
                {
                    allWarehouses = await WarehouseService.GetAllAsync();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Lỗi khi tải danh sách kho: {ex.Message}", Severity.Warning);
                    allWarehouses = new List<WarehouseResponse>();
                }

                // Load warehouse allocations once if order is not Pending
                List<WarehouseAllocationResponse> allocations = new();
                if (_order.Status != "Pending")
                {
                    try
                    {
                        allocations = await OrderService.GetWarehouseAllocationsAsync(OrderId);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"Lỗi khi tải phân bổ kho: {ex.Message}", Severity.Warning);
                    }
                }

                foreach (var item in _order.Items)
                {
                    if (!_warehouseAllocations.ContainsKey(item.Id))
                    {
                        _warehouseAllocations[item.Id] = new List<WarehouseAllocationItem>();
                    }

                    if (!_checkboxStates.ContainsKey(item.Id))
                    {
                        _checkboxStates[item.Id] = new Dictionary<int, bool>();
                    }

                    if (!_availableStockByWarehouse.ContainsKey(item.Id))
                    {
                        _availableStockByWarehouse[item.Id] = new Dictionary<int, int>();
                    }

                    // Load actual stock from inventory service
                    if (item.ProductId > 0)
                    {
                        try
                        {
                            var inventory = await InventoryService.GetProductInventoryByIdAsync(item.ProductId);
                            if (inventory != null)
                            {
                                // If variant is specified, get stock from variant
                                if (item.VariantId.HasValue && item.VariantId.Value > 0)
                                {
                                    var variantInventory = inventory.Variants?.FirstOrDefault(v => v.VariantId == item.VariantId.Value);
                                    if (variantInventory?.WarehouseStocks != null)
                                    {
                                        foreach (var warehouseStock in variantInventory.WarehouseStocks)
                                        {
                                            _availableStockByWarehouse[item.Id][warehouseStock.WarehouseId] = warehouseStock.Quantity;
                                        }
                                    }
                                }
                                else
                                {
                                    // Get stock from product level
                                    foreach (var warehouseStock in inventory.WarehouseStocks)
                                    {
                                        _availableStockByWarehouse[item.Id][warehouseStock.WarehouseId] = warehouseStock.Quantity;
                                    }
                                }
                            }
                        }
                        catch (Exception ex)
                        {
                            // Silently continue - stock info is for display only
                            Console.WriteLine($"Error loading inventory for product {item.ProductId}: {ex.Message}");
                        }
                    }
                    
                    // Initialize checkbox states for all warehouses
                    foreach (var warehouse in allWarehouses)
                    {
                        if (!_availableStockByWarehouse[item.Id].ContainsKey(warehouse.Id))
                        {
                            _availableStockByWarehouse[item.Id][warehouse.Id] = 0;
                        }
                        _checkboxStates[item.Id][warehouse.Id] = false;
                    }

                    // If order is not Pending, load existing warehouse allocations for display
                    if (_order.Status != "Pending" && !item.RequiresInstallation)
                    {
                        var itemAllocations = allocations.Where(a => a.OrderItemId == item.Id).ToList();
                        
                        // Remove duplicates by warehouse ID
                        var uniqueAllocations = itemAllocations
                            .GroupBy(a => a.WarehouseId)
                            .Select(g => g.First())
                            .ToList();
                        
                        foreach (var alloc in uniqueAllocations)
                        {
                            _warehouseAllocations[item.Id].Add(new WarehouseAllocationItem
                            {
                                WarehouseId = alloc.WarehouseId,
                                Quantity = alloc.Quantity,
                                AvailableStock = _availableStockByWarehouse.ContainsKey(item.Id) && 
                                                   _availableStockByWarehouse[item.Id].ContainsKey(alloc.WarehouseId)
                                                   ? _availableStockByWarehouse[item.Id][alloc.WarehouseId]
                                                   : 0
                            });
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải thông tin: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void ToggleWarehouse(int orderItemId, int warehouseId)
    {
        // Toggle checkbox state
        if (_checkboxStates.ContainsKey(orderItemId) && _checkboxStates[orderItemId].ContainsKey(warehouseId))
        {
            var currentState = _checkboxStates[orderItemId][warehouseId];
            _checkboxStates[orderItemId][warehouseId] = !currentState;
            
            if (!currentState)
            {
                // Create allocation
                if (!_warehouseAllocations[orderItemId].Any(a => a.WarehouseId == warehouseId))
                {
                    var availableStock = _availableStockByWarehouse.ContainsKey(orderItemId) && 
                                         _availableStockByWarehouse[orderItemId].ContainsKey(warehouseId)
                                         ? _availableStockByWarehouse[orderItemId][warehouseId]
                                         : 0;
                    _warehouseAllocations[orderItemId].Add(new WarehouseAllocationItem 
                    { 
                        WarehouseId = warehouseId, 
                        Quantity = 1,
                        AvailableStock = availableStock
                    });
                }
            }
            else
            {
                // Remove allocation
                _warehouseAllocations[orderItemId].RemoveAll(a => a.WarehouseId == warehouseId);
            }
        }

        StateHasChanged();
    }

    private async Task ConfirmOrder()
    {
        try
        {
            // Build warehouse allocation request
            var warehouseAllocations = new List<WarehouseAllocationRequest>();
            foreach (var item in _order.Items)
            {
                if (!item.RequiresInstallation && _warehouseAllocations.TryGetValue(item.Id, out var allocations))
                {
                    foreach (var allocation in allocations)
                    {
                        warehouseAllocations.Add(new WarehouseAllocationRequest
                        {
                            OrderItemId = item.Id,
                            WarehouseId = allocation.WarehouseId,
                            Quantity = allocation.Quantity
                        });
                    }
                }
            }

            await OrderService.ConfirmAsync(OrderId, warehouseAllocations);
            Snackbar.Add("Đã xác nhận đơn hàng", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task StartShipping()
    {
        try
        {
            await OrderService.StartShippingAsync(OrderId);
            Snackbar.Add("Đơn hàng bắt đầu giao", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task MarkDelivered()
    {
        try
        {
            await OrderService.MarkDeliveredAsync(OrderId);
            Snackbar.Add("Đã đánh dấu đơn hàng đã giao", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task CancelOrder()
    {
        try
        {
            await OrderService.CancelAsync(OrderId, "Hủy bởi admin");
            Snackbar.Add("Đã hủy đơn hàng", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task CompleteOrder()
    {
        try
        {
            await OrderService.CompleteAsync(OrderId);
            Snackbar.Add("Đã hoàn tất đơn hàng", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private static bool CanCancel(string status)
    {
        return status != "Completed" && status != "Cancelled" && status != "Refunded";
    }
}
