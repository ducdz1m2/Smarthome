@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@inject IOrderService OrderService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else if (_order == null)
        {
            <MudAlert Severity="Severity.Error">Không tìm thấy đơn hàng</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Thông tin đơn hàng</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudField Label="Mã đơn" Variant="Variant.Text">@_order.OrderNumber</MudField>
                            <MudField Label="Ngày tạo" Variant="Variant.Text">@_order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudField>
                            <MudField Label="Trạng thái" Variant="Variant.Text">
                                <MudChip T="string" Color="@GetStatusColor(_order.Status)" Size="Size.Small">
                                    @GetStatusDisplayName(_order.Status)
                                </MudChip>
                            </MudField>
                            <MudField Label="Phương thức thanh toán" Variant="Variant.Text">@_order.PaymentMethod</MudField>
                            <MudField Label="Phương thức giao hàng" Variant="Variant.Text">@_order.ShippingMethod</MudField>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Thông tin khách hàng</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudField Label="Tên người nhận" Variant="Variant.Text">@_order.ReceiverName</MudField>
                            <MudField Label="Điện thoại" Variant="Variant.Text">@_order.ReceiverPhone</MudField>
                            <MudField Label="Địa chỉ giao hàng" Variant="Variant.Text">@_order.ShippingAddress</MudField>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Chi tiết sản phẩm</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudTable Items="_order.Items" Dense="true" Hover="true" Striped="true" Bordered="true">
                                <HeaderContent>
                                    <MudTh>Sản phẩm</MudTh>
                                    <MudTh>SKU</MudTh>
                                    <MudTh>Số lượng</MudTh>
                                    <MudTh>Đơn giá</MudTh>
                                    <MudTh>Thành tiền</MudTh>
                                    <MudTh>Cần lắp đặt</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.ProductName</MudTd>
                                    <MudTd>@context.Sku</MudTd>
                                    <MudTd>@context.Quantity</MudTd>
                                    <MudTd>@context.UnitPrice.ToString("N0") đ</MudTd>
                                    <MudTd>@context.TotalPrice.ToString("N0") đ</MudTd>
                                    <MudTd>
                                        @if (context.RequiresInstallation)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" />
                                        }
                                        else
                                        {
                                            <MudText>-</MudText>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @if (_order.Shipments?.Any() == true)
                {
                    <MudItem xs="12">
                        <MudCard Elevation="0" Class="mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Thông tin vận chuyển</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTable Items="_order.Shipments" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Mã vận đơn</MudTh>
                                        <MudTh>Trạng thái</MudTh>
                                        <MudTh>Đơn vị vận chuyển</MudTh>
                                        <MudTh>Mã tracking</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.ShipmentNumber</MudTd>
                                        <MudTd>@context.Status</MudTd>
                                        <MudTd>@context.Carrier</MudTd>
                                        <MudTd>@context.TrackingNumber</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
                
                @if (_statusHistory?.Any() == true)
                {
                    <MudItem xs="12">
                        <MudCard Elevation="0" Class="mb-4">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Lịch sử trạng thái</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTimeline>
                                    @foreach (var history in _statusHistory)
                                    {
                                        <MudTimelineItem Color="@GetStatusColor(history.Status)">
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                                @GetStatusDisplayName(history.Status)
                                            </MudText>
                                            <MudText Typo="Typo.caption">@history.Note</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @history.At.ToString("dd/MM/yyyy HH:mm")
                                            </MudText>
                                        </MudTimelineItem>
                                    }
                                </MudTimeline>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
                
                <MudItem xs="12">
                    <MudCard Elevation="0">
                        <MudCardContent>
                            <MudGrid Justify="Justify.FlexEnd">
                                <MudItem>
                                    <MudText Typo="Typo.body2">Tạm tính: <strong>@_order.SubTotal.ToString("N0") đ</strong></MudText>
                                </MudItem>
                                @if (_order.DiscountAmount > 0)
                                {
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.body2" Color="Color.Success">Giảm giá: -@_order.DiscountAmount.ToString("N0") đ</MudText>
                                    </MudItem>
                                }
                                <MudItem xs="12">
                                    <MudText Typo="Typo.body2">Phí vận chuyển: @_order.ShippingFee.ToString("N0") đ</MudText>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Color="Color.Primary">
                                        Tổng cộng: @_order.TotalAmount.ToString("N0") đ
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @if (!string.IsNullOrEmpty(_order.CancelReason))
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Error">
                            <strong>Lý do hủy:</strong> @_order.CancelReason
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Đóng</MudButton>
        
        @if (_order != null && !IsReadOnly)
        {
            @* Luồng đơn hàng thường *@
            @if (_order.Status == "Pending")
            {
                <MudButton Color="Color.Primary" OnClick="ConfirmOrder" StartIcon="@Icons.Material.Filled.CheckCircle">
                    Xác nhận
                </MudButton>
            }
            
            @if (_order.Status == "Confirmed")
            {
                <MudButton Color="Color.Primary" OnClick="ProcessOrder" StartIcon="@Icons.Material.Filled.Inventory">
                    Chuẩn bị hàng
                </MudButton>
            }
            
            @if (_order.Status == "AwaitingPickup")
            {
                <MudButton Color="Color.Primary" OnClick="ShipOrder" StartIcon="@Icons.Material.Filled.LocalShipping">
                    Bắt đầu giao
                </MudButton>
            }
            
            @if (_order.Status == "Shipping")
            {
                <MudButton Color="Color.Success" OnClick="DeliverOrder" StartIcon="@Icons.Material.Filled.Done">
                    Đã giao
                </MudButton>
            }
            
            @* Luồng đơn hàng cần lắp đặt *@
            @if (_order.Status == "AwaitingSchedule")
            {
                <MudButton Color="Color.Primary" OnClick="ScheduleInstallation" StartIcon="@Icons.Material.Filled.CalendarToday">
                    Đặt lịch
                </MudButton>
            }
            
            @if (_order.Status == "Scheduled")
            {
                <MudButton Color="Color.Primary" OnClick="AssignTechnician" StartIcon="@Icons.Material.Filled.PersonAdd">
                    Phân công KT
                </MudButton>
            }
            
            @if (_order.Status == "TechnicianAssigned")
            {
                <MudButton Color="Color.Primary" OnClick="PrepareInstallation" StartIcon="@Icons.Material.Filled.Handyman">
                    Chuẩn bị
                </MudButton>
            }
            
            @if (_order.Status == "Preparing")
            {
                <MudButton Color="Color.Primary" OnClick="StartInstallation" StartIcon="@Icons.Material.Filled.Build">
                    Bắt đầu lắp
                </MudButton>
            }
            
            @if (_order.Status == "Installing")
            {
                <MudButton Color="Color.Primary" OnClick="StartTesting" StartIcon="@Icons.Material.Filled.Science">
                    Kiểm tra
                </MudButton>
            }
            
            @if (_order.Status is "Testing" or "Delivered")
            {
                <MudButton Color="Color.Success" OnClick="CompleteOrder" StartIcon="@Icons.Material.Filled.DoneAll">
                    Hoàn tất
                </MudButton>
            }
            
            @* Các hành động khác *@
            @if (CanCancel(_order.Status))
            {
                <MudButton Color="Color.Error" OnClick="CancelOrder" StartIcon="@Icons.Material.Filled.Cancel">
                    Hủy đơn
                </MudButton>
            }
            
            @if (_order.Status == "Delivered")
            {
                <MudButton Color="Color.Warning" OnClick="ReturnOrder" StartIcon="@Icons.Material.Filled.Replay">
                    Trả hàng
                </MudButton>
            }
            
            @if (_order.Status == "ReturnRequested" || _order.Status == "Cancelled")
            {
                <MudButton Color="Color.Secondary" OnClick="RefundOrder" StartIcon="@Icons.Material.Filled.MoneyOff">
                    Hoàn tiền
                </MudButton>
            }
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int OrderId { get; set; }
    
    [Parameter]
    public bool IsReadOnly { get; set; } = true;

    private OrderResponse? _order;
    private bool _loading = true;
    private List<StatusHistoryItem> _statusHistory = new();

    public class StatusHistoryItem
    {
        public string Status { get; set; } = "";
        public string Note { get; set; } = "";
        public DateTime At { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOrder();
    }

    private async Task LoadOrder()
    {
        _loading = true;
        try
        {
            _order = await OrderService.GetByIdAsync(OrderId);
            // TODO: Load status history from API when available
            _statusHistory = GetMockStatusHistory();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải thông tin: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private List<StatusHistoryItem> GetMockStatusHistory()
    {
        var history = new List<StatusHistoryItem>();
        if (_order == null) return history;

        var baseTime = _order.CreatedAt;
        int timeOffset = 0;

        // Luôn có trạng thái Pending
        history.Add(new StatusHistoryItem 
        { 
            Status = "Pending", 
            Note = "Đơn hàng được tạo", 
            At = baseTime.AddMinutes(timeOffset)
        });

        var currentStatus = _order.Status;
        if (currentStatus == "Pending") return history;

        // Confirmed
        timeOffset += 30;
        history.Add(new StatusHistoryItem 
        { 
            Status = "Confirmed", 
            Note = "Đơn hàng đã được xác nhận", 
            At = baseTime.AddMinutes(timeOffset)
        });
        if (currentStatus == "Confirmed") return history;

        // Luồng thường: AwaitingPickup -> Shipping -> Delivered
        if (currentStatus is "AwaitingPickup" or "Shipping" or "Delivered" or "Completed")
        {
            timeOffset += 30;
            history.Add(new StatusHistoryItem 
            { 
                Status = "AwaitingPickup", 
                Note = "Đơn hàng đang được chuẩn bị", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "AwaitingPickup") return history;

            timeOffset += 60;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Shipping", 
                Note = "Đơn hàng đang được giao", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "Shipping") return history;

            timeOffset += 120;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Delivered", 
                Note = "Đơn hàng đã được giao thành công", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "Delivered") return history;
        }

        // Luồng lắp đặt: AwaitingSchedule -> Scheduled -> TechnicianAssigned -> Preparing -> Installing -> Testing
        if (currentStatus is "AwaitingSchedule" or "Scheduled" or "TechnicianAssigned" or "Preparing" or "Installing" or "Testing" or "Completed")
        {
            timeOffset += 30;
            history.Add(new StatusHistoryItem 
            { 
                Status = "AwaitingSchedule", 
                Note = "Chờ đặt lịch lắp đặt", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "AwaitingSchedule") return history;

            timeOffset += 60;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Scheduled", 
                Note = "Đã đặt lịch lắp đặt", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "Scheduled") return history;

            timeOffset += 30;
            history.Add(new StatusHistoryItem 
            { 
                Status = "TechnicianAssigned", 
                Note = "Đã phân công kỹ thuật viên", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "TechnicianAssigned") return history;

            timeOffset += 30;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Preparing", 
                Note = "Kỹ thuật viên đang chuẩn bị", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "Preparing") return history;

            timeOffset += 60;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Installing", 
                Note = "Đang lắp đặt sản phẩm", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "Installing") return history;

            timeOffset += 60;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Testing", 
                Note = "Đang kiểm tra sau lắp đặt", 
                At = baseTime.AddMinutes(timeOffset)
            });
            if (currentStatus == "Testing") return history;
        }

        // Completed
        if (currentStatus == "Completed")
        {
            timeOffset += 30;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Completed", 
                Note = "Đơn hàng hoàn tất", 
                At = baseTime.AddMinutes(timeOffset)
            });
        }

        // Cancelled
        if (currentStatus == "Cancelled")
        {
            timeOffset += 30;
            history.Add(new StatusHistoryItem 
            { 
                Status = "Cancelled", 
                Note = "Đơn hàng đã hủy", 
                At = baseTime.AddMinutes(timeOffset)
            });
        }

        return history;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task ConfirmOrder()
    {
        try
        {
            await OrderService.ConfirmAsync(OrderId);
            Snackbar.Add("Đã xác nhận đơn hàng", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ProcessOrder()
    {
        try
        {
            await OrderService.ProcessAsync(OrderId);
            Snackbar.Add("Đơn hàng đang được chuẩn bị", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ShipOrder()
    {
        try
        {
            await OrderService.ShipAsync(OrderId);
            Snackbar.Add("Đơn hàng đang được giao", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeliverOrder()
    {
        try
        {
            await OrderService.DeliverAsync(OrderId);
            Snackbar.Add("Đã xác nhận đơn hàng đã giao", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ScheduleInstallation()
    {
        try
        {
            await OrderService.ScheduleInstallationAsync(OrderId);
            Snackbar.Add("Đã đặt lịch lắp đặt", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task AssignTechnician()
    {
        try
        {
            await OrderService.AssignTechnicianAsync(OrderId);
            Snackbar.Add("Đã phân công kỹ thuật viên", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrepareInstallation()
    {
        try
        {
            await OrderService.PrepareAsync(OrderId);
            Snackbar.Add("Kỹ thuật viên đang chuẩn bị", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task StartInstallation()
    {
        try
        {
            await OrderService.StartInstallationAsync(OrderId);
            Snackbar.Add("Bắt đầu lắp đặt sản phẩm", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task StartTesting()
    {
        try
        {
            await OrderService.StartTestingAsync(OrderId);
            Snackbar.Add("Bắt đầu kiểm tra sau lắp đặt", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task CompleteOrder()
    {
        try
        {
            await OrderService.CompleteAsync(OrderId);
            Snackbar.Add("Đã hoàn tất đơn hàng", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task CancelOrder()
    {
        try
        {
            await OrderService.CancelAsync(OrderId, "Hủy bởi admin");
            Snackbar.Add("Đã hủy đơn hàng", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ReturnOrder()
    {
        try
        {
            await OrderService.ReturnAsync(OrderId, "Yêu cầu trả hàng từ admin");
            Snackbar.Add("Đã tạo yêu cầu trả hàng", Severity.Warning);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task RefundOrder()
    {
        try
        {
            await OrderService.RefundAsync(OrderId, "Hoàn tiền cho đơn hàng");
            Snackbar.Add("Đã hoàn tiền", Severity.Success);
            await LoadOrder();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private static bool CanCancel(string status)
    {
        return status != "Completed" && status != "Cancelled" && status != "Refunded" && status != "ReturnRequested";
    }

    private static string GetStatusDisplayName(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "AwaitingPickup" => "Chờ lấy hàng",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "AwaitingSchedule" => "Chờ đặt lịch",
            "Scheduled" => "Đã có lịch",
            "TechnicianAssigned" => "Đã phân công",
            "Preparing" => "Chuẩn bị",
            "Installing" => "Đang lắp",
            "Testing" => "Kiểm tra",
            "Completed" => "Hoàn tất",
            "Cancelled" => "Đã hủy",
            "Refunded" => "Đã hoàn tiền",
            "ReturnRequested" => "Yêu cầu trả hàng",
            _ => status
        };
    }

    private static Color GetStatusColor(string status)
    {
        return status switch
        {
            "Pending" => Color.Warning,
            "Confirmed" => Color.Info,
            "AwaitingPickup" => Color.Info,
            "Shipping" => Color.Primary,
            "Delivered" => Color.Success,
            "AwaitingSchedule" => Color.Warning,
            "Scheduled" => Color.Info,
            "TechnicianAssigned" => Color.Info,
            "Preparing" => Color.Info,
            "Installing" => Color.Primary,
            "Testing" => Color.Primary,
            "Completed" => Color.Success,
            "Cancelled" => Color.Error,
            "Refunded" => Color.Error,
            "ReturnRequested" => Color.Error,
            _ => Color.Default
        };
    }
}
