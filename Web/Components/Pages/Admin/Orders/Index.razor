@page "/admin/orders"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using Web.Helpers
@using Web.Components.Shared.Common

@inject IOrderService OrderService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageHeader Title="Quản lý Đơn hàng" ShowAddButton="false" />

<FilterBar>
    <MudItem xs="12" sm="6" md="3">
        <MudSelect T="string" Label="Lọc theo trạng thái" @bind-Value="_selectedStatus" Clearable="true" Variant="Variant.Outlined">
            <MudSelectItem T="string" Value="@null">Tất cả</MudSelectItem>
            @foreach (var status in _statusList)
            {
                <MudSelectItem Value="@status">@StatusHelper.GetOrderStatusText(status)</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</FilterBar>

<DataTable Items="_orders" Title="Danh sách đơn hàng" Loading="_loading"
           FilterFunc="@FilterOrders">
    <HeaderContent>
        <MudTh width="80px"><MudTableSortLabel T="OrderResponse" SortBy="@(o => o.Id)">ID</MudTableSortLabel></MudTh>
        <MudTh width="100px">Loại</MudTh>
        <MudTh width="150px"><MudTableSortLabel T="OrderResponse" SortBy="@(o => o.OrderNumber)">Mã đơn</MudTableSortLabel></MudTh>
        <MudTh width="150px">Khách hàng</MudTh>
        <MudTh width="150px">Điện thoại</MudTh>
        <MudTh width="200px">Địa chỉ</MudTh>
        <MudTh width="120px"><MudTableSortLabel T="OrderResponse" SortBy="@(o => o.TotalAmount)">Tổng tiền</MudTableSortLabel></MudTh>
        <MudTh width="120px"><MudTableSortLabel T="OrderResponse" SortBy="@(o => o.Status)">Trạng thái</MudTableSortLabel></MudTh>
        <MudTh width="120px"><MudTableSortLabel T="OrderResponse" SortBy="@(o => o.CreatedAt)">Ngày tạo</MudTableSortLabel></MudTh>
        <MudTh width="100px">Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Loại">
            @if (context.HasUninstallBooking)
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Tháo dỡ</MudChip>
            }
            @if (context.HasWarrantyRequest)
            {
                <MudChip T="string" Color="Color.Info" Size="Size.Small">Bảo hành</MudChip>
            }
        </MudTd>
        <MudTd DataLabel="Mã đơn">
            <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.OrderNumber</MudText>
        </MudTd>
        <MudTd DataLabel="Khách hàng">@context.ReceiverName</MudTd>
        <MudTd DataLabel="Điện thoại">@context.ReceiverPhone</MudTd>
        <MudTd DataLabel="Địa chỉ">
            <MudText Typo="Typo.caption" Style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;">
                @context.ShippingAddress
            </MudText>
        </MudTd>
        <MudTd DataLabel="Tổng tiền">
            <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight: 500;">
                @context.TotalAmount.ToString("N0") đ
            </MudText>
        </MudTd>
        <MudTd DataLabel="Trạng thái">
            <MudChip T="string" Color="@StatusHelper.GetOrderStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">
                @StatusHelper.GetOrderStatusText(context.Status)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
        <MudTd>
            <ActionButtons ShowEdit="false" ShowAdd="false" ShowDelete="false" ShowView="true" ShowCancel="@CanCancel(context.Status)"
                          OnView="@(() => OpenOrderDialog(context))"
                          OnCancel="@(() => CancelOrder(context))" />
        </MudTd>
    </RowTemplate>
</DataTable>

@code {
    private List<OrderResponse> _orders = new();
    private List<OrderResponse> _allOrders = new();
    private bool _loading = true;
    private string _searchString = "";
    private string _selectedStatus = "";
    
    private readonly string[] _statusList = new[]
    {
        "Pending", "Confirmed", "AwaitingPickup", "Shipping", "Delivered",
        "AwaitingSchedule", "Scheduled", "TechnicianAssigned", "Preparing", "Installing", "Testing",
        "Completed", "Cancelled", "Refunded", "ReturnRequested"
    };

    private bool FilterOrders(OrderResponse order)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        
        return order.OrderNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               order.ReceiverName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               (order.ReceiverPhone?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (order.ShippingAddress?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        _loading = true;
        try
        {
            _allOrders = await OrderService.GetAllAsync();
            ApplyStatusFilter();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải danh sách: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyStatusFilter()
    {
        if (string.IsNullOrWhiteSpace(_selectedStatus))
        {
            _orders = _allOrders;
        }
        else
        {
            _orders = _allOrders.Where(o => o.Status.Equals(_selectedStatus, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private async Task OpenOrderDialog(OrderResponse order)
    {
        var parameters = new DialogParameters<OrderDialog>();
        parameters.Add(x => x.OrderId, order.Id);
        parameters.Add(x => x.IsReadOnly, false);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<OrderDialog>("Chi tiết đơn hàng", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            await LoadOrders();
        }
    }

    private async Task CancelOrder(OrderResponse order)
    {
        var parameters = new DialogParameters
        {
            { "Title", "Xác nhận hủy đơn" },
            { "Content", $"Bạn có chắc muốn hủy đơn hàng \"{order.OrderNumber}\"?" },
            { "ConfirmText", "Hủy đơn" },
            { "CancelText", "Đóng" },
            { "ConfirmColor", Color.Error }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                await OrderService.CancelAsync(order.Id, "Hủy bởi admin");
                Snackbar.Add("Đã hủy đơn hàng", Severity.Success);
                await LoadOrders();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi khi hủy đơn: {ex.Message}", Severity.Error);
            }
        }
    }

    private bool CanCancel(string status)
    {
        return status != "Completed" && status != "Cancelled" && status != "Refunded";
    }

}
