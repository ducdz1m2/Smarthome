@using Application.Interfaces.Services
@inject IUserService UserService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudText Typo="Typo.body1" Class="mb-4">
                Đặt lại mật khẩu cho người dùng: <strong>@UserName</strong>
            </MudText>
            
            <MudTextField @bind-Value="_newPassword" Label="Mật khẩu mới *" 
                          Required="true" RequiredError="Vui lòng nhập mật khẩu mới"
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password"
                          HelperText="Mật khẩu phải có ít nhất 6 ký tự" />
            
            <MudTextField @bind-Value="_confirmPassword" Label="Xác nhận mật khẩu *" 
                          Required="true" RequiredError="Vui lòng xác nhận mật khẩu"
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">
            Đặt lại mật khẩu
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int UserId { get; set; }

    [Parameter]
    public string UserName { get; set; } = string.Empty;

    private MudForm _form = null!;
    private bool _isValid;
    private string _newPassword = "";
    private string _confirmPassword = "";

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid) return;

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Mật khẩu xác nhận không khớp", Severity.Error);
            return;
        }

        if (_newPassword.Length < 6)
        {
            Snackbar.Add("Mật khẩu phải có ít nhất 6 ký tự", Severity.Error);
            return;
        }

        try
        {
            await UserService.ResetPasswordAsync(UserId, _newPassword);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
