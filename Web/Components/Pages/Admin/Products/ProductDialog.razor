@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using System.Net.Http.Json
@using MudBlazor
@using MudBlazor.Components
@inject IProductService ProductService
@inject IProductVariantService VariantService
@inject ICategoryService CategoryService
@inject IBrandService BrandService
@inject ISupplierService SupplierService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" panelclass="pa-6">
                <MudTabPanel Text="Thông tin cơ bản" Icon="@Icons.Material.Filled.Info">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_request.Name" Label="Tên sản phẩm *" 
                                          Required="true" RequiredError="Tên không được trống"
                                          Variant="Variant.Outlined" Class="mb-3" />
                            
                            <MudTextField @bind-Value="_sku" Label="SKU *" 
                                          Required="true" RequiredError="SKU không được trống"
                                          Variant="Variant.Outlined" Class="mb-3"
                                          Disabled="_isEdit"
                                          HelperText="Mã sản phẩm duy nhất" />
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudSelect T="int" @bind-Value="_request.CategoryId" Label="Danh mục *" 
                                       Required="true" RequiredError="Chọn danh mục"
                                       Variant="Variant.Outlined" Class="mb-3">
                                @foreach (var cat in _categories)
                                {
                                    <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
                                }
                            </MudSelect>
                            
                            <MudSelect T="int" @bind-Value="_request.BrandId" Label="Thương hiệu *" 
                                       Required="true" RequiredError="Chọn thương hiệu"
                                       Variant="Variant.Outlined" Class="mb-3">
                                @foreach (var brand in _brands)
                                {
                                    <MudSelectItem T="int" Value="@brand.Id">@brand.Name</MudSelectItem>
                                }
                            </MudSelect>
                            
                            <MudSelect T="int?" @bind-Value="_request.SupplierId" Label="Nhà cung cấp" 
                                       Variant="Variant.Outlined" Class="mb-3" Clearable="true">
                                @foreach (var supplier in _suppliers)
                                {
                                    <MudSelectItem T="int?" Value="@supplier.Id">@supplier.Name</MudSelectItem>
                                }
                            </MudSelect>
                            
                            <MudSwitch @bind-Value="_request.RequiresInstallation" 
                                       Label="Cần lắp đặt" Color="Color.Primary" />
                        </MudItem>
                        
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_request.Description" Label="Mô tả" 
                                          Variant="Variant.Outlined" Lines="4"
                                          MaxLength="2000"
                                          HelperText="Mô tả chi tiết sản phẩm" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                
                <MudTabPanel Text="Hình ảnh" Icon="@Icons.Material.Filled.Image">
                    <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                                   FilesChanged="UploadImages"
                                   Accept=".jpg,.jpeg,.png,.gif,.webp">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                                Thêm hình ảnh (@_imageUrls.Count ảnh)
                            </MudButton>
                        </ActivatorContent>
                        <FileContent>
                            @if (_imageUrls.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @foreach (var url in _imageUrls)
                                    {
                                        <MudCard Style="width: 100px; height: 100px;">
                                            <MudCardMedia Image="@url" Style="width: 100px; height: 100px; object-fit: cover;" />
                                        </MudCard>
                                    }
                                </div>
                            }
                        </FileContent>
                    </MudFileUpload>
                    
                    <MudText Typo="Typo.caption" Class="mt-2">Số ảnh hiện tại: @_imageUrls.Count</MudText>
                    
                    @if (_isUploading)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-3" />
                    }
                    
                    <MudGrid Class="mt-4" Spacing="2">
                        @foreach (var image in _imageUrls.Select((url, index) => new { url, index }))
                        {
                            <MudItem xs="6" sm="4" md="3" @key="image.index">
                                <MudCard Elevation="2">
                                    <MudImage Src="@image.url" 
                                              Alt="Product Image" 
                                              Height="150"
                                              ObjectFit="ObjectFit.Cover"
                                              Class="rounded-t" />
                                    <MudCardActions Class="justify-center">
                                        <MudButton Variant="Variant.Text" Color="Color.Error" 
                                                   OnClick="@(() => RemoveImage(image.index))" Size="Size.Small">
                                            Xóa
                                        </MudButton>
                                        @if (image.index > 0)
                                        {
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" 
                                                       OnClick="@(() => SetMainImage(image.index))" Size="Size.Small">
                                                Đặt chính
                                            </MudButton>
                                        }
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                    
                    @if (_imageUrls.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-4">Chưa có hình ảnh</MudAlert>
                    }
                </MudTabPanel>
                
                @if (_isEdit)
                {
                    <MudTabPanel Text="Trạng thái" Icon="@Icons.Material.Filled.Settings">
                        <MudSwitch @bind-Value="_request.IsActive" Label="Đang bán" 
                                   Color="Color.Success" />
                    </MudTabPanel>
                    
                    <MudTabPanel Text="Phân loại" Icon="@Icons.Material.Filled.Style">
                        <div class="d-flex justify-space-between align-center mb-4">
                            <MudText Typo="Typo.subtitle1">Danh sách phân loại sản phẩm</MudText>
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="OpenAddVariantDialog"
                                       Size="Size.Small">
                                Thêm phân loại
                            </MudButton>
                        </div>
                        
                        @if (_variants.Any())
                        {
                            <MudTable Items="_variants" Dense="true" Hover="true" Striped="true">
                                <HeaderContent>
                                    <MudTh>SKU</MudTh>
                                    <MudTh>Thuộc tính</MudTh>
                                    <MudTh>Giá</MudTh>
                                    <MudTh>Tồn kho</MudTh>
                                    <MudTh>Trạng thái</MudTh>
                                    <MudTh>Thao tác</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="SKU">@context.Sku</MudTd>
                                    <MudTd DataLabel="Thuộc tính">
                                        @if (context.Attributes.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var attr in context.Attributes)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                                        @attr.Key: @attr.Value
                                                    </MudChip>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Không có thuộc tính</MudText>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Giá">@context.Price.ToString("N0")đ</MudTd>
                                    <MudTd DataLabel="Tồn kho">
                                        <MudChip T="int" Size="Size.Small" Color="@GetStockColor(context.StockQuantity)">
                                            @context.StockQuantity
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Trạng thái">
                                        <MudSwitch T="bool" Value="@context.IsActive"
                                                   ValueChanged="@(v => ToggleVariantStatus(context.Id, v))"
                                                   Color="Color.Success" 
                                                   UncheckedColor="Color.Error" />
                                    </MudTd>
                                    <MudTd>
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                                       Color="Color.Primary" 
                                                       OnClick="@(() => OpenEditVariantDialog(context))" 
                                                       Size="Size.Small" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                       Color="Color.Error" 
                                                       OnClick="@(() => DeleteVariant(context))" 
                                                       Size="Size.Small" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info">
                                Chưa có phân loại nào. Nhấn "Thêm phân loại" để tạo các phiên bản khác nhau của sản phẩm (ví dụ: Màu sắc, Kích thước).
                            </MudAlert>
                        }
                    </MudTabPanel>
                }
            </MudTabs>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid || _isUploading">
            @(_isEdit ? "Cập nhật" : "Thêm mới")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int? ProductId { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isEdit => ProductId.HasValue;
    private bool _isUploading = false;
    
    private List<CategoryResponse> _categories = new();
    private List<BrandResponse> _brands = new();
    private List<SupplierResponse> _suppliers = new();
    private List<string> _imageUrls = new();
    private List<ProductVariantListResponse> _variants = new();
    
    private string _sku = "";
    
    private UpdateProductRequest _request = new()
    {
        Name = "",
        CategoryId = 0,
        BrandId = 0,
        IsActive = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDropdownData();
        await LoadFormData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isEdit)
        {
            await LoadFormData();
        }
    }

    private async Task LoadFormData()
    {
        if (_isEdit)
        {
            await LoadProduct();
        }
        else
        {
            var firstCategory = _categories.FirstOrDefault();
            var firstBrand = _brands.FirstOrDefault();
            
            _request = new UpdateProductRequest
            {
                Name = "",
                CategoryId = firstCategory?.Id ?? 0,
                BrandId = firstBrand?.Id ?? 0,
                IsActive = true
            };
            _sku = "";
            _imageUrls = new();
            
            if (firstCategory == null || firstBrand == null)
            {
                Snackbar.Add("Vui lòng tạo danh mục và thương hiệu trước khi thêm sản phẩm", Severity.Warning);
            }
        }
    }

    private async Task LoadDropdownData()
    {
        try
        {
            _categories = await CategoryService.GetAllAsync();
            _brands = await BrandService.GetAllAsync();
            _suppliers = await SupplierService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadProduct()
    {
        try
        {
            var product = await ProductService.GetByIdAsync(ProductId.Value);
            if (product != null)
            {
                _request = new UpdateProductRequest
                {
                    Name = product.Name,
                    Description = product.Description,
                    Specs = product.Specs,
                    RequiresInstallation = product.RequiresInstallation,
                    CategoryId = product.CategoryId,
                    BrandId = product.BrandId,
                    SupplierId = product.SupplierId,
                    IsActive = product.IsActive
                };
                _sku = product.Sku;
                _imageUrls = product.Images.Select(i => i.Url).ToList();
                
                // Load variants for this product
                await LoadVariants();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải sản phẩm: {ex.Message}", Severity.Error);
            MudDialog.Cancel();
        }
    }

    private async Task UploadImages(IReadOnlyList<IBrowserFile> files)
    {
        _isUploading = true;
        StateHasChanged();

        try
        {
            Console.WriteLine($"UploadImages called with {files.Count} files");
            var httpClient = new HttpClient { BaseAddress = new Uri(NavigationManager.BaseUri) };
            int successCount = 0;
            
            foreach (var file in files)
            {
                Console.WriteLine($"Processing file: {file.Name}, size: {file.Size}");
                var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
                content.Add(fileContent, "file", file.Name);

                var response = await httpClient.PostAsync("api/upload/temp", content);
                
                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                    if (result != null)
                    {
                        Console.WriteLine($"Upload success, URL: {result.url}");
                        _imageUrls.Add(result.url);
                        successCount++;
                    }
                }
                else
                {
                    Console.WriteLine($"Upload failed: {response.StatusCode}");
                }
            }
            
            Console.WriteLine($"Total images in list: {_imageUrls.Count}");
            Snackbar.Add($"Đã upload {successCount}/{files.Count} hình ảnh", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi upload: {ex.Message}", Severity.Error);
            Console.WriteLine($"Upload exception: {ex}");
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    private async Task RemoveImage(int index)
    {
        if (index >= 0 && index < _imageUrls.Count)
        {
            _imageUrls.RemoveAt(index);
            StateHasChanged();
            await Task.Delay(1);
            if (_form != null)
            {
                await _form.ValidateAsync();
            }
        }
    }

    private void SetMainImage(int index)
    {
        if (index > 0 && index < _imageUrls.Count)
        {
            var url = _imageUrls[index];
            _imageUrls.RemoveAt(index);
            _imageUrls.Insert(0, url);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        try
        {
            if (_request.CategoryId <= 0)
            {
                Snackbar.Add("Vui lòng chọn danh mục", Severity.Warning);
                return;
            }
            
            if (_request.BrandId <= 0)
            {
                Snackbar.Add("Vui lòng chọn thương hiệu", Severity.Warning);
                return;
            }
            
            if (string.IsNullOrWhiteSpace(_sku))
            {
                Snackbar.Add("Vui lòng nhập SKU", Severity.Warning);
                return;
            }

            if (_isEdit)
            {
                _request.ImageUrls = _imageUrls;
                await ProductService.UpdateAsync(ProductId.Value, _request);
                Snackbar.Add("Đã cập nhật sản phẩm", Severity.Success);
            }
            else
            {
                var createRequest = new CreateProductRequest
                {
                    Name = _request.Name,
                    Sku = _sku,
                    Description = _request.Description,
                    Specs = _request.Specs,
                    RequiresInstallation = _request.RequiresInstallation,
                    CategoryId = _request.CategoryId,
                    BrandId = _request.BrandId,
                    SupplierId = _request.SupplierId,
                    ImageUrls = _imageUrls
                };
                await ProductService.CreateAsync(createRequest);
                Snackbar.Add("Đã thêm sản phẩm mới", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private class UploadResult
    {
        public string url { get; set; } = "";
    }

    // Variant management methods
    private async Task LoadVariants()
    {
        if (_isEdit && ProductId.HasValue)
        {
            try
            {
                _variants = await VariantService.GetByProductIdAsync(ProductId.Value);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading variants: {ex.Message}");
            }
        }
    }

    private async Task OpenAddVariantDialog()
    {
        if (!ProductId.HasValue) return;

        var parameters = new DialogParameters<ProductVariantDialog>();
        parameters.Add(x => x.ProductId, ProductId.Value);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProductVariantDialog>("Thêm phân loại sản phẩm", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadVariants();
        }
    }

    private async Task OpenEditVariantDialog(ProductVariantListResponse variant)
    {
        if (!ProductId.HasValue) return;

        var parameters = new DialogParameters<ProductVariantDialog>();
        parameters.Add(x => x.ProductId, ProductId.Value);
        parameters.Add(x => x.VariantId, variant.Id);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ProductVariantDialog>("Sửa phân loại sản phẩm", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadVariants();
        }
    }

    private async Task DeleteVariant(ProductVariantListResponse variant)
    {
        var parameters = new DialogParameters
        {
            { "Title", "Xác nhận xóa" },
            { "Content", $"Bạn có chắc muốn xóa phân loại \"{variant.Sku}\"?" },
            { "ConfirmText", "Xóa" },
            { "CancelText", "Hủy" }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is true)
        {
            try
            {
                await VariantService.DeleteAsync(variant.Id);
                Snackbar.Add("Đã xóa phân loại sản phẩm", Severity.Success);
                await LoadVariants();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi khi xóa: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task ToggleVariantStatus(int variantId, bool isActive)
    {
        try
        {
            if (isActive)
                await VariantService.ActivateAsync(variantId);
            else
                await VariantService.DeactivateAsync(variantId);
            
            Snackbar.Add($"Đã {(isActive ? "kích hoạt" : "vô hiệu hóa")} phân loại", Severity.Success);
            await LoadVariants();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
            await LoadVariants();
        }
    }

    private static Color GetStockColor(int stock)
    {
        return stock switch
        {
            0 => Color.Error,
            <= 10 => Color.Warning,
            _ => Color.Success
        };
    }
}
