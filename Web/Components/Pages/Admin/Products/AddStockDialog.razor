@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudText Typo="Typo.h6" Class="mb-4">@ProductName</MudText>

            <MudNumericField T="int" @bind-Value="_request.Quantity"
                             Label="Số lượng nhập *"
                             Required="true" RequiredError="Nhập số lượng"
                             Variant="Variant.Outlined" Class="mb-3"
                             Min="1" />

            <MudSelect T="int?" @bind-Value="_request.WarehouseId" Label="Kho nhập *"
                       Required="true" RequiredError="Chọn kho"
                       Variant="Variant.Outlined" Class="mb-3">
                @foreach (var wh in _warehouses)
                {
                    <MudSelectItem T="int?" Value="@wh.Id">@wh.Name</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_request.Reason" Label="Lý do nhập kho"
                          Variant="Variant.Outlined" Class="mb-3"
                          HelperText="VD: Nhập từ nhà cung cấp, kiểm kê thêm..." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">
            Nhập kho
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int ProductId { get; set; }

    [Parameter]
    public string ProductName { get; set; } = "";

    private MudForm _form = null!;
    private bool _isValid;
    private List<WarehouseResponse> _warehouses = new();

    private AddStockRequest _request = new()
    {
        Quantity = 0,
        Reason = ""
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadWarehouses();
    }

    private async Task LoadWarehouses()
    {
        try
        {
            _warehouses = await WarehouseService.GetAllAsync();
            // Tự động chọn kho đầu tiên nếu chỉ có một kho
            if (_warehouses.Count == 1)
            {
                _request.WarehouseId = _warehouses[0].Id;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải danh sách kho: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        try
        {
            await ProductService.AddStockAsync(ProductId, _request);
            Snackbar.Add($"Đã nhập {_request.Quantity} sản phẩm vào kho", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
