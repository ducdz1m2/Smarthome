@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Web.Helpers
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="mb-0">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-2" />
            Chi tiết Yêu cầu Bảo hành
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (WarrantyRequest != null)
        {
            <MudGrid Class="mb-3">
                <!-- Status Card -->
                <MudItem xs="12">
                    <MudCard Elevation="1" Class="mb-3">
                        <MudCardContent>
                            <div class="d-flex align-center justify-space-between">
                                <MudText Typo="Typo.subtitle2" Class="text-secondary">Trạng thái</MudText>
                                <MudChip T="string" Color="@StatusHelper.GetWarrantyStatusColor(WarrantyRequest.Status)" Size="Size.Large" Variant="Variant.Filled">
                                    <MudIcon Icon="@GetStatusIcon(WarrantyRequest.Status)" Class="mr-1" Size="Size.Small" />
                                    @StatusHelper.GetWarrantyStatusText(WarrantyRequest.Status)
                                </MudChip>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Order Info -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Class="mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" Size="Size.Small" />
                                    Thông tin đơn hàng
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Tag" Class="mr-2" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2"><strong>Mã đơn:</strong> @WarrantyRequest.OrderNumber</MudText>
                                </div>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-2" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2"><strong>Sản phẩm:</strong> @WarrantyRequest.ProductName</MudText>
                                </div>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Class="mr-2" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2"><strong>Ngày tạo:</strong> @WarrantyRequest.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                </div>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Issue Description -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Class="mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Class="mr-2" Size="Size.Small" />
                                    Mô tả vấn đề
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudPaper Class="pa-3" Elevation="0" Style="background-color: var(--mud-palette-action-disabled-background);">
                                <MudText Typo="Typo.body2">@WarrantyRequest.Description</MudText>
                            </MudPaper>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Timeline -->
                <MudItem xs="12">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Class="mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" Size="Size.Small" />
                                    Timeline
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Create" Class="mr-2" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Typo="Typo.body2"><strong>Ngày tạo:</strong> @WarrantyRequest.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                </div>
                                @if (WarrantyRequest.ApprovedAt.HasValue)
                                {
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2"><strong>Ngày duyệt:</strong> @WarrantyRequest.ApprovedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                    </div>
                                }
                                @if (WarrantyRequest.StartedAt.HasValue)
                                {
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.BuildCircle" Class="mr-2" Size="Size.Small" Color="Color.Info" />
                                        <MudText Typo="Typo.body2"><strong>Ngày bắt đầu:</strong> @WarrantyRequest.StartedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                    </div>
                                }
                                @if (WarrantyRequest.CompletedAt.HasValue)
                                {
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.DoneAll" Class="mr-2" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.body2"><strong>Ngày hoàn thành:</strong> @WarrantyRequest.CompletedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                    </div>
                                }
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Technician Notes -->
                @if (!string.IsNullOrEmpty(WarrantyRequest.TechnicianNotes))
                {
                    <MudItem xs="12">
                        <MudCard Elevation="1">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" Size="Size.Small" />
                                        Ghi chú kỹ thuật viên
                                    </MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: var(--mud-palette-info-light);">
                                    <MudText Typo="Typo.body2">@WarrantyRequest.TechnicianNotes</MudText>
                                </MudPaper>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }

                <!-- Warranty Items -->
                @if (WarrantyRequest.Items.Any())
                {
                    <MudItem xs="12">
                        <MudCard Elevation="1">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">
                                        <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" Size="Size.Small" />
                                        Sản phẩm bảo hành
                                    </MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudList T="string" Dense="true">
                                    @foreach (var item in WarrantyRequest.Items)
                                    {
                                        <MudListItem T="string">
                                            <div class="d-flex align-center justify-space-between" style="width: 100%;">
                                                <MudText Typo="Typo.body2">@item.Description</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">x @item.Quantity</MudChip>
                                            </div>
                                        </MudListItem>
                                    }
                                </MudList>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public WarrantyRequestResponse? WarrantyRequest { get; set; }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private string GetStatusIcon(string status)
    {
        return status switch
        {
            "Pending" => Icons.Material.Filled.Pending,
            "Approved" => Icons.Material.Filled.CheckCircle,
            "Rejected" => Icons.Material.Filled.Cancel,
            "InProgress" => Icons.Material.Filled.BuildCircle,
            "Completed" => Icons.Material.Filled.DoneAll,
            _ => Icons.Material.Filled.Info
        };
    }
}
