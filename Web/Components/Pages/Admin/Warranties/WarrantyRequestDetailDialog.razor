@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Web.Helpers
@using MudBlazor

<MudDialog>
    <DialogContent>
        @if (WarrantyRequest != null)
        {
            <MudText Typo="Typo.h6" Class="mb-3">Thông tin yêu cầu bảo hành</MudText>

            <MudPaper Class="pa-3 mb-3" Elevation="2">
                <div class="d-flex flex-column gap-2">
                    <div><strong>Mã đơn:</strong> @WarrantyRequest.OrderNumber</div>
                    <div><strong>Mô tả:</strong> @WarrantyRequest.Description</div>
                    <div><strong>Trạng thái:</strong>
                        <MudChip T="string" Color="@StatusHelper.GetWarrantyStatusColor(WarrantyRequest.Status)" Size="Size.Small">@StatusHelper.GetWarrantyStatusText(WarrantyRequest.Status)</MudChip>
                    </div>
                    <div><strong>Ngày tạo:</strong> @WarrantyRequest.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    @if (WarrantyRequest.ApprovedAt.HasValue)
                    {
                        <div><strong>Ngày duyệt:</strong> @WarrantyRequest.ApprovedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    }
                    @if (WarrantyRequest.StartedAt.HasValue)
                    {
                        <div><strong>Ngày bắt đầu:</strong> @WarrantyRequest.StartedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    }
                    @if (WarrantyRequest.CompletedAt.HasValue)
                    {
                        <div><strong>Ngày hoàn thành:</strong> @WarrantyRequest.CompletedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    }
                    @if (!string.IsNullOrEmpty(WarrantyRequest.TechnicianNotes))
                    {
                        <div><strong>Ghi chú kỹ thuật viên:</strong> @WarrantyRequest.TechnicianNotes</div>
                    }
                    @if (WarrantyRequest.Items.Any())
                    {
                        <div><strong>Sản phẩm bảo hành:</strong></div>
                        @foreach (var item in WarrantyRequest.Items)
                        {
                            <div class="ml-3">- @item.Description (x @item.Quantity)</div>
                        }
                    }
                </div>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public WarrantyRequestResponse? WarrantyRequest { get; set; }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}
