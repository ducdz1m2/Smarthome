@page "/admin/warranty-requests"
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using Web.Helpers

@inject IWarrantyRequestService WarrantyRequestService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<MudText Typo="Typo.h4" Class="mb-4">Quản lý Yêu cầu Bảo hành</MudText>

<MudTable Items="_warrantyRequests" Dense="true" Hover="true" Loading="_loading"
          LoadingProgressColor="Color.Primary" Striped="true" Bordered="true"
          Filter="@FilterWarrantyRequests" SortMode="SortMode.Single" AllowUnsorted="false">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách yêu cầu bảo hành</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Tìm kiếm..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh width="60px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.Id)">ID</MudTableSortLabel></MudTh>
        <MudTh width="100px">Order Item</MudTh>
        <MudTh width="200px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.Description)">Mô tả</MudTableSortLabel></MudTh>
        <MudTh width="120px">Kỹ thuật viên</MudTh>
        <MudTh width="100px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.Status)">Trạng thái</MudTableSortLabel></MudTh>
        <MudTh width="150px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.CreatedAt)">Ngày tạo</MudTableSortLabel></MudTh>
        <MudTh width="100px">Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Order Item">#@context.OrderItemId</MudTd>
        <MudTd DataLabel="Mô tả">@context.Description</MudTd>
        <MudTd DataLabel="Kỹ thuật viên">
            @(context.AssignedTechnicianId.HasValue ? $"KTV #{context.AssignedTechnicianId}" : "Chưa gán")
        </MudTd>
        <MudTd DataLabel="Trạng thái">
            <MudChip T="string" Color="@StatusHelper.GetWarrantyStatusColor(context.Status)" Size="Size.Small">@StatusHelper.GetWarrantyStatusText(context.Status)</MudChip>
        </MudTd>
        <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
        <MudTd>
            <div class="d-flex gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                             Color="Color.Primary"
                             Size="Size.Small"
                             OnClick="() => ViewDetails(context.Id)"
                             Title="Chi tiết" />
                @if (context.Status == "Pending")
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                 Color="Color.Success"
                                 Size="Size.Small"
                                 OnClick="() => Approve(context.Id)"
                                 Title="Duyệt" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                 Color="Color.Error"
                                 Size="Size.Small"
                                 OnClick="() => Reject(context.Id)"
                                 Title="Từ chối" />
                }
            </div>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager RowsPerPageString="Số dòng:" rowsPerPageOptions="new[] { 5, 10, 25, 50 }"
                       InfoFormat="{first_item}-{last_item} / {all_items}" />
    </PagerContent>
</MudTable>

@code {
    private List<WarrantyRequestResponse> _warrantyRequests = new();
    private bool _loading = true;
    private string _searchString = "";

    private bool FilterWarrantyRequests(WarrantyRequestResponse warrantyRequest)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return warrantyRequest.OrderNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               warrantyRequest.Id.ToString().Contains(_searchString) ||
               warrantyRequest.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadWarrantyRequests();
    }

    private async Task LoadWarrantyRequests()
    {
        _loading = true;
        try
        {
            var allRequests = await WarrantyRequestService.GetAllAsync();
            // Show all warranty request statuses including InProgress and Completed
            _warrantyRequests = allRequests.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải yêu cầu bảo hành: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Approve(int id)
    {
        try
        {
            await WarrantyRequestService.ApproveAsync(id);
            Snackbar.Add("Đã duyệt yêu cầu bảo hành", Severity.Success);
            await LoadWarrantyRequests();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task Reject(int id)
    {
        try
        {
            await WarrantyRequestService.RejectAsync(id, "Yêu cầu không được duyệt");
            Snackbar.Add("Đã từ chối yêu cầu bảo hành", Severity.Success);
            await LoadWarrantyRequests();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ViewDetails(int id)
    {
        try
        {
            var warrantyRequest = await WarrantyRequestService.GetByIdAsync(id);
            if (warrantyRequest == null)
            {
                Snackbar.Add("Không tìm thấy yêu cầu bảo hành", Severity.Error);
                return;
            }

            var parameters = new DialogParameters<WarrantyRequestDetailDialog>
            {
                { x => x.WarrantyRequest, warrantyRequest }
            };

            await DialogService.ShowAsync<WarrantyRequestDetailDialog>("Chi tiết yêu cầu bảo hành", parameters);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
