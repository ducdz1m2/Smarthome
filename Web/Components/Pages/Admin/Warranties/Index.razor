@page "/admin/warranties"
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using MudBlazor
@using Web.Components.Shared
@layout AdminLayout
@inject IWarrantyService WarrantyService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<MudText Typo="Typo.h4" Class="mb-4">Quản lý Bảo hành</MudText>

<MudTable Items="_warranties" Dense="true" Hover="true" Loading="_loading" 
          LoadingProgressColor="Color.Primary" Striped="true" Bordered="true"
          Filter="@FilterWarranties" SortMode="SortMode.Single" AllowUnsorted="false">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách bảo hành</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Tìm kiếm..." 
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh Width="60px"><MudTableSortLabel T="WarrantyResponse" SortBy="@(w => w.Id)">ID</MudTableSortLabel></MudTh>
        <MudTh Width="150px"><MudTableSortLabel T="WarrantyResponse" SortBy="@(w => w.ProductName)">Sản phẩm</MudTableSortLabel></MudTh>
        <MudTh Width="100px"><MudTableSortLabel T="WarrantyResponse" SortBy="@(w => w.OrderItemId)">Mã đơn</MudTableSortLabel></MudTh>
        <MudTh Width="120px"><MudTableSortLabel T="WarrantyResponse" SortBy="@(w => w.StartDate)">Bắt đầu</MudTableSortLabel></MudTh>
        <MudTh Width="120px"><MudTableSortLabel T="WarrantyResponse" SortBy="@(w => w.EndDate)">Kết thúc</MudTableSortLabel></MudTh>
        <MudTh Width="100px"><MudTableSortLabel T="WarrantyResponse" SortBy="@(w => w.Status)">Trạng thái</MudTableSortLabel></MudTh>
        <MudTh Width="80px">Số yêu cầu</MudTh>
        <MudTh Width="150px">Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Sản phẩm">
            <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.ProductName</MudText>
            <MudText Typo="Typo.caption">ID: @context.ProductId</MudText>
        </MudTd>
        <MudTd DataLabel="Mã đơn">#@context.OrderItemId</MudTd>
        <MudTd DataLabel="Bắt đầu">@context.StartDate.ToString("dd/MM/yyyy")</MudTd>
        <MudTd DataLabel="Kết thúc">
            <MudText Color="@GetExpiryColor(context.EndDate)">
                @context.EndDate.ToString("dd/MM/yyyy")
            </MudText>
        </MudTd>
        <MudTd DataLabel="Trạng thái">
            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">
                @GetStatusDisplay(context.Status)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Yêu cầu">
            <MudChip T="string" Color="Color.Info" Size="Size.Small">
                @(context.Claims?.Count ?? 0) yêu cầu
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" 
                           OnClick="@(() => ViewWarranty(context))" Size="Size.Small" />
            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" 
                           OnClick="@(() => OpenClaimDialog(context))" Size="Size.Small" 
                           Disabled="@(!CanCreateClaim(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager RowsPerPageString="Số dòng:" RowsPerPageOptions="new[] { 5, 10, 25, 50 }"
                       InfoFormat="{first_item}-{last_item} / {all_items}" />
    </PagerContent>
</MudTable>

@code {
    private List<WarrantyResponse> _warranties = new();
    private bool _loading = true;
    private string _searchString = "";

    private bool FilterWarranties(WarrantyResponse warranty)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        
        return warranty.ProductName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               warranty.Id.ToString().Contains(_searchString);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadWarranties();
    }

    private async Task LoadWarranties()
    {
        _loading = true;
        try
        {
            _warranties = await WarrantyService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải danh sách: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ViewWarranty(WarrantyResponse warranty)
    {
        NavigationManager.NavigateTo($"/admin/warranties/{warranty.Id}");
    }

    private async Task OpenClaimDialog(WarrantyResponse warranty)
    {
        var parameters = new DialogParameters<CreateClaimDialog>();
        parameters.Add(x => x.WarrantyId, warranty.Id);

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateClaimDialog>("Tạo yêu cầu bảo hành", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadWarranties();
            Snackbar.Add("Đã tạo yêu cầu bảo hành", Severity.Success);
        }
    }

    private bool CanCreateClaim(WarrantyResponse warranty)
    {
        return warranty.Status == "Active" && warranty.EndDate > DateTime.UtcNow;
    }

    private static Color GetStatusColor(string status)
    {
        return status switch
        {
            "Active" => Color.Success,
            "Expired" => Color.Error,
            "Void" => Color.Default,
            _ => Color.Default
        };
    }

    private static string GetStatusDisplay(string status)
    {
        return status switch
        {
            "Active" => "Còn hiệu lực",
            "Expired" => "Hết hạn",
            "Void" => "Vô hiệu",
            _ => status
        };
    }

    private static Color GetExpiryColor(DateTime endDate)
    {
        var daysRemaining = (endDate - DateTime.UtcNow).Days;
        if (daysRemaining < 0) return Color.Error;
        if (daysRemaining < 30) return Color.Warning;
        return Color.Success;
    }
}
