@page "/admin/warranty-requests"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Microsoft.AspNetCore.Authorization
@using Web.Helpers
@using Web.Components.Pages.Admin.Installations

@inject IWarrantyRequestService WarrantyRequestService
@inject IInstallationService InstallationService
@inject IOrderService OrderService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<div class="pa-4">
    <PageHeader Title="Quản lý Yêu cầu Bảo hành" ShowAddButton="false" />

    <FilterBar>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string" Label="Lọc theo trạng thái" @bind-Value="_selectedStatus" Clearable="true" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@null">Tất cả</MudSelectItem>
                @foreach (var status in _statusList)
                {
                    <MudSelectItem Value="@status">@StatusHelper.GetWarrantyStatusText(status)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudTextField @bind-Value="_searchString" Placeholder="Tìm kiếm theo mã đơn, tên khách hàng, sản phẩm..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Immediate="true"></MudTextField>
        </MudItem>
    </FilterBar>

    <MudTable Items="_warrantyRequests" Dense="true" Hover="true" Loading="_loading"
              LoadingProgressColor="Color.Primary" Striped="true" Bordered="true"
              Filter="@FilterWarrantyRequests" SortMode="SortMode.Single" AllowUnsorted="false">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Danh sách yêu cầu bảo hành</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh width="60px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.Id)">ID</MudTableSortLabel></MudTh>
            <MudTh width="120px">Mã đơn</MudTh>
            <MudTh width="150px">Khách hàng</MudTh>
            <MudTh width="200px">Sản phẩm</MudTh>
            <MudTh width="150px">Mô tả</MudTh>
            <MudTh width="100px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.Status)">Trạng thái</MudTableSortLabel></MudTh>
            <MudTh width="120px"><MudTableSortLabel T="WarrantyRequestResponse" SortBy="@(w => w.CreatedAt)">Ngày tạo</MudTableSortLabel></MudTh>
            <MudTh width="180px">Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Mã đơn">
                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.OrderNumber</MudText>
            </MudTd>
            <MudTd DataLabel="Khách hàng">@context.CustomerName</MudTd>
            <MudTd DataLabel="Sản phẩm">@context.ProductName</MudTd>
            <MudTd DataLabel="Mô tả">
                <MudText Typo="Typo.caption" Style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;">
                    @context.Description
                </MudText>
            </MudTd>
            <MudTd DataLabel="Trạng thái">
                <MudChip T="string" Color="@StatusHelper.GetWarrantyStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">
                    @StatusHelper.GetWarrantyStatusText(context.Status)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd>
                <div class="d-flex gap-1 flex-wrap">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                              OnClick="() => ViewDetails(context.Id)">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Class="mr-1" Size="Size.Small" />
                        Chi tiết
                    </MudButton>
                    @if (context.Status == "Pending")
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                  OnClick="() => Approve(context.Id)">
                            <MudIcon Icon="@Icons.Material.Filled.Check" Class="mr-1" Size="Size.Small" />
                            Duyệt
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                  OnClick="() => Reject(context.Id)">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Class="mr-1" Size="Size.Small" />
                            Từ chối
                        </MudButton>
                    }
                    @if (context.Status == "Approved" && !context.InstallationBookingId.HasValue)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Info"
                                  OnClick="() => CreateWarrantyBooking(context.Id, context.OrderId)">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Class="mr-1" Size="Size.Small" />
                            Tạo lịch
                        </MudButton>
                    }
                </div>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager RowsPerPageString="Số dòng:" rowsPerPageOptions="new[] { 5, 10, 25, 50 }"
                           InfoFormat="{first_item}-{last_item} / {all_items}" />
        </PagerContent>
    </MudTable>
</div>

@code {
    private List<WarrantyRequestResponse> _warrantyRequests = new();
    private List<WarrantyRequestResponse> _allRequests = new();
    private bool _loading = true;
    private string _searchString = "";
    private string _selectedStatus = "Pending";
    private int _pendingCount = 0;

    private readonly string[] _statusList = new[]
    {
        "Pending", "Approved", "InProgress", "Completed", "Rejected"
    };

    private bool FilterWarrantyRequests(WarrantyRequestResponse warrantyRequest)
    {
        if (string.IsNullOrWhiteSpace(_searchString) && string.IsNullOrWhiteSpace(_selectedStatus))
            return true;

        var matchesSearch = string.IsNullOrWhiteSpace(_searchString) ||
            warrantyRequest.OrderNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            warrantyRequest.Id.ToString().Contains(_searchString) ||
            warrantyRequest.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            warrantyRequest.ProductName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            warrantyRequest.CustomerName.Contains(_searchString, StringComparison.OrdinalIgnoreCase);

        var matchesStatus = string.IsNullOrWhiteSpace(_selectedStatus) ||
            warrantyRequest.Status == _selectedStatus;

        return matchesSearch && matchesStatus;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadWarrantyRequests();
    }

    private async Task LoadWarrantyRequests()
    {
        _loading = true;
        try
        {
            var allRequests = await WarrantyRequestService.GetAllAsync();
            _allRequests = allRequests.ToList();
            _pendingCount = _allRequests.Count(w => w.Status == "Pending");

            // Default sort: Pending first, then by date descending
            _warrantyRequests = _allRequests
                .OrderByDescending(w => w.Status == "Pending")
                .ThenByDescending(w => w.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải yêu cầu bảo hành: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Approve(int id)
    {
        try
        {
            await WarrantyRequestService.ApproveAsync(id);
            Snackbar.Add("Đã duyệt yêu cầu bảo hành", Severity.Success);
            await LoadWarrantyRequests();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task Reject(int id)
    {
        try
        {
            await WarrantyRequestService.RejectAsync(id, "Yêu cầu không được duyệt");
            Snackbar.Add("Đã từ chối yêu cầu bảo hành", Severity.Success);
            await LoadWarrantyRequests();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task ViewDetails(int id)
    {
        try
        {
            var warrantyRequest = await WarrantyRequestService.GetByIdAsync(id);
            if (warrantyRequest == null)
            {
                Snackbar.Add("Không tìm thấy yêu cầu bảo hành", Severity.Error);
                return;
            }

            var parameters = new DialogParameters<WarrantyRequestDetailDialog>
            {
                { x => x.WarrantyRequest, warrantyRequest }
            };

            await DialogService.ShowAsync<WarrantyRequestDetailDialog>("Chi tiết yêu cầu bảo hành", parameters);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task CreateWarrantyBooking(int warrantyRequestId, int orderId)
    {
        try
        {
            // Get order information to extract shipping location for technician filtering
            var order = await OrderService.GetByIdAsync(orderId);
            string? filterCity = order?.ShippingCity;
            string? filterDistrict = order?.ShippingDistrict;

            var parameters = new DialogParameters
            {
                { "OrderId", orderId },
                { "WarrantyRequestId", warrantyRequestId },
                { "IsWarranty", true },
                { "FilterCity", filterCity },
                { "FilterDistrict", filterDistrict }
            };

            var dialog = await DialogService.ShowAsync<InstallationBookingDialog>("Tạo lịch bảo hành", parameters);
            var result = await dialog.Result;

            if (result.Canceled)
                return;

            Snackbar.Add("Đã tạo lịch bảo hành thành công", Severity.Success);
            await LoadWarrantyRequests();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
