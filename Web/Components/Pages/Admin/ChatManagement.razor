@code {
    private List<ChatRoomResponse> _chatRooms = new();
    private List<ChatMessageResponse> _messages = new();
    private int SelectedChatRoomId = 0;
    private string _message = "";
    private bool _loadingMessages = false;
    private bool _sending = false;
    private ElementReference _messagesContainer;
    private bool _initialized = false;
    private DateTime? _lastReadAt = null;
    private DateTime? _roomOpenTime = null;
    private bool _separatorShown = false;
    private Action<object>? _onMessageReceivedHandler;
    private IBrowserFile? _selectedFile;
    private string _filePreviewUrl = "";
    private bool _isRecording = false;
    private bool _isTranscribing = false;
    private static readonly SemaphoreSlim _chatServiceLock = new SemaphoreSlim(1, 1);

    private bool CanSendMessage => !_sending && !_isRecording && !_isTranscribing && (!string.IsNullOrWhiteSpace(_message) || _selectedFile != null);

    public async ValueTask DisposeAsync()
    {
        Console.WriteLine("[ChatManagement] DisposeAsync called - unsubscribing from events");
        if (_onMessageReceivedHandler != null)
        {
            SignalRService.OnChatMessageReceived -= _onMessageReceivedHandler;
            Console.WriteLine("[ChatManagement] OnChatMessageReceived event unsubscribed");
        }
        if (_isRecording)
        {
            _ = SpeechRecognitionService.CancelRecordingAsync();
        }
        await Task.CompletedTask;
    }

    private async Task ToggleRecording()
    {
        if (_isRecording)
        {
            // Stop recording - JavaScript will automatically stop and invoke callback
            _isTranscribing = true;
            await InvokeAsync(StateHasChanged);
            await SpeechRecognitionService.CancelRecordingAsync();
        }
        else
        {
            // Start recording with callback
            _isRecording = true;
            await InvokeAsync(StateHasChanged);

            try
            {
                await SpeechRecognitionService.StartRecordingAsync(async (text) =>
                {
                    _isRecording = false;
                    _isTranscribing = false;

                    if (!string.IsNullOrWhiteSpace(text))
                    {
                        _message += (string.IsNullOrEmpty(_message) ? "" : " ") + text;
                    }

                    await InvokeAsync(StateHasChanged);
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ChatManagement] Recording failed: {ex.Message}");
                _isRecording = false;
                _isTranscribing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        Console.WriteLine($"[ChatManagement] OnAfterRenderAsync called: firstRender={firstRender}, _initialized={_initialized}");
        
        if (firstRender && !_initialized)
        {
            try
            {
                Console.WriteLine("[ChatManagement] Initializing SignalR...");
                await SignalRService.InitializeAsync();
                Console.WriteLine("[ChatManagement] SignalRService.InitializeAsync completed");
                // Subscribe with sync wrapper to avoid async void issues
                _onMessageReceivedHandler = (msg) => _ = OnMessageReceived(msg);
                SignalRService.OnChatMessageReceived += _onMessageReceivedHandler;
                Console.WriteLine("[ChatManagement] OnChatMessageReceived event subscribed");
                await LoadChatRooms();
                _initialized = true;
                Console.WriteLine("[ChatManagement] Initialization completed successfully");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ChatManagement] Initialization failed: {ex.Message}");
                Console.WriteLine($"[ChatManagement] Stack trace: {ex.StackTrace}");
                await LoadChatRooms();
            }
        }
        else if (SelectedChatRoomId > 0 && _messages.Count == 0)
        {
            // Reload messages if room is selected but messages are empty (e.g., after F5)
            Console.WriteLine($"[ChatManagement] Room selected but messages empty, reloading messages");
            await InvokeAsync(async () => await LoadMessages());
        }
    }

    private async Task OnMessageReceived(object messageObj)
    {
        Console.WriteLine("[ChatManagement] OnMessageReceived called");
        try
        {
            var messageJson = System.Text.Json.JsonSerializer.Serialize(messageObj);
            Console.WriteLine($"[ChatManagement] Received message: {messageJson}");

            // Deserialize to check room and sender
            using var doc = System.Text.Json.JsonDocument.Parse(messageJson);
            if (doc.RootElement.TryGetProperty("chatRoomId", out var chatRoomIdElement) &&
                doc.RootElement.TryGetProperty("userId", out var userIdElement))
            {
                var messageRoomId = chatRoomIdElement.GetInt32();
                var senderId = userIdElement.GetInt32();
                var currentUserId = CurrentUser.UserId ?? 0;
                
                Console.WriteLine($"[ChatManagement] Message from user {senderId} to room {messageRoomId}, current room is {SelectedChatRoomId}, current user is {currentUserId}");

                // If message is from someone else and NOT currently viewing that room, increment badge
                if (senderId != currentUserId && SelectedChatRoomId != messageRoomId)
                {
                    Console.WriteLine($"[ChatManagement] Trying to increment badge for room {messageRoomId}. Total rooms: {_chatRooms.Count}");
                    var room = _chatRooms.FirstOrDefault(r => r.Id == messageRoomId);
                    if (room != null)
                    {
                        Console.WriteLine($"[ChatManagement] Found room {messageRoomId}, checking participants...");
                        var adminParticipant = room.Participants.FirstOrDefault(p => p.UserType == "Admin");
                        if (adminParticipant != null)
                        {
                            adminParticipant.UnreadCount++;
                            Console.WriteLine($"[ChatManagement] *** INCREMENTED BADGE *** for room {messageRoomId} to {adminParticipant.UnreadCount}");
                            await InvokeAsync(StateHasChanged);
                            Console.WriteLine($"[ChatManagement] StateHasChanged called for badge update");
                        }
                        else
                        {
                            Console.WriteLine($"[ChatManagement] Admin participant not found in room {messageRoomId}");
                        }
                    }
                    else
                    {
                        Console.WriteLine($"[ChatManagement] Room {messageRoomId} not found in _chatRooms");
                    }
                }
                else if (senderId != currentUserId && SelectedChatRoomId == messageRoomId)
                {
                    // Currently viewing the room - mark as read immediately
                    Console.WriteLine($"[ChatManagement] Currently viewing room {messageRoomId}, marking as read without badge");
                    _ = MarkAsRead();
                }

                // Only reload messages if the message is for the currently selected room
                if (SelectedChatRoomId > 0 && messageRoomId == SelectedChatRoomId)
                {
                    // If this is our own message, we already added it locally - don't reload to avoid losing it
                    if (senderId == currentUserId)
                    {
                        Console.WriteLine("[ChatManagement] Received own message - skipping reload to keep local message");
                    }
                    else
                    {
                        Console.WriteLine("[ChatManagement] Received message from others - reloading");
                        await LoadMessages();
                        await ScrollToBottom();
                    }
                }
                Console.WriteLine("[ChatManagement] Reload completed");
            }
            else
            {
                // Fallback: reload everything if we can't parse
                await LoadChatRooms();
                await InvokeAsync(StateHasChanged);
                if (SelectedChatRoomId > 0)
                {
                    await LoadMessages();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatManagement] Error processing message: {ex.Message}");
            // Fallback: reload everything
            await LoadChatRooms();
            await InvokeAsync(StateHasChanged);
            if (SelectedChatRoomId > 0)
            {
                await LoadMessages();
            }
        }
    }

    private async Task LoadChatRooms()
    {
        await _chatServiceLock.WaitAsync();
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            Console.WriteLine($"[ChatManagement] Loading chat rooms for admin user ID: {userId}");
            
            var rooms = await ChatService.GetAllSupportChatRoomsAsync();
            Console.WriteLine($"[ChatManagement] Found {rooms.Count} support chat rooms from service");
            
            _chatRooms = rooms.Select(r => new ChatRoomResponse
            {
                Id = r.Id,
                Title = r.Title,
                Type = r.Type,
                IsActive = r.IsActive,
                CreatedAt = r.CreatedAt,
                ClosedAt = r.ClosedAt,
                RelatedOrderId = r.RelatedOrderId,
                RelatedInstallationId = r.RelatedInstallationId,
                RelatedWarrantyClaimId = r.RelatedWarrantyClaimId,
                Participants = r.Participants.Select(p => new ChatParticipantResponse
                {
                    Id = p.Id,
                    UserId = p.UserId,
                    UserType = p.UserType,
                    UserName = p.UserName,
                    UserAvatar = p.UserAvatar,
                    JoinedAt = p.JoinedAt,
                    IsActive = p.IsActive,
                    IsBlocked = p.IsBlocked,
                    UnreadCount = p.UnreadCount,
                    LastActivityAt = p.LastActivityAt
                }).ToList(),
                LastMessage = r.LastMessage?.Content ?? "",
                UnreadCount = r.UnreadCount
            }).ToList();
            
            Console.WriteLine($"[ChatManagement] Mapped {_chatRooms.Count} chat rooms to UI");
            
            foreach (var room in _chatRooms)
            {
                Console.WriteLine($"[ChatManagement] UI Room: Id={room.Id}, Title={room.Title}, LastMessage={room.LastMessage}");
                
                // Join SignalR group for each room
                Console.WriteLine($"[ChatManagement] Joining SignalR group for room {room.Id}");
                await SignalRService.JoinChatRoom(room.Id);
                Console.WriteLine($"[ChatManagement] Joined SignalR group for room {room.Id}");
            }
            
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatManagement] Failed to load chat rooms: {ex.Message}");
            Console.WriteLine($"[ChatManagement] Stack trace: {ex.StackTrace}");
        }
        finally
        {
            _chatServiceLock.Release();
        }
    }

    private async Task SelectChatRoom(int roomId)
    {
        Console.WriteLine($"[ChatManagement] SelectChatRoom called with roomId: {roomId}");
        SelectedChatRoomId = roomId;
        _roomOpenTime = DateTime.Now;
        _separatorShown = false;
        Console.WriteLine($"[ChatManagement] SelectedChatRoomId set to: {SelectedChatRoomId}, RoomOpenTime: {_roomOpenTime}");
        await InvokeAsync(StateHasChanged);
        
        try
        {
            Console.WriteLine($"[ChatManagement] Joining SignalR chat room: {roomId}");
            await SignalRService.JoinChatRoom(roomId);
            
            // Mark chat as read to reset unread count when opening the room
            var userId = CurrentUser.UserId ?? 0;
            if (userId > 0)
            {
                await _chatServiceLock.WaitAsync();
                try
                {
                    Console.WriteLine($"[ChatManagement] Marking chat room {roomId} as read for user {userId}");
                    await ChatService.MarkChatAsReadAsync(roomId, userId);
                }
                finally
                {
                    _chatServiceLock.Release();
                }
            }
            
            // Reload chat rooms to update badge, then load messages
            await LoadChatRooms();
            await LoadMessages();
            Console.WriteLine($"[ChatManagement] SelectChatRoom completed");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatManagement] Error in SelectChatRoom: {ex.Message}");
        }
    }

    private async Task LoadMessages()
    {
        if (SelectedChatRoomId == 0) return;

        await _chatServiceLock.WaitAsync();
        try
        {
            _loadingMessages = true;
            _separatorShown = false;
            Console.WriteLine($"Loading messages for chat room: {SelectedChatRoomId}");
            var userId = CurrentUser.UserId ?? 0;
            Console.WriteLine($"Loading messages with user ID: {userId}");
            _messages = await ChatService.GetChatMessagesAsync(SelectedChatRoomId, userId, UserType.Admin);
            Console.WriteLine($"Loaded {_messages.Count} messages");
            
            // Get LastReadAt from admin participant
            var currentRoom = _chatRooms.FirstOrDefault(r => r.Id == SelectedChatRoomId);
            if (currentRoom != null)
            {
                var adminParticipant = currentRoom.Participants.FirstOrDefault(p => p.UserType == "Admin");
                _lastReadAt = adminParticipant?.LastReadAt;
                Console.WriteLine($"[ChatManagement] LastReadAt: {_lastReadAt}");
            }
            
            // Debug message order and content
            for (int i = 0; i < _messages.Count; i++)
            {
                var msg = _messages[i];
                Console.WriteLine($"[ChatManagement] Message[{i}]: Id={msg.Id}, SenderId={msg.SenderId}, Content={msg.Content}, SentAt={msg.SentAt}, IsFromMe={msg.IsFromMe}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load messages: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
        finally
        {
            _loadingMessages = false;
            _chatServiceLock.Release();
            Console.WriteLine($"[ChatManagement] LoadMessages completed, calling StateHasChanged, message count: {_messages.Count}");
            await InvokeAsync(StateHasChanged);
            Console.WriteLine($"[ChatManagement] StateHasChanged called");
            // Auto-scroll to bottom after loading messages
            try
            {
                await ScrollToBottom();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                Console.WriteLine("[ChatManagement] JS disconnected, skipping scroll");
            }
            // Mark as read after releasing lock and UI updated
            _ = MarkAsRead();
        }
    }

    private async Task MarkAsRead()
    {
        try
        {
            var userId = CurrentUser.UserId ?? 0;
            await _chatServiceLock.WaitAsync();
            try
            {
                await ChatService.MarkChatAsReadAsync(SelectedChatRoomId, userId);
            }
            finally
            {
                _chatServiceLock.Release();
            }
            // Note: LoadChatRooms should be called separately if needed
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to mark as read: {ex.Message}");
        }
    }

    private async Task SendMessage()
    {
        Console.WriteLine($"[ChatManagement] SendMessage called - Message: '{_message}', RoomId: {SelectedChatRoomId}, Sending: {_sending}");
        
        if (SelectedChatRoomId == 0 || _sending) 
        {
            Console.WriteLine($"[ChatManagement] SendMessage skipped - RoomId: {SelectedChatRoomId}, Sending: {_sending}");
            return;
        }

        if (string.IsNullOrWhiteSpace(_message) && _selectedFile == null)
        {
            Console.WriteLine($"[ChatManagement] SendMessage skipped - No content and no file");
            return;
        }

        var content = _message;
        var userId = CurrentUser.UserId ?? 0;
        _sending = true;

        // Upload file if selected
        string? fileUrl = null;
        string? fileName = null;
        string? fileType = null;
        long? fileSize = null;

        if (_selectedFile != null)
        {
            fileUrl = await UploadFileAsync(_selectedFile);
            if (fileUrl != null)
            {
                fileName = _selectedFile.Name;
                fileType = _selectedFile.ContentType;
                fileSize = _selectedFile.Size;
            }
            else
            {
                Console.WriteLine("[ChatManagement] File upload failed");
                // If file upload failed and no text content, don't send
                if (string.IsNullOrWhiteSpace(_message))
                {
                    Console.WriteLine("[ChatManagement] Cannot send message: no content and file upload failed");
                    _sending = false;
                    return;
                }
            }
        }

        ChatMessageResponse? tempMessage = null;

        try
        {
            // Add message to UI immediately for instant feedback
            tempMessage = new ChatMessageResponse
            {
                Id = _messages.Count > 0 ? _messages.Max(m => m.Id) + 1 : 1,
                ChatRoomId = SelectedChatRoomId,
                SenderId = userId,
                SenderType = "Admin",
                SenderName = CurrentUser.UserName,
                Content = content,
                SentAt = DateTime.Now,
                IsFromMe = true,
                Attachments = fileUrl != null ? new List<ChatAttachmentResponse>
                {
                    new ChatAttachmentResponse
                    {
                        FileUrl = fileUrl,
                        FileName = fileName ?? string.Empty,
                        FileType = fileType ?? string.Empty,
                        FileSize = fileSize ?? 0
                    }
                } : new()
            };
            _messages.Add(tempMessage);
            _message = "";
            _selectedFile = null;
            _filePreviewUrl = "";
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();

            // Send message via SignalR Hub (Hub will save to DB and broadcast to all clients)
            Console.WriteLine($"[ChatManagement] Sending message via SignalR Hub to chat room {SelectedChatRoomId}");
            await SignalRService.SendMessage(SelectedChatRoomId, userId, "Admin", content, fileUrl, fileName, fileType, fileSize);
            Console.WriteLine($"[ChatManagement] Message sent via SignalR Hub");
            // Note: Will reload when receiving own message via SignalR
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatManagement] Failed to send message: {ex.Message}");
            // Remove temp message if sending failed
            _messages.Remove(tempMessage);
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _sending = false;
        }
    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task TriggerFileSelect()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.admin-chat-file-input').click()");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            _selectedFile = file;
            
            // Create preview URL for images
            if (_isImageFile(file))
            {
                using var stream = file.OpenReadStream(file.Size);
                using var ms = new System.IO.MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();
                _filePreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            }
            
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RemoveFile()
    {
        _selectedFile = null;
        _filePreviewUrl = "";
    }

    private bool _isImageFile(IBrowserFile file)
    {
        var imageExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        return imageExtensions.Contains(extension);
    }

    private async Task<string?> UploadFileAsync(IBrowserFile file)
    {
        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var token = await JwtTokenHandler.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                httpClient.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream());
            content.Add(fileContent, "file", file.Name);

            var uploadUrl = $"{Navigation.BaseUri}api/chat/upload";
            var response = await httpClient.PostAsync(uploadUrl, content);
            
            if (response.IsSuccessStatusCode)
            {
                var responseContent = await response.Content.ReadAsStringAsync();
                using var doc = System.Text.Json.JsonDocument.Parse(responseContent);
                return doc.RootElement.TryGetProperty("fileUrl", out var fileUrlElem) ? fileUrlElem.GetString() : null;
            }
            
            return null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ChatManagement] Upload failed: {ex.Message}");
            return null;
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ');
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpper();
    }

    private string GetSelectedRoomName()
    {
        var room = _chatRooms.FirstOrDefault(r => r.Id == SelectedChatRoomId);
        if (room == null) return "";
        
        var customerParticipant = room.Participants.FirstOrDefault(p => p.UserType == "Customer");
        return customerParticipant?.UserName ?? room.Title;
    }

    private string GetSidebarHeaderName()
    {
        if (SelectedChatRoomId == 0)
        {
            return "Hỗ trợ khách hàng";
        }
        
        var room = _chatRooms.FirstOrDefault(r => r.Id == SelectedChatRoomId);
        if (room == null) return "Hỗ trợ khách hàng";
        
        var customerParticipant = room.Participants.FirstOrDefault(p => p.UserType == "Customer");
        return customerParticipant?.UserName ?? "Hỗ trợ khách hàng";
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("eval", @"
            const element = document.querySelector('.chat-messages');
            if (element) {
                element.scrollTop = element.scrollHeight;
            }
        ");
    }

