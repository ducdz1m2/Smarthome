@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@inject IWarrantyRequestService WarrantyRequestService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Yêu cầu bảo hành - Đơn #@OrderNumber</MudText>
        
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Loại bảo hành:</MudText>
            <MudSelect T="Domain.Enums.WarrantyType" @bind-Value="_warrantyType" Label="Chọn loại bảo hành *" Required="true" RequiredError="Vui lòng chọn loại bảo hành">
                <MudSelectItem T="Domain.Enums.WarrantyType" Value="@Domain.Enums.WarrantyType.Repair">Sửa chữa</MudSelectItem>
                <MudSelectItem T="Domain.Enums.WarrantyType" Value="@Domain.Enums.WarrantyType.Replace">Thay thế</MudSelectItem>
                <MudSelectItem T="Domain.Enums.WarrantyType" Value="@Domain.Enums.WarrantyType.Refund">Hoàn tiền</MudSelectItem>
            </MudSelect>
            
            <MudText Typo="Typo.subtitle1" Class="mb-2 mt-4">Chọn sản phẩm bảo hành:</MudText>
            
            @foreach (var item in Items)
            {
                <MudCard Class="mb-2" Elevation="0" Outlined="true">
                    <MudCardContent>
                        <div class="d-flex align-center justify-space-between mb-2">
                            <div>
                                <MudText Typo="Typo.body1" Class="fw-bold">@item.ProductName</MudText>
                                <MudText Typo="Typo.caption">SKU: @item.Sku</MudText>
                            </div>
                            <div class="d-flex align-center gap-3">
                                <MudNumericField T="int" @bind-Value="_warrantyQuantities[item.Id]"
                                                 Label="SL bảo hành" Min="0" Max="@item.Quantity"
                                                 Style="width: 120px;" />
                                <MudText Typo="Typo.caption">/ @item.Quantity</MudText>
                            </div>
                        </div>
                        <MudCheckBox T="bool" @bind-Checked="_isDamaged[item.Id]"
                                   Label="Sản phẩm bị hư hỏng (không trả lại kho)"
                                   Color="Color.Warning" />
                    </MudCardContent>
                </MudCard>
            }
            
            <MudTextField @bind-Value="_description" Label="Mô tả vấn đề *" 
                          Required="true" RequiredError="Vui lòng nhập mô tả"
                          Lines="3" Class="mt-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid || !HasSelectedItems()">
            Gửi yêu cầu
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .fw-bold {
        font-weight: 600;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int OrderId { get; set; }

    [Parameter]
    public string OrderNumber { get; set; } = "";

    [Parameter]
    public List<OrderItemResponse> Items { get; set; } = new();

    private MudForm _form = null!;
    private bool _isValid;
    private Domain.Enums.WarrantyType _warrantyType = Domain.Enums.WarrantyType.Repair;
    private string _description = "";
    private Dictionary<int, int> _warrantyQuantities = new();
    private Dictionary<int, bool> _isDamaged = new();

    protected override void OnInitialized()
    {
        // Initialize warranty quantities to 0
        foreach (var item in Items)
        {
            _warrantyQuantities[item.Id] = 0;
            _isDamaged[item.Id] = false;
        }
    }

    private bool HasSelectedItems()
    {
        return _warrantyQuantities.Values.Any(q => q > 0);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid || !HasSelectedItems()) return;

        try
        {
            // Create warranty items
            var warrantyItems = _warrantyQuantities
                .Where(x => x.Value > 0)
                .Select(x => new WarrantyRequestItemDto
                {
                    OrderItemId = x.Key,
                    Quantity = x.Value,
                    Description = _description,
                    IsDamaged = _isDamaged[x.Key]
                })
                .ToList();

            var request = new CreateWarrantyRequestRequest
            {
                OrderId = OrderId,
                WarrantyType = _warrantyType,
                Description = _description,
                Items = warrantyItems
            };

            await WarrantyRequestService.CreateAsync(request);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
