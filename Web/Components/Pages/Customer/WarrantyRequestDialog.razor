@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@inject IWarrantyRequestService WarrantyRequestService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Yêu cầu bảo hành sản phẩm</MudText>

        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Thông tin sản phẩm:</MudText>

            <MudSelect T="int?" @bind-Value="_selectedOrderItemId" Label="Sản phẩm" Required="true" RequiredError="Vui lòng chọn sản phẩm">
                @foreach (var item in Items)
                {
                    <MudSelectItem T="int?" Value="@item.Id">@item.ProductName (@item.Id)</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_issue" Label="Mô tả vấn đề *"
                          Required="true" RequiredError="Vui lòng nhập mô tả"
                          Lines="3" Class="mt-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">
            Gửi yêu cầu
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public List<OrderItemResponse> Items { get; set; } = new();

    private MudForm _form = null!;
    private bool _isValid;
    private int? _selectedOrderItemId;
    private string _issue = "";

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        try
        {
            // Get selected order item
            var selectedItem = Items.FirstOrDefault(i => i.Id == _selectedOrderItemId);
            if (selectedItem == null)
            {
                Snackbar.Add("Vui lòng chọn sản phẩm", Severity.Error);
                return;
            }

            var request = new CreateWarrantyRequestRequest
            {
                ProductId = selectedItem.ProductId,
                VariantId = selectedItem.VariantId,
                OrderItemId = selectedItem.Id,
                Issue = _issue
            };

            await WarrantyRequestService.CreateAsync(request);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
