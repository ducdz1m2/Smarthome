@page "/profile"
@layout Web.Components.Layout.AccountLayout
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using MudBlazor.Components
@inject IIdentityService IdentityService
@inject ITechnicianProfileService TechnicianService
@inject CurrentUserService CurrentUserService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject LocalAuthStateProvider LocalAuthStateProvider
@inject IProductService ProductService

@* For file upload *@
@using System.Net.Http

<div class="profile-container">
    <MudCard Elevation="3" Class="profile-card">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
            <MudTabPanel Text="Thông tin cá nhân" Icon="@Icons.Material.Filled.Person">
                <MudCardHeader Class="profile-header">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Class="profile-title">Thông tin cá nhân</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="profile-subtitle">Cập nhật thông tin tài khoản của bạn</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isValid">
                        <MudTextField @bind-Value="_editModel.FullName"
                                  Label="Họ và tên"
                                  Required="true"
                                  RequiredError="Vui lòng nhập họ tên"
                                  Variant="Variant.Outlined"
                                  Class="mb-3 profile-field" />

                        <MudTextField @bind-Value="_editModel.Email"
                                  Label="Email"
                                  Required="true"
                                  RequiredError="Vui lòng nhập email"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Class="mb-3 profile-field" />

                        <MudTextField @bind-Value="_editModel.PhoneNumber"
                                  Label="Số điện thoại"
                                  Variant="Variant.Outlined"
                                  Class="mb-3 profile-field" />

                        @* Avatar Upload Section *@
                        <div class="avatar-section">
                            <MudText Typo="Typo.subtitle2" Class="mb-2 section-label">Ảnh đại diện</MudText>

                            @if (!string.IsNullOrEmpty(_editModel.Avatar))
                            {
                                <div class="avatar-preview mb-3">
                                    <MudAvatar Size="Size.Large" Class="profile-avatar">
                                        <MudImage Src="@_editModel.Avatar" Alt="Avatar" ObjectFit="ObjectFit.Cover" />
                                    </MudAvatar>
                                    <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           OnClick="RemoveAvatar"
                                           Size="Size.Small"
                                           Class="remove-avatar-btn"
                                           StartIcon="@Icons.Material.Filled.Delete">
                                        Xóa ảnh
                                    </MudButton>
                                </div>
                            }

                            <MudFileUpload T="IBrowserFile"
                                   FilesChanged="UploadAvatar"
                                   Accept=".jpg,.jpeg,.png,.gif,.webp"
                                   Class="upload-section">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload"
                                       Disabled="_isUploading"
                                       Size="Size.Medium"
                                       Class="upload-btn">
                                        @if (_isUploading)
                                        {
                                            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
                                            <span>Đang upload...</span>
                                        }
                                        else
                                        {
                                            <span>Tải ảnh lên</span>
                                        }
                                    </MudButton>
                                </ActivatorContent>
                                <FileContent>
                                    @if (!string.IsNullOrEmpty(_editModel.Avatar))
                                    {
                                        <MudImage Src="@_editModel.Avatar" Alt="Avatar" ObjectFit="ObjectFit.Cover" Style="max-width: 200px; max-height: 200px;" />
                                    }
                                </FileContent>
                            </MudFileUpload>

                            @if (_isUploading)
                            {
                                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-2" />
                            }
                        </div>
                    </MudForm>
                </MudCardContent>
                <MudCardActions Class="justify-end profile-actions">
                    <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveProfile"
                           Disabled="!_isValid || _isSaving"
                           StartIcon="@Icons.Material.Filled.Save"
                           Class="save-btn">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
                            <span>Đang lưu...</span>
                        }
                        else
                        {
                            <span>Lưu thay đổi</span>
                        }
                    </MudButton>
                </MudCardActions>
            </MudTabPanel>

            <MudTabPanel Text="Danh sách yêu thích" Icon="@Icons.Material.Filled.Favorite">
                <MudCardHeader Class="profile-header">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Class="profile-title">Danh sách yêu thích</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="profile-subtitle">Sản phẩm bạn đã lưu</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_loadingWishlist)
                    {
                        <MudProgressLinear Indeterminate="true" Class="my-4" />
                    }
                    else if (_wishlistProducts.Any())
                    {
                        <MudGrid>
                            @foreach (var product in _wishlistProducts)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudCard Elevation="2" Class="h-100">
                                        <div class="wishlist-product-image-container">
                                            @if (!string.IsNullOrEmpty(product.MainImageUrl))
                                            {
                                                <img src="@product.MainImageUrl" alt="@product.Name" class="wishlist-product-image" />
                                            }
                                            else
                                            {
                                                <div class="no-image-placeholder">
                                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Color="Color.Secondary"/>
                                                </div>
                                            }
                                        </div>
                                        <MudCardContent Class="pa-3">
                                            <MudText Typo="Typo.subtitle1" Class="fw-bold text-truncate" title="@product.Name">@product.Name</MudText>
                                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold mt-1">
                                                @FormatPrice(product.MinPrice)
                                            </MudText>
                                        </MudCardContent>
                                        <MudCardActions Class="justify-space-between pa-2">
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                       OnClick="() => NavigateToProduct(product.Id)">
                                                Xem chi tiết
                                            </MudButton>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                           OnClick="() => RemoveFromWishlist(product.Id)"
                                                           Title="Xóa khỏi danh sách yêu thích" />
                                        </MudCardActions>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                    else
                    {
                        <MudPaper Elevation="0" Class="pa-8 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Size="Size.Large" Color="Color.Secondary" Class="mb-4"/>
                            <MudText Typo="Typo.h6" Class="mb-2">Chưa có sản phẩm yêu thích</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                                Hãy thêm sản phẩm vào danh sách yêu thích để không bỏ lỡ!
                            </MudText>
                            <MudButton Href="/products" Variant="Variant.Filled" Color="Color.Primary">
                                Khám phá sản phẩm
                            </MudButton>
                        </MudPaper>
                    }
                </MudCardContent>
            </MudTabPanel>
        </MudTabs>
    </MudCard>
</div>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _isSaving;
    private UserResponse? _user;
    private EditModel _editModel = new();
    private List<ProductListResponse> _wishlistProducts = new();
    private bool _loadingWishlist = true;

    public class EditModel
    {
        public int Id { get; set; }
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string? PhoneNumber { get; set; }
        public string? Avatar { get; set; }
    }

    private bool _isUploading = false;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"[Profile] OnInitializedAsync called");

        // Get authentication state first to ensure CurrentUserService is populated
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        Console.WriteLine($"[Profile] AuthState - IsAuthenticated: {user.Identity?.IsAuthenticated}");
        Console.WriteLine($"[Profile] AuthState - UserName: {user.Identity?.Name}");

        // Wait a moment to ensure CurrentUserService is populated
        await Task.Delay(100);

        // Now load the profile
        await LoadUserProfile();
        await LoadWishlist();
    }

    private async Task LoadUserProfile()
    {
        try
        {
            // Get current authenticated user from CurrentUserService
            Console.WriteLine($"[Profile] IsAuthenticated: {CurrentUserService.IsAuthenticated}");
            Console.WriteLine($"[Profile] UserId: {CurrentUserService.UserId}");
            Console.WriteLine($"[Profile] UserName: {CurrentUserService.UserName}");
            Console.WriteLine($"[Profile] Roles: {string.Join(", ", CurrentUserService.Roles)}");

            if (!CurrentUserService.IsAuthenticated || !CurrentUserService.UserId.HasValue)
            {
                Console.WriteLine($"[Profile] User not authenticated or no UserId");
                Snackbar.Add("Không tìm thấy thông tin người dùng", Severity.Error);
                return;
            }

            var userId = CurrentUserService.UserId.Value;
            var roles = CurrentUserService.Roles;
            Console.WriteLine($"[Profile] UserId: {userId}");
            Console.WriteLine($"[Profile] Roles: {string.Join(", ", roles)}");

            // Check if user is technician
            if (roles.Contains("Technician"))
            {
                // Load technician profile
                Console.WriteLine($"[Profile] Loading technician profile for userId: {userId}");
                var technician = await TechnicianService.GetByUserIdAsync(userId);
                Console.WriteLine($"[Profile] Technician found: {technician != null}");

                if (technician != null)
                {
                    _editModel = new EditModel
                    {
                        Id = technician.Id,
                        FullName = technician.FullName,
                        Email = technician.Email ?? "",
                        PhoneNumber = technician.PhoneNumber,
                        Avatar = null // Technician doesn't have avatar
                    };
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    Snackbar.Add("Không tìm thấy thông tin kỹ thuật viên", Severity.Error);
                }
            }
            else
            {
                // Load regular user profile (customer or admin)
                Console.WriteLine($"[Profile] Loading user profile for userId: {userId}");
                _user = await IdentityService.GetUserByIdAsync(userId);
                Console.WriteLine($"[Profile] User found: {_user != null}");

                if (_user != null)
                {
                    _editModel = new EditModel
                    {
                        Id = _user.Id,
                        FullName = _user.FullName,
                        Email = _user.Email,
                        PhoneNumber = _user.PhoneNumber,
                        Avatar = _user.Avatar
                    };
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    Snackbar.Add("Không tìm thấy thông tin người dùng", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Profile] Error: {ex.Message}");
            Snackbar.Add($"Lỗi khi tải thông tin: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveProfile()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _isSaving = true;
        try
        {
            var request = new Application.DTOs.Requests.UpdateUserRequest
            {
                Id = _editModel.Id,
                FullName = _editModel.FullName,
                Email = _editModel.Email,
                PhoneNumber = _editModel.PhoneNumber,
                Avatar = _editModel.Avatar,
                IsActive = true,
                Roles = _user?.Roles ?? new List<string>()
            };

            var result = await IdentityService.UpdateUserAsync(request);
            if (result.Succeeded)
            {
                // Save avatar to localStorage for navbar/sidebar
                if (!string.IsNullOrEmpty(_editModel.Avatar))
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "userAvatar", _editModel.Avatar);
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "userAvatar");
                }
                Snackbar.Add("Cập nhật thông tin thành công!", Severity.Success);
                await LoadUserProfile();
            }
            else
            {
                Snackbar.Add($"Lỗi: {string.Join(", ", result.Errors.Select(e => e.Description))}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UploadAvatar(IBrowserFile file)
    {
        _isUploading = true;
        try
        {
            var httpClient = new HttpClient { BaseAddress = new Uri(NavigationManager.BaseUri) };
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024)); // Max 2MB for avatar
            content.Add(fileContent, "file", file.Name);

            var response = await httpClient.PostAsync("api/upload/temp", content);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                if (result != null)
                {
                    _editModel.Avatar = result.url;
                    // Save to localStorage for navbar/sidebar
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "userAvatar", result.url);
                    Snackbar.Add("Upload ảnh thành công!", Severity.Success);
                }
            }
            else
            {
                Snackbar.Add("Upload ảnh thất bại!", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi upload: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task RemoveAvatar()
    {
        _editModel.Avatar = null;
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "userAvatar");
        Snackbar.Add("Đã xóa ảnh đại diện", Severity.Info);
    }

    private async Task LoadWishlist()
    {
        try
        {
            _loadingWishlist = true;
            var wishlistJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "wishlist");
            if (!string.IsNullOrEmpty(wishlistJson))
            {
                var wishlistIds = System.Text.Json.JsonSerializer.Deserialize<List<int>>(wishlistJson);
                if (wishlistIds != null && wishlistIds.Any())
                {
                    var allProducts = await ProductService.GetAllAsync();
                    _wishlistProducts = allProducts.Where(p => wishlistIds.Contains(p.Id)).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading wishlist: {ex.Message}");
        }
        finally
        {
            _loadingWishlist = false;
        }
    }

    private async Task RemoveFromWishlist(int productId)
    {
        try
        {
            var wishlistJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "wishlist");
            var wishlist = string.IsNullOrEmpty(wishlistJson)
                ? new List<int>()
                : System.Text.Json.JsonSerializer.Deserialize<List<int>>(wishlistJson) ?? new List<int>();

            if (wishlist.Contains(productId))
            {
                wishlist.Remove(productId);
                await JSRuntime.InvokeVoidAsync("localStorage.setItem", "wishlist",
                    System.Text.Json.JsonSerializer.Serialize(wishlist));
                Snackbar.Add("Đã xóa khỏi danh sách yêu thích", Severity.Success);
                await LoadWishlist();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private void NavigateToProduct(int productId)
    {
        NavigationManager.NavigateTo($"/products/{productId}");
    }

    private string FormatPrice(decimal price)
    {
        return $"{price:N0} ₫";
    }

    private class UploadResult
    {
        public string url { get; set; } = "";
    }
}
