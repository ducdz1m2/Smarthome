@page "/orders"
@layout Web.Components.Layout.AccountLayout
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Web.Helpers
@using Web.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject IOrderService OrderService
@inject IReturnOrderService ReturnOrderService
@inject IWarrantyRequestService WarrantyRequestService
@inject IAuthService AuthService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudText Typo="Typo.h5" Class="mb-4">Đơn hàng của tôi</MudText>

    @if (_isLoading)
    {
        <MudGrid>
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12">
                    <MudCard Elevation="2" Class="mb-3">
                        <MudCardContent>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="30%" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="50%" Class="mt-2" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" Class="mt-2" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (!_orders.Any())
    {
        <MudPaper Elevation="0" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-2">Chưa có đơn hàng</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                Bạn chưa có đơn hàng nào. Hãy mua sắm ngay!
            </MudText>
            <MudButton Href="/products" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ShoppingCart">
                Mua sắm ngay
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @foreach (var order in _pagedOrders)
            {
                <MudItem xs="12">
                    <MudCard Elevation="2" Class="mb-3 cursor-pointer" @onclick="() => OpenOrderDetail(order)">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div class="d-flex align-center justify-space-between">
                                    <div>
                                        <MudText Typo="Typo.subtitle1" Class="fw-bold">
                                            Đơn hàng #@order.OrderNumber
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </MudText>
                                    </div>
                                    <MudChip T="string" Color="@GetStatusColor(order.Status, _returnOrders.ContainsKey(order.Id) ? _returnOrders[order.Id] : null, _warrantyRequests.ContainsKey(order.Id) ? _warrantyRequests[order.Id] : null)" Size="Size.Small">
                                        @GetStatusText(order.Status, _returnOrders.ContainsKey(order.Id) ? _returnOrders[order.Id] : null, _warrantyRequests.ContainsKey(order.Id) ? _warrantyRequests[order.Id] : null)
                                    </MudChip>
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" md="8">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @order.Items.Count sản phẩm
                                    </MudText>
                                    @foreach (var item in order.Items.Take(2))
                                    {
                                        <MudText Typo="Typo.body2" Class="text-truncate">
                                            @item.ProductName
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <span> (@item.VariantName)</span>
                                            }
                                            x @item.Quantity
                                        </MudText>
                                    }
                                    @if (order.Items.Count > 2)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            +@(order.Items.Count - 2) sản phẩm khác
                                        </MudText>
                                    }
                                </MudItem>
                                <MudItem xs="12" md="4" class="text-right">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Tổng tiền</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold">
                                        @FormatPrice(order.TotalAmount)
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions Class="justify-end">
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       EndIcon="@Icons.Material.Filled.ChevronRight"
                                       OnClick="() => OpenOrderDetail(order)">
                                Xem chi tiết
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        @if (_totalPages > 1)
        {
            <div class="d-flex justify-center align-center mt-4 gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Disabled="@(_currentPageValue == 1)"
                           OnClick="() => ChangePage(_currentPageValue - 1)">
                    Trang trước
                </MudButton>
                <MudText Typo="Typo.body2" Class="mx-2">
                    Trang @_currentPageValue / @_totalPages
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Disabled="@(_currentPageValue == _totalPages)"
                           OnClick="() => ChangePage(_currentPageValue + 1)">
                    Trang sau
                </MudButton>
            </div>
        }
    }

<style>
    .cursor-pointer {
        cursor: pointer;
    }
    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .fw-bold {
        font-weight: 600;
    }
</style>

@code {
    private MudForm _form = null!;
    private bool _isLoading = true;
    private List<OrderResponse> _orders = new();
    private List<OrderResponse> _pagedOrders = new();
    private Dictionary<int, ReturnOrderResponse?> _returnOrders = new();
    private Dictionary<int, WarrantyRequestResponse?> _warrantyRequests = new();
    private int? _currentUserId;
    private int _currentPageValue = 1;
    private int _pageSize = 10;
    private int _totalPages => (int)Math.Ceiling(_orders.Count / (double)_pageSize);

    protected override async Task OnInitializedAsync()
    {
        // Wait for auth state to be ready
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        Console.WriteLine($"[Orders.OnInitializedAsync] User.Identity?.IsAuthenticated: {user.Identity?.IsAuthenticated}");
        Console.WriteLine($"[Orders.OnInitializedAsync] User.Identity?.Name: {user.Identity?.Name}");

        await LoadCurrentUserId();
        await LoadOrdersAsync();
    }

    private async Task LoadCurrentUserId()
    {
        var userIdStr = await AuthService.GetUserIdAsync();
        Console.WriteLine($"[Orders.LoadCurrentUserId] userIdStr: '{userIdStr}'");
        if (int.TryParse(userIdStr, out var userId))
        {
            _currentUserId = userId;
            Console.WriteLine($"[Orders.LoadCurrentUserId] _currentUserId: {_currentUserId}");
        }
        else
        {
            Console.WriteLine($"[Orders.LoadCurrentUserId] Failed to parse userIdStr");
        }
    }

    private async Task LoadOrdersAsync()
    {
        if (!_currentUserId.HasValue)
        {
            Snackbar.Add("Không tìm thấy thông tin người dùng", Severity.Error);
            return;
        }

        _isLoading = true;
        try
        {
            var allOrders = await OrderService.GetByUserIdAsync(_currentUserId.Value);
            _orders = allOrders.OrderByDescending(o => o.CreatedAt).ToList();

            // Load all return orders at once to prevent DbContext concurrency
            var allReturnOrders = await ReturnOrderService.GetAllAsync();
            var returnOrdersByOrderId = allReturnOrders
                .GroupBy(r => r.OrderId)
                .ToDictionary(g => g.Key, g => g.ToList());

            // Load all warranty requests at once to prevent DbContext concurrency
            var allWarrantyRequests = await WarrantyRequestService.GetAllAsync();
            var warrantyRequestsByOrderId = allWarrantyRequests
                .GroupBy(w => w.OrderId)
                .ToDictionary(g => g.Key, g => g.ToList());

            // Map return orders and warranty requests to orders
            foreach (var order in _orders)
            {
                if (returnOrdersByOrderId.TryGetValue(order.Id, out var returnOrders))
                {
                    // Get the most recent return order (not rejected if possible)
                    var nonRejected = returnOrders.FirstOrDefault(r => r.Status != "Rejected");
                    _returnOrders[order.Id] = nonRejected ?? returnOrders.OrderByDescending(r => r.CreatedAt).FirstOrDefault();
                }

                if (warrantyRequestsByOrderId.TryGetValue(order.Id, out var warrantyRequests))
                {
                    // Get the most recent warranty request (not rejected if possible)
                    var nonRejectedWarranty = warrantyRequests.FirstOrDefault(w => w.Status != "Rejected");
                    _warrantyRequests[order.Id] = nonRejectedWarranty ?? warrantyRequests.OrderByDescending(w => w.CreatedAt).FirstOrDefault();
                }
            }

            UpdatePagedItems();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải đơn hàng: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UpdatePagedItems()
    {
        var skip = (_currentPageValue - 1) * _pageSize;
        _pagedOrders = _orders.Skip(skip).Take(_pageSize).ToList();

        // Adjust current page if it's beyond total pages
        if (_currentPageValue > _totalPages && _totalPages > 0)
        {
            _currentPageValue = _totalPages;
            UpdatePagedItems();
        }
    }

    private void ChangePage(int page)
    {
        _currentPageValue = page;
        UpdatePagedItems();
    }

    private async Task OpenOrderDetail(OrderResponse order)
    {
        var parameters = new DialogParameters<OrderDetailDialog>();
        parameters.Add(x => x.OrderId, order.Id);

        var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true
            };

        var dialog = await DialogService.ShowAsync<OrderDetailDialog>("Chi tiết đơn hàng", parameters, options);
        await dialog.Result;
    }

    private static Color GetStatusColor(string orderStatus, ReturnOrderResponse? returnOrder, WarrantyRequestResponse? warrantyRequest)
    {
        // If there's an active warranty request, show warranty status color
        if (warrantyRequest != null && warrantyRequest.Status != "Completed")
        {
            return StatusHelper.GetWarrantyStatusColor(warrantyRequest.Status);
        }

        // If there's an active return order, show return status color
        if (returnOrder != null)
        {
            return StatusHelper.GetReturnOrderStatusColor(returnOrder.Status);
        }

        return StatusHelper.GetOrderStatusColor(orderStatus);
    }

    private static string GetStatusText(string orderStatus, ReturnOrderResponse? returnOrder, WarrantyRequestResponse? warrantyRequest)
    {
        // If there's an active warranty request, show warranty status text
        if (warrantyRequest != null && warrantyRequest.Status != "Completed")
        {
            return StatusHelper.GetWarrantyStatusText(warrantyRequest.Status);
        }

        // If there's an active return order, show return status text
        if (returnOrder != null)
        {
            return StatusHelper.GetReturnOrderStatusText(returnOrder.Status);
        }

        return StatusHelper.GetOrderStatusText(orderStatus);
    }

    private string FormatPrice(decimal price)
    {
        return $"{price:N0} ₫";
    }
}
