@page "/orders"
@layout Web.Components.Layout.AccountLayout
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums

@inject IOrderService OrderService
@inject IReturnOrderService ReturnOrderService
@inject IWarrantyRequestService WarrantyRequestService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<MudText Typo="Typo.h5" Class="mb-4">Đơn hàng của tôi</MudText>

    @if (_isLoading)
    {
        <MudGrid>
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12">
                    <MudCard Elevation="2" Class="mb-3">
                        <MudCardContent>
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="30%" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="50%" Class="mt-2" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" Class="mt-2" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (!_orders.Any())
    {
        <MudPaper Elevation="0" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-2">Chưa có đơn hàng</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                Bạn chưa có đơn hàng nào. Hãy mua sắm ngay!
            </MudText>
            <MudButton Href="/products" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ShoppingCart">
                Mua sắm ngay
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @foreach (var order in _orders.OrderByDescending(o => o.CreatedAt))
            {
                <MudItem xs="12">
                    <MudCard Elevation="2" Class="mb-3 cursor-pointer" @onclick="() => OpenOrderDetail(order)">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div class="d-flex align-center justify-space-between">
                                    <div>
                                        <MudText Typo="Typo.subtitle1" Class="fw-bold">
                                            Đơn hàng #@order.OrderNumber
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </MudText>
                                    </div>
                                    <MudChip T="string" Color="@GetStatusColor(order.Status, _returnOrders.ContainsKey(order.Id) ? _returnOrders[order.Id] : null, _warrantyRequests.ContainsKey(order.Id) ? _warrantyRequests[order.Id] : null)" Size="Size.Small">
                                        @GetStatusText(order.Status, _returnOrders.ContainsKey(order.Id) ? _returnOrders[order.Id] : null, _warrantyRequests.ContainsKey(order.Id) ? _warrantyRequests[order.Id] : null)
                                    </MudChip>
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" md="8">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @order.Items.Count sản phẩm
                                    </MudText>
                                    @foreach (var item in order.Items.Take(2))
                                    {
                                        <MudText Typo="Typo.body2" Class="text-truncate">
                                            @item.ProductName
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <span> (@item.VariantName)</span>
                                            }
                                            x @item.Quantity
                                        </MudText>
                                    }
                                    @if (order.Items.Count > 2)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            +@(order.Items.Count - 2) sản phẩm khác
                                        </MudText>
                                    }
                                </MudItem>
                                <MudItem xs="12" md="4" class="text-right">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Tổng tiền</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold">
                                        @FormatPrice(order.TotalAmount)
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                        <MudCardActions Class="justify-end">
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       EndIcon="@Icons.Material.Filled.ChevronRight"
                                       OnClick="() => OpenOrderDetail(order)">
                                Xem chi tiết
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

<style>
    .cursor-pointer {
        cursor: pointer;
    }
    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .fw-bold {
        font-weight: 600;
    }
</style>

@code {
    private List<OrderResponse> _orders = new();
    private bool _isLoading = true;
    private Dictionary<int, ReturnOrderResponse?> _returnOrders = new();
    private Dictionary<int, WarrantyRequestResponse?> _warrantyRequests = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadOrdersAsync();
        }
    }

    private async Task LoadOrdersAsync()
    {
        _isLoading = true;
        try
        {
            // TODO: Get current user ID from auth service
            // For now, get all orders (should filter by current user)
            var allOrders = await OrderService.GetAllAsync();
            _orders = allOrders;

            // Load return orders for each order
            foreach (var order in _orders)
            {
                var returnOrders = await ReturnOrderService.GetByOrderIdAsync(order.Id);
                // Get the most recent return order (not rejected if possible)
                var nonRejected = returnOrders.FirstOrDefault(r => r.Status != "Rejected");
                _returnOrders[order.Id] = nonRejected ?? returnOrders.OrderByDescending(r => r.CreatedAt).FirstOrDefault();

                // Small delay to prevent DbContext threading issues
                await Task.Delay(10);

                // Load warranty requests for each order
                var warrantyRequests = await WarrantyRequestService.GetByOrderIdAsync(order.Id);
                // Get the most recent warranty request (not rejected if possible)
                var nonRejectedWarranty = warrantyRequests.FirstOrDefault(w => w.Status != "Rejected");
                _warrantyRequests[order.Id] = nonRejectedWarranty ?? warrantyRequests.OrderByDescending(w => w.CreatedAt).FirstOrDefault();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải đơn hàng: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenOrderDetail(OrderResponse order)
    {
        var parameters = new DialogParameters<OrderDetailDialog>();
        parameters.Add(x => x.OrderId, order.Id);

        var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true
            };

        var dialog = await DialogService.ShowAsync<OrderDetailDialog>("Chi tiết đơn hàng", parameters, options);
        await dialog.Result;
    }

    private static Color GetStatusColor(string orderStatus, ReturnOrderResponse? returnOrder, WarrantyRequestResponse? warrantyRequest)
    {
        // If there's an active warranty request, show warranty status color
        if (warrantyRequest != null && warrantyRequest.Status != "Completed")
        {
            return warrantyRequest.Status switch
            {
                "Pending" => Color.Warning,
                "Approved" => Color.Success,
                "Rejected" => Color.Error,
                "InProgress" => Color.Info,
                "Completed" => Color.Primary,
                _ => Color.Default
            };
        }

        // If there's an active return order, show return status color
        if (returnOrder != null)
        {
            return returnOrder.Status switch
            {
                "Pending" => Color.Warning,
                "Approved" => Color.Info,
                "Received" => Color.Primary,
                "Completed" => Color.Success,
                "Rejected" => Color.Error,
                _ => Color.Default
            };
        }

        return orderStatus switch
        {
            "Pending" => Color.Warning,
            "Confirmed" => Color.Info,
            "AwaitingPickup" => Color.Info,
            "Shipping" => Color.Primary,
            "Shipped" => Color.Primary,
            "Delivered" => Color.Success,
            "AwaitingSchedule" => Color.Info,
            "Scheduled" => Color.Secondary,
            "TechnicianAssigned" => Color.Tertiary,
            "Preparing" => Color.Primary,
            "Installing" => Color.Primary,
            "Testing" => Color.Info,
            "Completed" => Color.Success,
            "Cancelled" => Color.Error,
            "Refunded" => Color.Warning,
            "ReturnRequested" => Color.Warning,
            _ => Color.Default
        };
    }

    private static string GetStatusText(string orderStatus, ReturnOrderResponse? returnOrder, WarrantyRequestResponse? warrantyRequest)
    {
        // If there's an active warranty request, show warranty status text
        if (warrantyRequest != null && warrantyRequest.Status != "Completed")
        {
            return warrantyRequest.Status switch
            {
                "Pending" => "Yêu cầu bảo hành",
                "Approved" => "Đã duyệt bảo hành",
                "Rejected" => "Đã từ chối bảo hành",
                "InProgress" => "Đang bảo hành",
                "Completed" => "Bảo hành hoàn thành",
                _ => warrantyRequest.Status
            };
        }

        // If there's an active return order, show return status text
        if (returnOrder != null)
        {
            return returnOrder.Status switch
            {
                "Pending" => "Yêu cầu hoàn hàng",
                "Approved" => "Đã duyệt hoàn hàng",
                "Received" => "Đã nhận hàng hoàn",
                "Completed" => "Đã hoàn thành hoàn hàng",
                "Rejected" => "Đã từ chối hoàn hàng",
                _ => returnOrder.Status
            };
        }

        return orderStatus switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "AwaitingPickup" => "Chờ lấy hàng",
            "Shipping" => "Đang giao",
            "Delivered" => "Đã giao",
            "AwaitingSchedule" => "Chờ lịch",
            "Scheduled" => "Đã đặt lịch",
            "TechnicianAssigned" => "Đã giao kỹ thuật",
            "Preparing" => "Đang chuẩn bị",
            "Installing" => "Đang lắp đặt",
            "Testing" => "Đang kiểm tra",
            "Completed" => "Hoàn thành",
            "Cancelled" => "Đã hủy",
            "Refunded" => "Đã hoàn tiền",
            "ReturnRequested" => "Yêu cầu trả hàng",
            "Shipped" => "Đang giao", // Legacy support
            _ => orderStatus
        };
    }

    private string FormatPrice(decimal price)
    {
        return $"{price:N0} ₫";
    }
}
