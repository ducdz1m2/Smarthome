@page "/checkout"
@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Services
@using Domain.Entities.Installation
@using Web.Services

@inject Application.Interfaces.Services.IOrderService OrderService
@inject IUserAddressService UserAddressService
@inject IInstallationSlotService InstallationSlotService
@inject ITechnicianProfileService TechnicianProfileService
@inject Domain.Services.IShippingService ShippingService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject CurrentUserService CurrentUserService
@inject IVNPayService VNPayService
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Thanh toán</MudText>

    @if (_isLoading)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" Animation="Animation.Wave" />
    }
    else if (!_cartItems.Any())
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Giỏ hàng trống. Vui lòng thêm sản phẩm trước khi thanh toán.
        </MudAlert>
        <MudButton Href="/products" Variant="Variant.Filled" Color="Color.Primary">
            Tiếp tục mua sắm
        </MudButton>
    }
    else
    {
        <MudGrid>
            <!-- Shipping Information -->
            <MudItem xs="12" md="7">
                <!-- Saved Addresses -->
                @if (_userAddresses.Any())
                {
                    <MudCard Elevation="2" Class="mb-4">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Địa chỉ đã lưu</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudRadioGroup T="int" @bind-Value="_selectedAddressId" SelectedChanged="OnAddressSelected">
                                @foreach (var address in _userAddresses)
                                {
                                    <MudRadio Value="@address.Id" Class="mb-2">
                                        <MudCard Elevation="0" Outlined="true" Class="w-100">
                                            <MudCardContent Class="pa-3">
                                                <div class="d-flex justify-space-between align-center">
                                                    <div>
                                                        <MudText Typo="Typo.subtitle2" Class="fw-bold">@address.Label</MudText>
                                                        @if (address.IsDefault)
                                                        {
                                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="ml-2">Mặc định</MudChip>
                                                        }
                                                    </div>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@address.ReceiverName - @address.ReceiverPhone</MudText>
                                                </div>
                                                <MudText Typo="Typo.body2" Class="mt-1">@address.FullAddress</MudText>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudRadio>
                                }
                            </MudRadioGroup>
                        </MudCardContent>
                    </MudCard>
                }

                <MudCard Elevation="2" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Thông tin giao hàng</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudForm @ref="_form" @bind-IsValid="_isValid">
                            <MudTextField @bind-Value="_request.ReceiverName" 
                                         Label="Họ và tên người nhận *" 
                                         Required="true"
                                         RequiredError="Vui lòng nhập họ tên"
                                         Variant="Variant.Outlined" 
                                         Class="mb-3" />
                            
                            <MudTextField @bind-Value="_request.ReceiverPhone" 
                                         Label="Số điện thoại *" 
                                         Required="true"
                                         RequiredError="Vui lòng nhập số điện thoại"
                                         Variant="Variant.Outlined" 
                                         Class="mb-3" />
                            
                            <MudTextField @bind-Value="_request.ShippingStreet" 
                                         Label="Địa chỉ (số nhà, đường) *" 
                                         Required="true"
                                         RequiredError="Vui lòng nhập địa chỉ"
                                         Variant="Variant.Outlined" 
                                         Class="mb-3" />
                            
                            <MudGrid>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_request.ShippingWard" 
                                                 Label="Phường/Xã *" 
                                                 Required="true"
                                                 RequiredError="Nhập phường/xã"
                                                 Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_request.ShippingDistrict" 
                                                 Label="Quận/Huyện *" 
                                                 Required="true"
                                                 RequiredError="Nhập quận/huyện"
                                                 Variant="Variant.Outlined"
                                                 OnBlur="OnDistrictChanged" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="_request.ShippingCity" 
                                                 Label="Tỉnh/Thành phố *" 
                                                 Required="true"
                                                 RequiredError="Nhập tỉnh/thành"
                                                 Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                    </MudCardContent>
                </MudCard>

                <!-- Payment Method -->
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Phương thức thanh toán</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudRadioGroup @bind-Value="_paymentMethod" T="string">
                            <MudRadio Value="@("COD")" Class="mb-2">
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" />
                                    <div>
                                        <MudText Typo="Typo.body1" Class="fw-bold">Thanh toán khi nhận hàng (COD)</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Thanh toán bằng tiền mặt khi nhận hàng</MudText>
                                    </div>
                                </div>
                            </MudRadio>
                            
                            <MudDivider Class="my-2" />

                            <MudRadio Value="@("VNPAY")">
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.CreditCard" Color="Color.Primary" />
                                    <div>
                                        <MudText Typo="Typo.body1" Class="fw-bold">Thanh toán VNPAY</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Thanh toán qua cổng thanh toán VNPAY</MudText>
                                    </div>
                                </div>
                            </MudRadio>
                        </MudRadioGroup>
                    </MudCardContent>
                </MudCard>

                <!-- Installation Scheduling -->
                @if (_requiresInstallation)
                {
                    <MudCard Elevation="2" Class="mt-4 installation-card">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Lịch lắp đặt</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Error">* Bắt buộc</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudDatePicker Label="Ngày lắp đặt *"
                                                   @bind-Date="_request.InstallationDate"
                                                   @bind-Date:after="OnInstallationDateChanged"
                                                   Required="true"
                                                   RequiredError="Vui lòng chọn ngày lắp đặt"
                                                   Variant="Variant.Outlined"
                                                   MinDate="@DateTime.Today"
                                                   MaxDate="@DateTime.Today.AddDays(30)"
                                                   DisableUnderlined="true" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="int?" Label="Khung giờ *"
                                               @bind-Value="_request.InstallationSlotId"
                                               @bind-Value:after="OnInstallationSlotChanged"
                                               Required="true"
                                               RequiredError="Vui lòng chọn khung giờ lắp đặt"
                                               Variant="Variant.Outlined"
                                               DisableUnderlined="true">
                                        @if (!_installationSlots.Any())
                                        {
                                            <MudSelectItem T="int?" Value="@null">
                                                Không có khung giờ khả dụng
                                            </MudSelectItem>
                                        }
                                        else
                                        {
                                            @foreach (var slot in _installationSlots.Where(s => !s.IsBooked))
                                            {
                                                <MudSelectItem T="int?" Value="@slot.Id">
                                                    @slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")
                                                </MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                            @if (!_isInstallationValid)
                            {
                                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">
                                    Vui lòng chọn ngày và khung giờ lắp đặt trước khi đặt hàng
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                }
            </MudItem>

            <!-- Order Summary -->
            <MudItem xs="12" md="5">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Đơn hàng của bạn</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @foreach (var item in _cartItems)
                        {
                            <div class="d-flex justify-space-between align-center mb-2">
                                <div>
                                    <MudText Typo="Typo.body2" Class="fw-bold">@item.ProductName</MudText>
                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@item.VariantName</MudText>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">x @item.Quantity</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Class="fw-bold">
                                    @FormatPrice(item.TotalPrice)
                                </MudText>
                            </div>
                        }
                        
                        <MudDivider Class="my-4" />
                        
                        <div class="d-flex justify-space-between mb-2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tạm tính</MudText>
                            <MudText Typo="Typo.body2">@FormatPrice(_subTotal)</MudText>
                        </div>
                        <div class="d-flex justify-space-between mb-2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Phí vận chuyển</MudText>
                            <MudText Typo="Typo.body2">
                                @if (_shippingFee == 0)
                                {
                                    <span class="text-success">Miễn phí</span>
                                }
                                else
                                {
                                    @FormatPrice(_shippingFee)
                                }
                            </MudText>
                        </div>
                        <MudDivider Class="my-4" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.h6" Class="fw-bold">Tổng cộng</MudText>
                            <MudText Typo="Typo.h5" Color="Color.Primary" Class="fw-bold">
                                @FormatPrice(_total)
                            </MudText>
                        </div>
                    </MudCardContent>
                    <MudCardActions Class="flex-column">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.ShoppingBag"
                                   OnClick="PlaceOrder"
                                   Disabled="@(!_isValid || _isPlacingOrder || (_requiresInstallation && !_isInstallationValid))">
                            @if (_isPlacingOrder)
                            {
                                <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
                                <span>Đang xử lý...</span>
                            }
                            else
                            {
                                <span>Đặt hàng</span>
                            }
                        </MudButton>
                        <MudButton Variant="Variant.Text" 
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   Href="/cart"
                                   Class="mt-2">
                            Quay lại giỏ hàng
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

<style>
    .fw-bold {
        font-weight: 600;
    }
    .text-success {
        color: var(--mud-palette-success);
    }
</style>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _isLoading = true;
    private bool _isPlacingOrder = false;
    private string _paymentMethod = "COD";
    private bool _isInstallationValid = true;

    private List<CartItem> _cartItems = new();
    private List<UserAddressResponse> _userAddresses = new();
    private List<InstallationSlotResponse> _installationSlots = new();
    private int _selectedAddressId = 0;
    private int _currentUserId = 0;

    private CreateOrderRequest _request = new()
    {
        ReceiverName = "",
        ReceiverPhone = "",
        ShippingStreet = "",
        ShippingWard = "",
        ShippingDistrict = "",
        ShippingCity = "",
        Items = new()
    };

    public class CartItem
    {
        public int Id { get; set; }
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int? VariantId { get; set; }
        public string? VariantName { get; set; }
        public string? VariantSku { get; set; }
        public string? ImageUrl { get; set; }
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
        public decimal Weight { get; set; } // Weight in kg
        public bool RequiresInstallation { get; set; }
        public decimal TotalPrice => UnitPrice * Quantity;
    }

    private decimal _totalWeight => _cartItems.Sum(i => i.Weight * i.Quantity);
    private decimal _subTotal => _cartItems.Sum(i => i.TotalPrice);
    private bool _requiresInstallation => _cartItems.Any(i => i.RequiresInstallation);
    private decimal _shippingFee;
    private decimal _total => _subTotal + _shippingFee;

    protected override async Task OnInitializedAsync()
    {
        await LoadCartAsync();
        await LoadUserAddressesAsync();
        await LoadInstallationSlotsAsync();
        await CalculateShippingFeeAsync();
        ValidateInstallation();
    }

    private async Task LoadInstallationSlotsAsync()
    {
        if (!_requiresInstallation)
            return;

        try
        {
            var targetDate = _request.InstallationDate ?? DateTime.Today;

            // Get technicians by district
            var technicians = await TechnicianProfileService.GetByDistrictAsync(_request.ShippingDistrict);

            // Fallback to city if no technician found for the district
            if (!technicians.Any())
            {
                technicians = await TechnicianProfileService.GetByCityAsync(_request.ShippingCity);
            }

            if (!technicians.Any())
            {
                _installationSlots = new List<InstallationSlotResponse>();
                Snackbar.Add($"Không tìm thấy kỹ thuật viên cho khu vực {_request.ShippingDistrict} hoặc thành phố {_request.ShippingCity}", Severity.Warning);
                return;
            }

            Console.WriteLine($"[LoadInstallationSlotsAsync] Found {technicians.Count} technicians for {_request.ShippingDistrict}/{_request.ShippingCity}");

            // Load slots from ALL technicians in the area
            var allSlots = new List<InstallationSlotResponse>();
            foreach (var technician in technicians)
            {
                var slots = await InstallationSlotService.GetAvailableSlotsAsync(technician.Id, targetDate);
                Console.WriteLine($"[LoadInstallationSlotsAsync] Technician {technician.Id} ({technician.FullName}) has {slots.Count} slots for {targetDate:dd/MM/yyyy}");
                allSlots.AddRange(slots);
            }

            // Sort slots by time
            _installationSlots = allSlots.OrderBy(s => s.StartTime).ToList();

            Console.WriteLine($"[LoadInstallationSlotsAsync] Total slots loaded: {_installationSlots.Count}");

            if (!_installationSlots.Any())
            {
                Snackbar.Add($"Không có khung giờ khả dụng cho ngày {targetDate:dd/MM/yyyy}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadInstallationSlotsAsync] Error: {ex.Message}");
            _installationSlots = new List<InstallationSlotResponse>();
        }
    }

    private async Task OnInstallationDateChanged()
    {
        _request.InstallationSlotId = null; // Reset slot selection when date changes
        await LoadInstallationSlotsAsync();
        ValidateInstallation();
        StateHasChanged();
    }

    private void ValidateInstallation()
    {
        if (!_requiresInstallation)
        {
            _isInstallationValid = true;
            return;
        }

        _isInstallationValid = _request.InstallationDate.HasValue && _request.InstallationSlotId.HasValue;
    }

    private async Task OnDistrictChanged()
    {
        if (_requiresInstallation)
        {
            _request.InstallationSlotId = null; // Reset slot selection when district changes
            await LoadInstallationSlotsAsync();
            ValidateInstallation();
            StateHasChanged();
        }
    }

    private void OnInstallationSlotChanged()
    {
        ValidateInstallation();
        StateHasChanged();
    }

    private async Task LoadUserAddressesAsync()
    {
        try
        {
            _currentUserId = CurrentUserService.UserId ?? 0;
            _userAddresses = await UserAddressService.GetByUserIdAsync(_currentUserId);

            // Auto-select default address if exists
            var defaultAddress = _userAddresses.FirstOrDefault(a => a.IsDefault);
            if (defaultAddress != null)
            {
                _selectedAddressId = defaultAddress.Id;
                PopulateFormFromAddress(defaultAddress);
            }
        }
        catch
        {
            // Ignore errors when loading addresses
            _userAddresses = new List<UserAddressResponse>();
        }
    }

    private void PopulateFormFromAddress(UserAddressResponse address)
    {
        _request.ReceiverName = address.ReceiverName;
        _request.ReceiverPhone = address.ReceiverPhone ?? "";
        _request.ShippingStreet = address.Street;
        _request.ShippingWard = address.Ward;
        _request.ShippingDistrict = address.District;
        _request.ShippingCity = address.City;
    }

    private void OnAddressSelected(int addressId)
    {
        if (addressId > 0)
        {
            var selectedAddress = _userAddresses.FirstOrDefault(a => a.Id == addressId);
            if (selectedAddress != null)
            {
                PopulateFormFromAddress(selectedAddress);
                _ = CalculateShippingFeeAsync();
            }
        }
    }

    private async Task CalculateShippingFeeAsync()
    {
        if (!_cartItems.Any())
        {
            _shippingFee = 0;
            return;
        }

        try
        {
            var city = _request.ShippingCity;
            var district = _request.ShippingDistrict;
            var weight = _totalWeight;
            var amount = _subTotal;

            var fee = await ShippingService.CalculateShippingFeeAsync(city, district, weight, amount, _requiresInstallation);
            _shippingFee = fee.Amount;
        }
        catch
        {
            // Fallback to simple logic if service fails
            if (_requiresInstallation)
            {
                _shippingFee = 0;
            }
            else
            {
                _shippingFee = _subTotal >= 500000 ? 0 : 30000;
            }
        }

        StateHasChanged();
    }

    private async Task LoadCartAsync()
    {
        _isLoading = true;
        try
        {
            var cartJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "cart");
            if (!string.IsNullOrEmpty(cartJson))
            {
                _cartItems = System.Text.Json.JsonSerializer.Deserialize<List<CartItem>>(cartJson) ?? new();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải giỏ hàng: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PlaceOrder()
    {
        if (!_isValid || !_cartItems.Any()) return;

        await _form.ValidateAsync();
        if (!_isValid) return;

        _isPlacingOrder = true;
        try
        {
            // Build request
            _request.Items = _cartItems.Select(i => new CreateOrderItemRequest
            {
                ProductId = i.ProductId,
                VariantId = i.VariantId,
                Quantity = i.Quantity,
                RequiresInstallation = i.RequiresInstallation
            }).ToList();

            // Get current user ID from auth service
            _request.UserId = CurrentUserService.UserId ?? 0;

            // Set shipping fee
            _request.ShippingFee = _shippingFee;

            // Set payment method
            _request.PaymentMethod = _paymentMethod == "VNPAY" ? Domain.Enums.PaymentMethod.VNPay : Domain.Enums.PaymentMethod.COD;

            // Create order
            var orderId = await OrderService.CreateAsync(_request);

            // Clear cart
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "cart");

            // Handle VNPay payment
            if (_paymentMethod == "VNPAY")
            {
                var orderInfo = $"Thanh toán đơn hàng {orderId}";
                var vnPayResponse = await VNPayService.CreatePaymentUrlAsync(orderId, _total, orderInfo);

                if (vnPayResponse.Success)
                {
                    // Redirect to VNPay payment page
                    NavigationManager.NavigateTo(vnPayResponse.PaymentUrl, forceLoad: true);
                }
                else
                {
                    Snackbar.Add($"Lỗi khi tạo URL thanh toán VNPAY: {vnPayResponse.Message}", Severity.Error);
                    NavigationManager.NavigateTo($"/orders/{orderId}");
                }
            }
            else
            {
                Snackbar.Add("Đặt hàng thành công!", Severity.Success);
                NavigationManager.NavigateTo("/orders");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi đặt hàng: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPlacingOrder = false;
        }
    }

    private string FormatPrice(decimal price)
    {
        return $"{price:N0} ₫";
    }
}
