@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@inject IReturnOrderService ReturnOrderService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Yêu cầu hoàn hàng - Đơn #@OrderNumber</MudText>
        
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Chọn sản phẩm hoàn trả:</MudText>
            
            @foreach (var item in Items)
            {
                <MudCard Class="mb-2" Elevation="0" Outlined="true">
                    <MudCardContent>
                        <div class="d-flex align-center justify-space-between">
                            <div>
                                <MudText Typo="Typo.body1" Class="fw-bold">@item.ProductName</MudText>
                                <MudText Typo="Typo.caption">SKU: @item.Sku</MudText>
                            </div>
                            <div class="d-flex align-center gap-3">
                                <MudNumericField T="int" @bind-Value="_returnQuantities[item.Id]" 
                                                 Label="SL hoàn" Min="0" Max="@item.Quantity"
                                                 Style="width: 100px;" />
                                <MudText Typo="Typo.caption">/ @item.Quantity</MudText>
                            </div>
                        </div>
                    </MudCardContent>
                </MudCard>
            }
            
            <MudTextField @bind-Value="_reason" Label="Lý do hoàn hàng *" 
                          Required="true" RequiredError="Vui lòng nhập lý do"
                          Lines="3" Class="mt-4" />
            
            <MudTextField @bind-Value="_bankInfo" Label="Thông tin tài khoản hoàn tiền (nếu có)"
                          HelperText="Số tài khoản - Tên ngân hàng - Tên chủ TK"
                          Class="mt-2" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid || !HasSelectedItems()">
            Gửi yêu cầu
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .fw-bold {
        font-weight: 600;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int OrderId { get; set; }

    [Parameter]
    public string OrderNumber { get; set; } = "";

    [Parameter]
    public List<OrderItemResponse> Items { get; set; } = new();

    private MudForm _form = null!;
    private bool _isValid;
    private string _reason = "";
    private string _bankInfo = "";
    private Dictionary<int, int> _returnQuantities = new();

    protected override void OnInitialized()
    {
        // Initialize return quantities to 0
        foreach (var item in Items)
        {
            _returnQuantities[item.Id] = 0;
        }
    }

    private bool HasSelectedItems()
    {
        return _returnQuantities.Values.Any(q => q > 0);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid || !HasSelectedItems()) return;

        try
        {
            // Create return items
            var returnItems = _returnQuantities
                .Where(x => x.Value > 0)
                .Select(x => new CreateReturnOrderItemRequest
                {
                    OrderItemId = x.Key,
                    Quantity = x.Value,
                    Reason = _reason
                })
                .ToList();

            var request = new CreateReturnOrderRequest
            {
                OrderId = OrderId,
                Reason = _reason,
                Items = returnItems
            };

            await ReturnOrderService.CreateAsync(request);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }
}
