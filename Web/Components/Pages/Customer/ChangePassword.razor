@page "/change-password"
@layout Web.Components.Layout.AccountLayout
@using Application.DTOs.Requests
@using Application.Interfaces.Services
@using Web.Services
@inject IIdentityService IdentityService
@inject IAuthService AuthService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<MudText Typo="Typo.h5" Class="mb-4">Đổi mật khẩu</MudText>

<MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Thay đổi mật khẩu</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudForm @ref="_form" @bind-IsValid="_isValid">
                        <MudTextField @bind-Value="_currentPassword" 
                                      Label="Mật khẩu hiện tại" 
                                      InputType="InputType.Password"
                                      Required="true"
                                      RequiredError="Vui lòng nhập mật khẩu hiện tại"
                                      Variant="Variant.Outlined" 
                                      Class="mb-3" />
                        
                        <MudTextField @bind-Value="_newPassword" 
                                      Label="Mật khẩu mới" 
                                      InputType="InputType.Password"
                                      Required="true"
                                      RequiredError="Vui lòng nhập mật khẩu mới"
                                      Variant="Variant.Outlined" 
                                      Class="mb-3"
                                      HelperText="Mật khẩu phải có ít nhất 6 ký tự" />
                        
                        <MudTextField @bind-Value="_confirmPassword" 
                                      Label="Xác nhận mật khẩu mới" 
                                      InputType="InputType.Password"
                                      Required="true"
                                      RequiredError="Vui lòng xác nhận mật khẩu mới"
                                      Validation="@((string val) => val == _newPassword ? null : "Mật khẩu xác nhận không khớp")"
                                      Variant="Variant.Outlined" 
                                      Class="mb-3" />
                    </MudForm>

                    <MudAlert Severity="Severity.Info" Class="mt-4">
                        <MudText Typo="Typo.body2">
                            <strong>Lưu ý:</strong> Sau khi đổi mật khẩu thành công, bạn sẽ cần đăng nhập lại.
                        </MudText>
                    </MudAlert>
                </MudCardContent>
                <MudCardActions Class="justify-end">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary"
                               OnClick="ChangePasswordAsync"
                               Disabled="!_isValid || _isChanging"
                               StartIcon="@Icons.Material.Filled.Lock">
                        @if (_isChanging)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
                            <span>Đang xử lý...</span>
                        }
                        else
                        {
                            <span>Đổi mật khẩu</span>
                        }
                    </MudButton>
                </MudCardActions>
            </MudCard>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _isChanging;
    private int? _currentUserId;
    
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCurrentUserId();
        }
    }

    private async Task LoadCurrentUserId()
    {
        var userIdStr = await AuthService.GetUserIdAsync();
        if (int.TryParse(userIdStr, out var userId))
        {
            _currentUserId = userId;
        }
    }

    private async Task ChangePasswordAsync()
    {
        if (!_currentUserId.HasValue)
        {
            Snackbar.Add("Không tìm thấy thông tin người dùng", Severity.Error);
            return;
        }

        await _form.ValidateAsync();
        if (!_isValid) return;

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Mật khẩu xác nhận không khớp", Severity.Error);
            return;
        }

        if (_newPassword.Length < 6)
        {
            Snackbar.Add("Mật khẩu mới phải có ít nhất 6 ký tự", Severity.Error);
            return;
        }

        _isChanging = true;
        try
        {
            var result = await IdentityService.ChangePasswordAsync(_currentUserId.Value, _currentPassword, _newPassword);
            if (!result.Succeeded)
            {
                Snackbar.Add($"Lỗi: {string.Join(", ", result.Errors.Select(e => e.Description))}", Severity.Error);
                return;
            }
            
            Snackbar.Add("Đổi mật khẩu thành công! Vui lòng đăng nhập lại.", Severity.Success);
            
            // Clear form
            _currentPassword = "";
            _newPassword = "";
            _confirmPassword = "";
            
            // Redirect to login after 2 seconds
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/login", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isChanging = false;
        }
    }
}
