@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@using Domain.Enums
@using Web.Helpers
@using Web.Services
@implements IAsyncDisposable
@inject IOrderService OrderService
@inject IReturnOrderService ReturnOrderService
@inject IWarrantyRequestService WarrantyRequestService
@inject IProductCommentService CommentService
@inject ITechnicianRatingService TechnicianRatingService
@inject IInstallationService InstallationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IChatService ChatService
@inject CurrentUserService CurrentUser
@inject IJSRuntime JSRuntime
@inject IHttpClientFactory HttpClientFactory
@inject SignalRService SignalRService
@inject NavigationManager NavigationManager

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Animation="Animation.Wave" />
        }
        else if (_order == null)
        {
            <MudAlert Severity="Severity.Error">Không tìm thấy đơn hàng</MudAlert>
        }
        else
        {
            <!-- Order Header - Always Visible -->
            <div class="d-flex align-center justify-space-between mb-4">
                <div>
                    <MudText Typo="Typo.h6" Class="fw-bold">Đơn hàng #@_order.OrderNumber</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Đặt ngày @_order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </MudText>
                </div>
                <MudChip T="string" Color="@StatusHelper.GetOrderStatusColor(_order.Status)" Size="Size.Medium">
                    @StatusHelper.GetOrderStatusText(_order.Status)
                </MudChip>
            </div>

            <!-- Cancel Reason -->
            @if (!string.IsNullOrEmpty(_order.CancelReason))
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    <MudText Typo="Typo.body2" Class="fw-bold">Lý do hủy:</MudText>
                    <MudText Typo="Typo.body2">@_order.CancelReason</MudText>
                </MudAlert>
            }

            <!-- Tabs -->
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
                <!-- Tab 1: Thông tin chung -->
                <MudTabPanel Text="Thông tin chung" Icon="@Icons.Material.Filled.Info">
                    <MudGrid>
                        <!-- Order Items -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Sản phẩm</MudText>
                            <MudCard Elevation="0" Outlined="true" Class="mb-4">
                                @foreach (var item in _order.Items)
                                {
                                    <MudCardContent Class="py-2">
                                        <div class="d-flex align-center justify-space-between">
                                            <div class="d-flex align-center gap-3">
                                                <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined">
                                                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                                                </MudAvatar>
                                                <div>
                                                    <MudText Typo="Typo.body1" Class="fw-bold">@item.ProductName</MudText>
                                                    @if (!string.IsNullOrEmpty(item.VariantSku))
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">SKU: @item.VariantSku</MudText>
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">SKU: @item.Sku</MudText>
                                                    }
                                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Phân loại: @item.VariantName</MudText>
                                                    }
                                                    @if (item.RequiresInstallation)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mt-1">
                                                            Cần lắp đặt
                                                        </MudChip>
                                                    }
                                                </div>
                                            </div>
                                            <div class="text-right">
                                                <MudText Typo="Typo.body2">x @item.Quantity</MudText>
                                                <MudText Typo="Typo.body1" Class="fw-bold" Color="Color.Primary">
                                                    @FormatPrice(item.TotalPrice)
                                                </MudText>
                                            </div>
                                        </div>
                                    </MudCardContent>
                                    @if (item != _order.Items.Last())
                                    {
                                        <MudDivider />
                                    }
                                }
                            </MudCard>
                        </MudItem>

                        <!-- Order Summary -->
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Thông tin giao hàng</MudText>
                            <MudCard Elevation="0" Outlined="true" Class="mb-4">
                                <MudCardContent>
                                    <div class="d-flex align-center gap-2 mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_order.ReceiverName</MudText>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_order.ReceiverPhone))
                                    {
                                        <div class="d-flex align-center gap-2 mb-2">
                                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">@_order.ReceiverPhone</MudText>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(_order.ShippingAddress))
                                    {
                                        <div class="d-flex align-start gap-2">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">@_order.ShippingAddress</MudText>
                                        </div>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Thanh toán</MudText>
                            <MudCard Elevation="0" Outlined="true" Class="mb-4">
                                <MudCardContent>
                                    <div class="d-flex justify-space-between mb-2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Tạm tính</MudText>
                                        <MudText Typo="Typo.body2">@FormatPrice(_order.SubTotal)</MudText>
                                    </div>
                                    @if (_order.DiscountAmount > 0)
                                    {
                                        <div class="d-flex justify-space-between mb-2">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Giảm giá</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Success">-@FormatPrice(_order.DiscountAmount)</MudText>
                                        </div>
                                    }
                                    <div class="d-flex justify-space-between mb-2">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Phí vận chuyển</MudText>
                                        <MudText Typo="Typo.body2">@FormatPrice(_order.ShippingFee)</MudText>
                                    </div>
                                    <MudDivider Class="my-2" />
                                    <div class="d-flex justify-space-between">
                                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Tổng cộng</MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold">
                                            @FormatPrice(_order.TotalAmount)
                                        </MudText>
                                    </div>
                                    <div class="d-flex justify-space-between mt-2">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Phương thức thanh toán</MudText>
                                        <MudText Typo="Typo.caption">@GetPaymentMethodText(_order.PaymentMethod)</MudText>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 2: Hoàn hàng & Bảo hành -->
                <MudTabPanel Text="Hoàn hàng & Bảo hành" Icon="@Icons.Material.Filled.AssignmentReturn">
                    <MudGrid>
                        <!-- Return Policy Countdown - Consistent with Header -->
                        @if (!_hasReturnOrder)
                        {
                            var daysSinceOrder = (DateTime.UtcNow - _order.CreatedAt).TotalDays;
                            var returnDeadlineDays = 30; // 1 month (30 days) from order date
                            var daysRemaining = returnDeadlineDays - daysSinceOrder;
                            <MudItem xs="12">
                                @if (daysRemaining > 0)
                                {
                                    <MudAlert Severity="Severity.Info" Class="mb-4">
                                        <div class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large" />
                                            <div>
                                                <MudText Typo="Typo.subtitle2" Class="fw-bold">Thời hạn hoàn hàng</MudText>
                                                <MudText Typo="Typo.body2">
                                                    Còn <strong>@Math.Floor(daysRemaining)</strong> ngày để hoàn trả (trong vòng 1 tháng đầu kể từ ngày đặt hàng: @_order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy"))
                                                </MudText>
                                            </div>
                                        </div>
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Warning" Class="mb-4">
                                        <div class="d-flex align-center gap-3">
                                            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" />
                                            <div>
                                                <MudText Typo="Typo.subtitle2" Class="fw-bold">Thời hạn hoàn hàng</MudText>
                                                <MudText Typo="Typo.body2">
                                                    Đã hết thời gian hoàn trả (1 tháng đầu kể từ ngày đặt hàng: @_order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy"))
                                                </MudText>
                                            </div>
                                        </div>
                                    </MudAlert>
                                }
                            </MudItem>
                        }

                        <!-- Warranty Request Status -->
                        @if (_warrantyRequest != null)
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Trạng thái bảo hành</MudText>
                                <MudCard Elevation="0" Outlined="true">
                                    <MudCardContent>
                                        <div class="d-flex align-center justify-space-between mb-2">
                                            <div>
                                                <MudText Typo="Typo.body2" Class="fw-bold">Trạng thái:</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="@GetWarrantyStatusColor(_warrantyRequest.Status)">
                                                    @GetWarrantyStatusText(_warrantyRequest.Status)
                                                </MudChip>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(_warrantyRequest.Description))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                                Mô tả: @_warrantyRequest.Description
                                            </MudText>
                                        }
                                        @if (_warrantyRequest.ApprovedAt.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                                Ngày duyệt: @_warrantyRequest.ApprovedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                            </MudText>
                                        }
                                        @if (_warrantyRequest.CompletedAt.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                                Ngày hoàn thành: @_warrantyRequest.CompletedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                            </MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        }
                        else if (_order.Status == "Delivered" || _order.Status == "Completed")
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info">
                                    <MudText Typo="Typo.body2">Chưa có yêu cầu bảo hành nào cho đơn hàng này.</MudText>
                                </MudAlert>
                            </MudItem>
                        }

                        <!-- Return Order Info -->
                        @if (_hasReturnOrder)
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Yêu cầu hoàn hàng</MudText>
                                <MudAlert Severity="Severity.Success">
                                    <MudText Typo="Typo.body2">Đơn hàng này đã có yêu cầu hoàn hàng.</MudText>
                                </MudAlert>
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 4: Đánh giá -->
                <MudTabPanel Text="Đánh giá" Icon="@Icons.Material.Filled.Star">
                    <MudGrid>
                        <!-- Product Reviews -->
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Đánh giá sản phẩm</MudText>
                            @if (_reviews?.Any() == true)
                            {
                                @foreach (var review in _reviews)
                                {
                                    <MudCard Class="mb-2" Elevation="0" Outlined="true">
                                        <MudCardContent>
                                            <div class="d-flex align-center justify-space-between mb-2">
                                                <div class="d-flex align-center gap-2">
                                                    <MudRating SelectedValue="review.Rating" ReadOnly="true" MaxValue="5" Size="Size.Small" />
                                                    <MudText Typo="Typo.caption" Color="Color.Primary">@review.Rating/5</MudText>
                                                    @if (review.IsApproved)
                                                    {
                                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Đã duyệt</MudChip>
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Chờ duyệt</MudChip>
                                                    }
                                                </div>
                                                <MudButton Variant="Variant.Text" Color="Color.Primary" Class="pa-0 fw-bold" OnClick="() => NavigateToProduct(review.ProductId)">
                                                    @review.ProductName
                                                </MudButton>
                                            </div>
                                            <MudText Typo="Typo.body2" Class="mt-2">@review.Content</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@review.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                            @if (review.Replies?.Any() == true)
                                            {
                                                <div class="mt-2 ml-4">
                                                    @foreach (var reply in review.Replies)
                                                    {
                                                        <MudCard Class="mb-1" Elevation="0" Outlined="true" Style="background-color: #f5f5f5;">
                                                            <MudCardContent Class="pa-2">
                                                                <MudText Typo="Typo.caption" Class="fw-bold">@reply.UserName</MudText>
                                                                <MudRating SelectedValue="reply.Rating" ReadOnly="true" MaxValue="5" Size="Size.Small" />
                                                                <MudText Typo="Typo.caption">@reply.Content</MudText>
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@reply.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                                            </MudCardContent>
                                                        </MudCard>
                                                    }
                                                </div>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                }
                            }
                            else if (_order.Status == "Completed")
                            {
                                <MudAlert Severity="Severity.Info">
                                    <MudText Typo="Typo.body2">Bạn chưa đánh giá sản phẩm nào cho đơn hàng này.</MudText>
                                </MudAlert>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Đánh giá sản phẩm sẽ có sẵn sau khi đơn hàng hoàn thành.</MudText>
                            }
                        </MudItem>

                        <!-- Technician Rating -->
                        @if (_hasInstallation)
                        {
                            <MudItem xs="12">
                                <MudDivider Class="my-4" />
                                <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Đánh giá kỹ thuật viên</MudText>
                                @if (_technicianRating != null)
                                {
                                    <MudCard Elevation="0" Outlined="true">
                                        <MudCardContent>
                                            <div class="d-flex align-center justify-space-between">
                                                <div>
                                                    <MudText Typo="Typo.body2" Class="fw-bold mb-1">
                                                        Kỹ thuật viên: @_technicianRating.TechnicianName
                                                    </MudText>
                                                    <div class="d-flex align-center gap-2">
                                                        <MudRating SelectedValue="_technicianRating.Rating" ReadOnly="true" MaxValue="5" Size="Size.Small" />
                                                        <MudText Typo="Typo.caption" Color="Color.Primary">@_technicianRating.Rating/5</MudText>
                                                        @if (_technicianRating.IsApproved)
                                                        {
                                                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Đã duyệt</MudChip>
                                                        }
                                                        else
                                                        {
                                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">Chờ duyệt</MudChip>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            <MudText Typo="Typo.body2" Class="mt-2">@_technicianRating.Content</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@_technicianRating.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                        </MudCardContent>
                                    </MudCard>
                                }
                                else if (_order.Status == "Completed")
                                {
                                    <MudAlert Severity="Severity.Info">
                                        <MudText Typo="Typo.body2">Bạn chưa đánh giá kỹ thuật viên cho đơn hàng này.</MudText>
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Đánh giá kỹ thuật viên sẽ có sẵn sau khi lắp đặt hoàn thành.</MudText>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>

                <!-- Tab 5: Lắp đặt (chỉ hiển thị khi có lắp đặt) -->
                @if (_hasInstallation)
                {
                    <MudTabPanel Text="Lắp đặt" Icon="@Icons.Material.Filled.Build">
                        <MudGrid>
                            <!-- Installation Booking Info -->
                            @if (_installationBooking != null)
                            {
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Thông tin lắp đặt</MudText>
                                    <MudCard Elevation="0" Outlined="true" Class="mb-4">
                                        <MudCardContent>
                                            <div class="d-flex align-center gap-2 mb-2">
                                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                                <MudText Typo="Typo.body2">Ngày lắp: @_installationBooking.ScheduledDate.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
                                            </div>
                                            @if (_installationBooking.StartTime.HasValue)
                                            {
                                                <div class="d-flex align-center gap-2 mb-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.body2">Giờ: @_installationBooking.StartTime.Value.ToString(@"hh\:mm") - @_installationBooking.EndTime.Value.ToString(@"hh\:mm")</MudText>
                                                </div>
                                            }
                                            <div class="d-flex align-center gap-2 mb-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                                <MudText Typo="Typo.body2">KTV: @_installationBooking.TechnicianName</MudText>
                                            </div>
                                            <MudChip T="string" Color="@StatusHelper.GetInstallationStatusColor(_installationBooking.Status)" Size="Size.Small">
                                                @StatusHelper.GetInstallationStatusText(_installationBooking.Status)
                                            </MudChip>
                                            @if (_installationBooking.CustomerRescheduleCount >= 1)
                                            {
                                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-2">
                                                    Đã đổi lịch
                                                </MudChip>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            }

                            <!-- Chat with Technician -->
                            @if (_installationBooking != null && _installationBooking.TechnicianId.HasValue)
                            {
                                <MudItem xs="12">
                                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Liên hệ kỹ thuật viên</MudText>
                                    <MudCard Elevation="0" Outlined="true">
                                        <MudCardContent>
                                            <div class="technician-chat-interface">
                                                <!-- Chat Header -->
                                                <div class="chat-header">
                                                    <div class="d-flex align-items-center gap-3">
                                                        <MudAvatar Size="Size.Medium" Color="Color.Primary">
                                                            <MudIcon Icon="@Icons.Material.Filled.Engineering" />
                                                        </MudAvatar>
                                                        <div>
                                                            <MudText Typo="Typo.subtitle2" Class="mb-0">@_installationBooking.TechnicianName</MudText>
                                                            @if (!string.IsNullOrEmpty(_installationBooking.TechnicianPhone))
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@_installationBooking.TechnicianPhone</MudText>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Messages -->
                                                <div class="chat-messages" @ref="_technicianChatMessagesContainer">
                                                    @if (_loadingTechnicianChat)
                                                    {
                                                        <div class="text-center py-4">
                                                            <MudProgressCircular Color="Color.Primary" Size="Size.Medium" />
                                                        </div>
                                                    }
                                                    else if (_technicianChatMessages.Count == 0)
                                                    {
                                                        <div class="text-center py-4">
                                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Chưa có tin nhắn nào. Hãy bắt đầu cuộc trò chuyện!</MudText>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var msg in _technicianChatMessages)
                                                        {
                                                            <div class="@($"message {(msg.IsFromMe ? "sent" : "received")}")">
                                                                @if (!msg.IsFromMe)
                                                                {
                                                                    <div class="message-avatar">KTV</div>
                                                                }
                                                                <div class="message-content">
                                                                    <div class="message-bubble">
                                                                        @if (msg.Attachments != null && msg.Attachments.Any())
                                                                        {
                                                                            @foreach (var attachment in msg.Attachments)
                                                                            {
                                                                                @if (!string.IsNullOrEmpty(attachment.FileType) && attachment.FileType.StartsWith("image/"))
                                                                                {
                                                                                    <img src="@attachment.FileUrl" alt="@attachment.FileName" style="max-width: 100%; max-height: 300px; border-radius: 8px;" />
                                                                                }
                                                                                else
                                                                                {
                                                                                    <div class="file-attachment">
                                                                                        <span>📎</span>
                                                                                        <a href="@attachment.FileUrl" target="_blank">@attachment.FileName</a>
                                                                                    </div>
                                                                                }
                                                                            }
                                                                        }
                                                                        @if (!string.IsNullOrEmpty(msg.Content))
                                                                        {
                                                                            <MudText Typo="Typo.body2">@msg.Content</MudText>
                                                                        }
                                                                    </div>
                                                                    <div class="message-time">@msg.SentAt.ToLocalTime().ToString("HH:mm")</div>
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                </div>

                                                <!-- Input Area -->
                                                <div class="chat-input-area">
                                                    @if (!string.IsNullOrEmpty(_technicianChatFilePreviewUrl))
                                                    {
                                                        <div class="file-preview">
                                                            <img src="@_technicianChatFilePreviewUrl" alt="Preview" style="max-width: 100%; max-height: 100px; border-radius: 8px;" />
                                                            <button type="button" class="remove-file" @onclick="RemoveTechnicianChatFile">✕</button>
                                                        </div>
                                                    }
                                                    <div class="d-flex gap-2">
                                                        <InputFile class="d-none technician-chat-file-input" OnChange="OnTechnicianChatFileSelected" accept="image/*,.pdf,.doc,.docx" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.AttachFile" @onclick="TriggerTechnicianChatFileSelect" Disabled="@(_sendingTechnicianChat)" Title="Đính kèm file" Size="Size.Medium" />
                                                        <MudTextField T="string" 
                                                                     @bind-Value="_technicianChatMessage" 
                                                                     Placeholder="Nhập tin nhắn..." 
                                                                     Variant="Variant.Outlined" 
                                                                     OnKeyDown="OnTechnicianChatKeyPress"
                                                                     Disabled="@(_sendingTechnicianChat)"
                                                                     Class="chat-input-field" />
                                                        <MudButton Variant="Variant.Filled" 
                                                                   Color="Color.Primary" 
                                                                   OnClick="async () => await SendTechnicianChatMessage()" 
                                                                   Disabled="@(!CanSendTechnicianChatMessage)"
                                                                   Class="chat-send-button">
                                                            <MudIcon Icon="@Icons.Material.Filled.Send" />
                                                        </MudButton>
                                                    </div>
                                                </div>
                                            </div>
                                        </MudCardContent>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudTabPanel>
                }
            </MudTabs>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Đóng</MudButton>
        
        @* Nút Hủy đơn - chỉ hiển thị khi đơn hàng đang chờ xác nhận *@
        @if (_order != null && _order.Status == "Pending")
        {
            <MudButton Color="Color.Error" OnClick="CancelOrder" StartIcon="@Icons.Material.Filled.Cancel">
                Hủy đơn hàng
            </MudButton>
        }
        
        @* Nút Hoàn hàng - hiển thị khi đơn hàng đã giao hoặc hoàn thành và còn thời hạn hoàn trả *@
        @if (_order != null && (_order.Status == "Delivered" || _order.Status == "Completed") && !_hasReturnOrder)
        {
            var daysSinceOrder = (DateTime.UtcNow - _order.CreatedAt).TotalDays;
            var returnDeadlineDays = 30; // 1 month (30 days) from order date
            var daysRemaining = returnDeadlineDays - daysSinceOrder;
            
            @if (daysRemaining > 0)
            {
                <MudButton Color="Color.Warning" OnClick="OpenReturnDialog" StartIcon="@Icons.Material.Filled.AssignmentReturn">
                    Hoàn hàng
                </MudButton>
            }
            else
            {
                <MudButton Color="Color.Warning" Disabled="true" StartIcon="@Icons.Material.Filled.AssignmentReturn">
                    Hoàn hàng (hết hạn)
                </MudButton>
            }
        }

        @* Nút Bảo hành - hiển thị khi đơn hàng đã giao hoặc hoàn thành và chưa hoàn hàng *@
        @if (_order != null && (_order.Status == "Delivered" || _order.Status == "Completed") && !_hasWarrantyRequest && !_hasReturnOrder)
        {
            <MudButton Color="Color.Info" OnClick="OpenWarrantyDialog" StartIcon="@Icons.Material.Filled.Build">
                Bảo hành
            </MudButton>
        }
        
        @* Nút Đánh giá sản phẩm - hiển thị khi đơn hàng hoàn thành *@
        @if (_order != null && _order.Status == "Completed")
        {
            @if (_hasReviewed)
            {
                <MudButton Color="Color.Primary" OnClick="OpenEditReviewDialog" StartIcon="@Icons.Material.Filled.Edit">
                    Đánh giá sản phẩm
                </MudButton>
            }
            else
            {
                <MudButton Color="Color.Primary" OnClick="OpenReviewDialog" StartIcon="@Icons.Material.Filled.RateReview">
                    Đánh giá sản phẩm
                </MudButton>
            }
        }
        
        @* Nút Đánh giá kỹ thuật viên - hiển thị khi đơn hàng hoàn thành và có lắp đặt *@
        @if (_order != null && _order.Status == "Completed" && _hasInstallation)
        {
            @if (_hasRatedTechnician)
            {
                <MudButton Color="Color.Secondary" OnClick="OpenEditTechnicianRatingDialog" StartIcon="@Icons.Material.Filled.Edit">
                    Đánh giá kỹ thuật viên
                </MudButton>
            }
            else
            {
                <MudButton Color="Color.Secondary" OnClick="OpenTechnicianRatingDialog" StartIcon="@Icons.Material.Filled.Star">
                    Đánh giá kỹ thuật viên
                </MudButton>
            }
        }

        @* Nút Đổi lịch - hiển thị khi có lắp đặt và chưa hoàn thành và chưa đổi lịch *@
        @if (_hasInstallation && _installationBooking != null && _installationBooking.Status != "Completed" && _installationBooking.CustomerRescheduleCount < 1)
        {
            <MudButton Color="Color.Tertiary" OnClick="OpenRescheduleDialog" StartIcon="@Icons.Material.Filled.Event">
                Đổi lịch lắp đặt
            </MudButton>
        }
    </DialogActions>
</MudDialog>

