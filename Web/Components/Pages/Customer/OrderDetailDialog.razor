@using Application.DTOs.Requests
@using Application.DTOs.Responses
@using Application.Interfaces.Services
@inject IOrderService OrderService
@inject IReturnOrderService ReturnOrderService
@inject IWarrantyRequestService WarrantyRequestService
@inject IProductCommentService CommentService
@inject ITechnicianRatingService TechnicianRatingService
@inject IInstallationService InstallationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Animation="Animation.Wave" />
        }
        else if (_order == null)
        {
            <MudAlert Severity="Severity.Error">Không tìm thấy đơn hàng</MudAlert>
        }
        else
        {
            <MudGrid>
                <!-- Order Header -->
                <MudItem xs="12">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div>
                            <MudText Typo="Typo.h6" Class="fw-bold">Đơn hàng #@_order.OrderNumber</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Đặt ngày @_order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </div>
                        <MudChip T="string" Color="@GetStatusColor(_order.Status)" Size="Size.Medium">
                            @GetStatusText(_order.Status)
                        </MudChip>
                    </div>
                </MudItem>

                <!-- Order Items -->
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Sản phẩm</MudText>
                    <MudCard Elevation="0" Outlined="true" Class="mb-4">
                        @foreach (var item in _order.Items)
                        {
                            <MudCardContent Class="py-2">
                                <div class="d-flex align-center justify-space-between">
                                    <div class="d-flex align-center gap-3">
                                        <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined">
                                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                                        </MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.body1" Class="fw-bold">@item.ProductName</MudText>
                                            @if (!string.IsNullOrEmpty(item.VariantSku))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">SKU: @item.VariantSku</MudText>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">SKU: @item.Sku</MudText>
                                            }
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Phân loại: @item.VariantName</MudText>
                                            }
                                            @if (item.RequiresInstallation)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mt-1">
                                                    Cần lắp đặt
                                                </MudChip>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <MudText Typo="Typo.body2">x @item.Quantity</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-bold" Color="Color.Primary">
                                            @FormatPrice(item.TotalPrice)
                                        </MudText>
                                    </div>
                                </div>
                            </MudCardContent>
                            @if (item != _order.Items.Last())
                            {
                                <MudDivider />
                            }
                        }
                    </MudCard>
                </MudItem>

                <!-- Order Summary -->
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Thông tin giao hàng</MudText>
                    <MudCard Elevation="0" Outlined="true" Class="mb-4">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_order.ReceiverName</MudText>
                            </div>
                            @if (!string.IsNullOrEmpty(_order.ReceiverPhone))
                            {
                                <div class="d-flex align-center gap-2 mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">@_order.ReceiverPhone</MudText>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(_order.ShippingAddress))
                            {
                                <div class="d-flex align-start gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">@_order.ShippingAddress</MudText>
                                </div>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Thanh toán</MudText>
                    <MudCard Elevation="0" Outlined="true" Class="mb-4">
                        <MudCardContent>
                            <div class="d-flex justify-space-between mb-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Tạm tính</MudText>
                                <MudText Typo="Typo.body2">@FormatPrice(_order.SubTotal)</MudText>
                            </div>
                            @if (_order.DiscountAmount > 0)
                            {
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Giảm giá</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Success">-@FormatPrice(_order.DiscountAmount)</MudText>
                                </div>
                            }
                            <div class="d-flex justify-space-between mb-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Phí vận chuyển</MudText>
                                <MudText Typo="Typo.body2">@FormatPrice(_order.ShippingFee)</MudText>
                            </div>
                            <MudDivider Class="my-2" />
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.subtitle1" Class="fw-bold">Tổng cộng</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold">
                                    @FormatPrice(_order.TotalAmount)
                                </MudText>
                            </div>
                            <div class="d-flex justify-space-between mt-2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Phương thức thanh toán</MudText>
                                <MudText Typo="Typo.caption">@GetPaymentMethodText(_order.PaymentMethod)</MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Shipments -->
                @if (_order.Shipments.Any())
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Thông tin vận chuyển</MudText>
                        @foreach (var shipment in _order.Shipments)
                        {
                            <MudCard Elevation="0" Outlined="true" Class="mb-2">
                                <MudCardContent>
                                    <div class="d-flex align-center justify-space-between">
                                        <div>
                                            <MudText Typo="Typo.body2" Class="fw-bold">Mã vận đơn: @shipment.TrackingNumber</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @if (!string.IsNullOrEmpty(shipment.Carrier))
                                                {
                                                    <span>Đơn vị: @shipment.Carrier</span>
                                                }
                                                @if (!string.IsNullOrEmpty(shipment.TrackingNumber))
                                                {
                                                    <span> | Mã vận: @shipment.TrackingNumber</span>
                                                }
                                            </MudText>
                                        </div>
                                        <MudChip T="string" Size="Size.Small" Color="@GetShipmentStatusColor(shipment.Status)">
                                            @GetShipmentStatusText(shipment.Status)
                                        </MudChip>
                                    </div>
                                    @if (shipment.PickedUpAt.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                            Lấy hàng ngày: @shipment.PickedUpAt.Value.ToString("dd/MM/yyyy")
                                        </MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        }
                    </MudItem>
                }

                <!-- Cancel Reason -->
                @if (!string.IsNullOrEmpty(_order.CancelReason))
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info">
                            <MudText Typo="Typo.body2" Class="fw-bold">Lý do hủy:</MudText>
                            <MudText Typo="Typo.body2">@_order.CancelReason</MudText>
                        </MudAlert>
                    </MudItem>
                }

                <!-- Warranty Request Status -->
                @if (_warrantyRequest != null)
                {
                    <MudItem xs="12" Class="mt-4">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Trạng thái bảo hành</MudText>
                        <MudCard Elevation="0" Outlined="true">
                            <MudCardContent>
                                <div class="d-flex align-center justify-space-between mb-2">
                                    <div>
                                        <MudText Typo="Typo.body2" Class="fw-bold">Loại bảo hành:</MudText>
                                        <MudText Typo="Typo.caption">@_warrantyRequest.WarrantyType</MudText>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Color="@GetWarrantyStatusColor(_warrantyRequest.Status)">
                                        @GetWarrantyStatusText(_warrantyRequest.Status)
                                    </MudChip>
                                </div>
                                @if (!string.IsNullOrEmpty(_warrantyRequest.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        Mô tả: @_warrantyRequest.Description
                                    </MudText>
                                }
                                @if (_warrantyRequest.ApprovedAt.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        Ngày duyệt: @_warrantyRequest.ApprovedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    </MudText>
                                }
                                @if (_warrantyRequest.CompletedAt.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        Ngày hoàn thành: @_warrantyRequest.CompletedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    </MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }

                <!-- Reviews -->
                @if (_reviews?.Any() == true)
                {
                    <MudItem xs="12" Class="mt-4">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Đánh giá sản phẩm</MudText>
                        @foreach (var review in _reviews)
                        {
                            <MudCard Class="mb-2" Elevation="0" Outlined="true">
                                <MudCardContent>
                                    <div class="d-flex align-center gap-2">
                                        <MudRating SelectedValue="review.Rating" ReadOnly="true" MaxValue="5" Size="Size.Small" />
                                        <MudText Typo="Typo.caption" Color="Color.Primary">@review.Rating/5</MudText>
                                        @if (review.IsApproved)
                                        {
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Đã duyệt</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">Chờ duyệt</MudChip>
                                        }
                                    </div>
                                    <MudText Typo="Typo.body2" Class="mt-2">@review.Content</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                                    @if (review.Replies?.Any() == true)
                                    {
                                        <div class="mt-2 ml-4">
                                            @foreach (var reply in review.Replies)
                                            {
                                                <MudCard Class="mb-1" Elevation="0" Outlined="true" Style="background-color: #f5f5f5;">
                                                    <MudCardContent Class="pa-2">
                                                        <MudText Typo="Typo.caption" Class="fw-bold">@reply.UserName</MudText>
                                                        <MudRating SelectedValue="reply.Rating" ReadOnly="true" MaxValue="5" Size="Size.Small" />
                                                        <MudText Typo="Typo.caption">@reply.Content</MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@reply.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                                                    </MudCardContent>
                                                </MudCard>
                                            }
                                        </div>
                                    }
                                </MudCardContent>
                            </MudCard>
                        }
                    </MudItem>
                }

                <!-- Technician Rating -->
                @if (_hasInstallation && _technicianRating != null)
                {
                    <MudItem xs="12" Class="mt-4">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1" Class="fw-bold mb-2">Đánh giá kỹ thuật viên</MudText>
                        <MudCard Elevation="0" Outlined="true">
                            <MudCardContent>
                                <div class="d-flex align-center justify-space-between">
                                    <div>
                                        <MudText Typo="Typo.body2" Class="fw-bold mb-1">
                                            Kỹ thuật viên: @_technicianRating.TechnicianName
                                        </MudText>
                                        <div class="d-flex align-center gap-2">
                                            <MudRating SelectedValue="_technicianRating.Rating" ReadOnly="true" MaxValue="5" Size="Size.Small" />
                                            <MudText Typo="Typo.caption" Color="Color.Primary">@_technicianRating.Rating/5</MudText>
                                            @if (_technicianRating.IsApproved)
                                            {
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Đã duyệt</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Chờ duyệt</MudChip>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <MudText Typo="Typo.body2" Class="mt-2">@_technicianRating.Content</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@_technicianRating.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Đóng</MudButton>
        
        @* Nút Hủy đơn - chỉ hiển thị khi đơn hàng đang chờ xác nhận *@
        @if (_order != null && _order.Status == "Pending")
        {
            <MudButton Color="Color.Error" OnClick="CancelOrder" StartIcon="@Icons.Material.Filled.Cancel">
                Hủy đơn hàng
            </MudButton>
        }
        
        @* Nút Hoàn hàng - hiển thị khi đơn hàng đã giao hoặc hoàn thành *@
        @if (_order != null && (_order.Status == "Delivered" || _order.Status == "Completed") && !_hasReturnOrder)
        {
            <MudButton Color="Color.Warning" OnClick="OpenReturnDialog" StartIcon="@Icons.Material.Filled.AssignmentReturn">
                Hoàn hàng
            </MudButton>
        }

        @* Nút Bảo hành - hiển thị khi đơn hàng đã giao hoặc hoàn thành và chưa hoàn hàng *@
        @if (_order != null && (_order.Status == "Delivered" || _order.Status == "Completed") && !_hasWarrantyRequest && !_hasReturnOrder)
        {
            <MudButton Color="Color.Info" OnClick="OpenWarrantyDialog" StartIcon="@Icons.Material.Filled.Build">
                Bảo hành
            </MudButton>
        }
        
        @* Nút Đánh giá sản phẩm - hiển thị khi đơn hàng hoàn thành *@
        @if (_order != null && _order.Status == "Completed")
        {
            @if (_hasReviewed)
            {
                <MudButton Color="Color.Primary" OnClick="OpenEditReviewDialog" StartIcon="@Icons.Material.Filled.Edit">
                    Đánh giá sản phẩm
                </MudButton>
            }
            else
            {
                <MudButton Color="Color.Primary" OnClick="OpenReviewDialog" StartIcon="@Icons.Material.Filled.RateReview">
                    Đánh giá sản phẩm
                </MudButton>
            }
        }
        
        @* Nút Đánh giá kỹ thuật viên - hiển thị khi đơn hàng hoàn thành và có lắp đặt *@
        @if (_order != null && _order.Status == "Completed" && _hasInstallation)
        {
            @if (_hasRatedTechnician)
            {
                <MudButton Color="Color.Secondary" OnClick="OpenEditTechnicianRatingDialog" StartIcon="@Icons.Material.Filled.Edit">
                    Đánh giá kỹ thuật viên
                </MudButton>
            }
            else
            {
                <MudButton Color="Color.Secondary" OnClick="OpenTechnicianRatingDialog" StartIcon="@Icons.Material.Filled.Star">
                    Đánh giá kỹ thuật viên
                </MudButton>
            }
        }
    </DialogActions>
</MudDialog>

<style>
    .fw-bold {
        font-weight: 600;
    }
    .text-right {
        text-align: right;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int OrderId { get; set; }

    private OrderResponse? _order;
    private bool _isLoading = true;
    private bool _hasReturnOrder = false;
    private bool _hasWarrantyRequest = false;
    private bool _hasReviewed = false;
    private bool _hasInstallation = false;
    private bool _hasRatedTechnician = false;
    private TechnicianRatingResponse? _technicianRating;
    private List<ProductCommentResponse>? _reviews;
    private WarrantyRequestResponse? _warrantyRequest;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderAsync();
    }

    private async Task LoadOrderAsync()
    {
        _isLoading = true;
        try
        {
            _order = await OrderService.GetByIdAsync(OrderId);
            
            // Check if order has return order
            if (_order != null)
            {
                var returnOrders = await ReturnOrderService.GetByOrderIdAsync(OrderId);
                _hasReturnOrder = returnOrders.Any();

                // Check if order has warranty request
                var warrantyRequests = await WarrantyRequestService.GetByOrderIdAsync(OrderId);
                _hasWarrantyRequest = warrantyRequests.Any();
                _warrantyRequest = warrantyRequests.OrderByDescending(w => w.CreatedAt).FirstOrDefault();

                // Check if order has installation items
                _hasInstallation = _order.Items.Any(i => i.RequiresInstallation);

                // Load reviews for this order's products
                await LoadReviewsAsync();

                // Check if user has rated technician
                if (_hasInstallation)
                {
                    await CheckTechnicianRatingAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải đơn hàng: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Close() => MudDialog.Close();

    private async Task CancelOrder()
    {
        if (_order == null) return;

        // TODO: Show confirmation dialog and get cancel reason
        try
        {
            await OrderService.CancelAsync(OrderId, "Khách hàng hủy đơn");
            Snackbar.Add("Đã hủy đơn hàng", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenReturnDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "Items", _order.Items }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReturnOrderDialog>("Yêu cầu hoàn hàng", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi yêu cầu hoàn hàng thành công", Severity.Success);
            _hasReturnOrder = true;
            await LoadOrderAsync();
        }
    }

    private async Task OpenWarrantyDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "Items", _order.Items }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<WarrantyRequestDialog>("Yêu cầu bảo hành", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi yêu cầu bảo hành thành công", Severity.Success);
            _hasWarrantyRequest = true;
            await LoadOrderAsync();
        }
    }

    private async Task LoadReviewsAsync()
    {
        try
        {
            // Load reviews for this specific order
            _reviews = await CommentService.GetByOrderAsync(OrderId);
            _hasReviewed = _reviews.Any();
        }
        catch
        {
            // Ignore errors when loading reviews
            _reviews = new List<ProductCommentResponse>();
        }
    }

    private async Task OpenReviewDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "Items", _order.Items },
            { "UserId", _order.UserId }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReviewDialog>("Đánh giá sản phẩm", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi đánh giá thành công", Severity.Success);
            await LoadReviewsAsync();
        }
    }

    private async Task OpenEditReviewDialog()
    {
        if (_order == null || _reviews == null || !_reviews.Any()) return;

        var firstReview = _reviews.First();
        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "Items", _order.Items },
            { "UserId", _order.UserId },
            { "ExistingCommentId", firstReview.Id }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReviewDialog>("Sửa đánh giá sản phẩm", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã cập nhật đánh giá thành công", Severity.Success);
            await LoadReviewsAsync();
        }
    }

    private async Task CheckTechnicianRatingAsync()
    {
        try
        {
            if (_order == null) return;

            var booking = await InstallationService.GetByOrderIdAsync(OrderId);
            if (booking != null && booking.TechnicianId.HasValue)
            {
                var rating = await TechnicianRatingService.GetByTechnicianAndBookingAsync(booking.TechnicianId.Value, booking.Id);
                _hasRatedTechnician = rating != null;
                _technicianRating = rating;
            }
        }
        catch
        {
            // Ignore errors when checking technician rating
            _hasRatedTechnician = false;
            _technicianRating = null;
        }
    }

    private async Task OpenTechnicianRatingDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "UserId", _order.UserId }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TechnicianRatingDialog>("Đánh giá kỹ thuật viên", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi đánh giá thành công", Severity.Success);
            await CheckTechnicianRatingAsync();
        }
    }

    private async Task OpenEditTechnicianRatingDialog()
    {
        if (_order == null || _technicianRating == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "UserId", _order.UserId },
            { "ExistingRatingId", _technicianRating.Id }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TechnicianRatingDialog>("Sửa đánh giá kỹ thuật viên", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã cập nhật đánh giá thành công", Severity.Success);
            await CheckTechnicianRatingAsync();
        }
    }

