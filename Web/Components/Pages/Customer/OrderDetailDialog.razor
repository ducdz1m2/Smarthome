@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int OrderId { get; set; }

    private OrderResponse? _order;
    private bool _isLoading = true;
    private bool _hasReturnOrder = false;
    private bool _hasWarrantyRequest = false;
    private bool _hasReviewed = false;
    private bool _hasInstallation = false;
    private bool _hasRatedTechnician = false;
    private TechnicianRatingResponse? _technicianRating;
    private List<ProductCommentResponse>? _reviews;
    private WarrantyRequestResponse? _warrantyRequest;
    private InstallationBookingResponse? _installationBooking;

    // Technician chat fields
    private List<ChatMessageResponse> _technicianChatMessages = new();
    private string _technicianChatMessage = string.Empty;
    private bool _loadingTechnicianChat = false;
    private bool _sendingTechnicianChat = false;
    private ElementReference _technicianChatMessagesContainer;
    private int? _technicianChatRoomId = null;
    private IBrowserFile? _technicianChatSelectedFile;
    private string _technicianChatFilePreviewUrl = "";
    private Action<object>? _onMessageReceivedHandler;
    private bool _signalRInitialized = false;

    private bool CanSendTechnicianChatMessage => !_sendingTechnicianChat && (!string.IsNullOrWhiteSpace(_technicianChatMessage) || _technicianChatSelectedFile != null);

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        Console.WriteLine($"[OrderDetailDialog] OnAfterRenderAsync: firstRender={firstRender}, _signalRInitialized={_signalRInitialized}");
        if (firstRender && !_signalRInitialized)
        {
            try
            {
                Console.WriteLine("[OrderDetailDialog] Initializing SignalR...");
                await SignalRService.InitializeAsync();
                _onMessageReceivedHandler = (msg) => _ = OnTechnicianChatMessageReceived(msg);
                SignalRService.OnChatMessageReceived += _onMessageReceivedHandler;
                _signalRInitialized = true;
                Console.WriteLine("[OrderDetailDialog] SignalR initialized successfully");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[OrderDetailDialog] Failed to initialize SignalR: {ex.Message}");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_onMessageReceivedHandler != null)
        {
            SignalRService.OnChatMessageReceived -= _onMessageReceivedHandler;
        }
        await Task.CompletedTask;
    }

    private async Task OnTechnicianChatMessageReceived(object messageObj)
    {
        try
        {
            var messageJson = System.Text.Json.JsonSerializer.Serialize(messageObj);
            using var doc = System.Text.Json.JsonDocument.Parse(messageJson);
            if (doc.RootElement.TryGetProperty("chatRoomId", out var chatRoomIdElement))
            {
                var messageRoomId = chatRoomIdElement.GetInt32();
                var currentUserId = CurrentUser.UserId ?? 0;

                // Only reload if this is the current chat room
                if (_technicianChatRoomId.HasValue && messageRoomId == _technicianChatRoomId.Value)
                {
                    await LoadTechnicianChatMessages();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error processing chat message: {ex.Message}");
        }
    }

    private async Task LoadOrderAsync()
    {
        _isLoading = true;
        try
        {
            _order = await OrderService.GetByIdAsync(OrderId);
            
            // Check if order has return order
            if (_order != null)
            {
                var returnOrders = await ReturnOrderService.GetByOrderIdAsync(OrderId);
                _hasReturnOrder = returnOrders.Any();

                // Small delay to prevent DbContext threading issues
                await Task.Delay(10);

                // Check if order has warranty request
                var warrantyRequests = await WarrantyRequestService.GetByOrderIdAsync(OrderId);
                _hasWarrantyRequest = warrantyRequests.Any();
                _warrantyRequest = warrantyRequests.OrderByDescending(w => w.CreatedAt).FirstOrDefault();

                // Small delay to prevent DbContext threading issues
                await Task.Delay(10);

                // Check if order has installation items
                _hasInstallation = _order.Items.Any(i => i.RequiresInstallation);

                // Load installation booking if order has installation items
                if (_hasInstallation)
                {
                    try
                    {
                        _installationBooking = await InstallationService.GetByOrderIdAsync(OrderId);

                        // Load technician chat messages if technician is assigned
                        if (_installationBooking != null && _installationBooking.TechnicianId.HasValue)
                        {
                            await LoadTechnicianChatMessages();
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Failed to load installation booking: {ex.Message}");
                    }
                }

                // Small delay to prevent DbContext threading issues
                await Task.Delay(10);

                // Load reviews for this order's products
                await LoadReviewsAsync();

                // Check if user has rated technician
                if (_hasInstallation)
                {
                    await CheckTechnicianRatingAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi tải đơn hàng: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Close() => MudDialog.Close();

    private async Task CancelOrder()
    {
        if (_order == null) return;

        // TODO: Show confirmation dialog and get cancel reason
        try
        {
            await OrderService.CancelAsync(OrderId, "Khách hàng hủy đơn");
            Snackbar.Add("Đã hủy đơn hàng", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenReturnDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "Items", _order.Items }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReturnOrderDialog>("Yêu cầu hoàn hàng", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi yêu cầu hoàn hàng thành công", Severity.Success);
            _hasReturnOrder = true;
            await LoadOrderAsync();
        }
    }

    private async Task OpenWarrantyDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "Items", _order.Items }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<WarrantyRequestDialog>("Yêu cầu bảo hành", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi yêu cầu bảo hành thành công", Severity.Success);
            _hasWarrantyRequest = true;
            await LoadOrderAsync();
        }
    }

    private async Task LoadReviewsAsync()
    {
        try
        {
            // Load reviews for this specific order
            _reviews = await CommentService.GetByOrderAsync(OrderId);
            _hasReviewed = _reviews.Any();
        }
        catch
        {
            // Ignore errors when loading reviews
            _reviews = new List<ProductCommentResponse>();
        }
    }

    private async Task OpenReviewDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "Items", _order.Items },
            { "UserId", _order.UserId }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReviewDialog>("Đánh giá sản phẩm", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi đánh giá thành công", Severity.Success);
            await LoadReviewsAsync();
        }
    }

    private async Task OpenEditReviewDialog()
    {
        if (_order == null || _reviews == null || !_reviews.Any()) return;

        var firstReview = _reviews.First();
        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "Items", _order.Items },
            { "UserId", _order.UserId },
            { "ExistingCommentId", firstReview.Id }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReviewDialog>("Sửa đánh giá sản phẩm", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã cập nhật đánh giá thành công", Severity.Success);
            await LoadReviewsAsync();
        }
    }

    private async Task CheckTechnicianRatingAsync()
    {
        try
        {
            if (_order == null) return;

            var booking = await InstallationService.GetByOrderIdAsync(OrderId);
            if (booking != null && booking.TechnicianId.HasValue)
            {
                var rating = await TechnicianRatingService.GetByTechnicianAndBookingAsync(booking.TechnicianId.Value, booking.Id);
                _hasRatedTechnician = rating != null;
                _technicianRating = rating;
            }
        }
        catch
        {
            // Ignore errors when checking technician rating
            _hasRatedTechnician = false;
            _technicianRating = null;
        }
    }

    private async Task OpenTechnicianRatingDialog()
    {
        if (_order == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "UserId", _order.UserId }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TechnicianRatingDialog>("Đánh giá kỹ thuật viên", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã gửi đánh giá thành công", Severity.Success);
            await CheckTechnicianRatingAsync();
        }
    }

    private async Task OpenEditTechnicianRatingDialog()
    {
        if (_order == null || _technicianRating == null) return;

        var parameters = new DialogParameters
        {
            { "OrderId", OrderId },
            { "OrderNumber", _order.OrderNumber },
            { "UserId", _order.UserId },
            { "ExistingRatingId", _technicianRating.Id }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TechnicianRatingDialog>("Sửa đánh giá kỹ thuật viên", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã cập nhật đánh giá thành công", Severity.Success);
            await CheckTechnicianRatingAsync();
        }
    }

    private static Color GetShipmentStatusColor(string status)
    {
        return StatusHelper.GetShipmentStatusColor(status);
    }

    private static string GetShipmentStatusText(string status)
    {
        return StatusHelper.GetShipmentStatusText(status);
    }

    private void NavigateToProduct(int productId)
    {
        NavigationManager.NavigateTo($"/products/{productId}");
    }

    private async Task LoadTechnicianChatMessages()
    {
        if (_installationBooking == null) return;

        try
        {
            _loadingTechnicianChat = true;

            // Create chat room first if it doesn't exist
            if (_technicianChatRoomId == null && _installationBooking.TechnicianId.HasValue)
            {
                try
                {
                    var customerId = CurrentUser.UserId ?? 0;
                    _technicianChatRoomId = await ChatService.CreateInstallationChatAsync(customerId, _installationBooking.TechnicianId.Value, _installationBooking.Id);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Failed to create chat room: {ex.Message}");
                    // If chat room creation fails, just show empty state
                    _technicianChatMessages = new List<ChatMessageResponse>();
                    return;
                }
            }

            // Join SignalR room if chat room exists
            if (_technicianChatRoomId.HasValue)
            {
                await SignalRService.JoinChatRoom(_technicianChatRoomId.Value);

                var userId = CurrentUser.UserId ?? 0;
                _technicianChatMessages = await ChatService.GetChatMessagesAsync(_technicianChatRoomId.Value, userId, UserType.Customer);
                _technicianChatMessages = _technicianChatMessages.OrderBy(m => m.SentAt).ToList();
                await ScrollTechnicianChatToBottom();
            }
            else
            {
                _technicianChatMessages = new List<ChatMessageResponse>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading chat messages: {ex.Message}");
            Snackbar.Add($"Lỗi tải tin nhắn: {ex.Message}", Severity.Error);
            _technicianChatMessages = new List<ChatMessageResponse>();
        }
        finally
        {
            _loadingTechnicianChat = false;
        }
    }

    private async Task SendTechnicianChatMessage()
    {
        if (_installationBooking == null || _sendingTechnicianChat) return;

        if (string.IsNullOrWhiteSpace(_technicianChatMessage) && _technicianChatSelectedFile == null) return;

        try
        {
            _sendingTechnicianChat = true;
            await InvokeAsync(StateHasChanged);

            // Ensure chat room exists
            if (_technicianChatRoomId == null)
            {
                var customerId = CurrentUser.UserId ?? 0;
                _technicianChatRoomId = await ChatService.CreateInstallationChatAsync(customerId, _installationBooking.TechnicianId.Value, _installationBooking.Id);
            }

            // Upload file if selected
            List<ChatAttachmentRequest>? attachments = null;

            if (_technicianChatSelectedFile != null)
            {
                var fileUrl = await UploadTechnicianChatFileAsync(_technicianChatSelectedFile);
                if (fileUrl != null)
                {
                    attachments = new List<ChatAttachmentRequest>
                    {
                        new ChatAttachmentRequest
                        {
                            FileName = _technicianChatSelectedFile.Name,
                            FileUrl = fileUrl,
                            FileType = _technicianChatSelectedFile.ContentType,
                            FileSize = _technicianChatSelectedFile.Size
                        }
                    };
                }
            }

            var request = new SendMessageRequest
            {
                Content = _technicianChatMessage,
                Attachments = attachments
            };

            var userId = CurrentUser.UserId ?? 0;
            await ChatService.SendMessageAsync(_technicianChatRoomId.Value, userId, UserType.Customer, request);

            // Clear input
            _technicianChatMessage = string.Empty;
            _technicianChatSelectedFile = null;
            _technicianChatFilePreviewUrl = "";

            // Reload messages
            await LoadTechnicianChatMessages();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi gửi tin nhắn: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sendingTechnicianChat = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<string?> UploadTechnicianChatFileAsync(IBrowserFile file)
    {
        try
        {
            var content = new MultipartFormDataContent();
            content.Add(new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)), "file", file.Name);

            var client = HttpClientFactory.CreateClient();
            var response = await client.PostAsync($"https://localhost:7298/api/upload/chat", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadAsStringAsync();
                return result; // Return the URL string directly
            }

            return null;
        }
        catch
        {
            return null;
        }
    }

    private void OnTechnicianChatKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = SendTechnicianChatMessage();
        }
    }

    private async void TriggerTechnicianChatFileSelect()
    {
        await JSRuntime.InvokeVoidAsync("document.querySelector('.technician-chat-file-input').click()");
    }

    private async void OnTechnicianChatFileSelected(InputFileChangeEventArgs e)
    {
        if (e.File != null)
        {
            _technicianChatSelectedFile = e.File;

            if (e.File.ContentType.StartsWith("image/"))
            {
                var reader = new StreamReader(e.File.OpenReadStream());
                var base64 = await reader.ReadToEndAsync();
                _technicianChatFilePreviewUrl = $"data:{e.File.ContentType};base64,{base64}";
            }
        }
    }

    private void RemoveTechnicianChatFile()
    {
        _technicianChatSelectedFile = null;
        _technicianChatFilePreviewUrl = "";
    }

    private async Task ScrollTechnicianChatToBottom()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", $"document.querySelector('.chat-messages').scrollTop = document.querySelector('.chat-messages').scrollHeight");
        }
        catch { }
    }

    private async Task OpenRescheduleDialog()
    {
        if (_installationBooking == null) return;

        var parameters = new DialogParameters
        {
            { "BookingId", _installationBooking.Id },
            { "CurrentDate", _installationBooking.ScheduledDate },
            { "CurrentSlotId", _installationBooking.SlotId }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RescheduleDialog>("Đổi lịch lắp đặt", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled == false)
        {
            Snackbar.Add("Đã đổi lịch thành công", Severity.Success);
            await LoadOrderAsync();
        }
    }

    private static string GetPaymentMethodText(string paymentMethod)
    {
        return paymentMethod switch
        {
            "COD" => "Thanh toán khi nhận hàng (COD)",
            "VNPay" => "VNPay",
            "CashOnDelivery" => "Thanh toán khi nhận hàng (COD)",
            "BankTransfer" => "Chuyển khoản ngân hàng",
            "CreditCard" => "Thẻ tín dụng",
            "EWallet" => "Ví điện tử",
            _ => paymentMethod
        };
    }

    private static Color GetWarrantyStatusColor(string status)
    {
        return StatusHelper.GetWarrantyStatusColor(status);
    }

    private static string GetWarrantyStatusText(string status)
    {
        return StatusHelper.GetWarrantyStatusText(status);
    }

    private string FormatPrice(decimal price)
    {
        return $"{price:N0} ₫";
    }
}

<style>
.technician-chat-interface {
    display: flex;
    flex-direction: column;
    height: 500px;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.chat-header {
    padding: 16px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.chat-header .mud-avatar {
    background: rgba(255,255,255,0.2);
}

.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    background: #f5f5f5;
    max-height: 350px;
}

.message {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
}

.message.received {
    justify-content: flex-start;
}

.message.sent {
    justify-content: flex-end;
}

.message-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 12px;
    flex-shrink: 0;
}

.message-content {
    max-width: 70%;
}

.message-bubble {
    padding: 10px 14px;
    border-radius: 12px;
    position: relative;
}

.message.received .message-bubble {
    background: white;
    border-bottom-left-radius: 2px;
}

.message.sent .message-bubble {
