@inject Web.Services.RecommendationApiService RecommendationApiService
@inject NavigationManager NavigationManager

@code {
    private const int RecommendedProductsCount = 4;
}

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
        <MudGrid Spacing="3">
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="250px" Animation="Animation.Wave"/>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
}
else if (_recommendedProducts.Any())
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h5" Class="fw-bold">
                <MudIcon Icon="@Icons.Material.Filled.Recommend" Class="mr-2" Size="Size.Small"/>
                Gợi ý cho bạn
            </MudText>
            <MudButton Href="/products" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">
                Xem tất cả
            </MudButton>
        </div>
        <MudGrid Spacing="3">
            @foreach (var product in _recommendedProducts.Take(RecommendedProductsCount))
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="2" Class="h-100 cursor-pointer product-card" @onclick="() => NavigateToProduct(product.Id)">
                        <div class="product-image-container">
                            @if (!string.IsNullOrEmpty(product.MainImageUrl))
                            {
                                <img src="@product.MainImageUrl" alt="@product.Name" class="product-image" />
                            }
                            else
                            {
                                <div class="no-image-placeholder">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Color="Color.Secondary"/>
                                </div>
                            }
                        </div>
                        <MudCardContent Class="pa-3">
                            <MudText Typo="Typo.subtitle1" Class="fw-bold text-truncate" title="@product.Name">@product.Name</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="fw-bold mt-1">
                                @GetDisplayPrice(product)
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
}

<style>
    .product-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
    .product-image-container {
        height: 180px;
        overflow: hidden;
        background-color: #f5f5f5;
    }
    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }
    .product-card:hover .product-image {
        transform: scale(1.05);
    }
    .no-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .cursor-pointer {
        cursor: pointer;
    }
    .fw-bold {
        font-weight: 600;
    }
</style>

@code {
    private List<Application.DTOs.Responses.ProductListResponse> _recommendedProducts = new();
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecommendedProductsAsync();
    }

    private async Task LoadRecommendedProductsAsync()
    {
        try
        {
            _isLoading = true;
            _recommendedProducts = await RecommendationApiService.GetRecommendedProductsAsync(4);
        }
        catch
        {
            // Silently fail - if recommendation fails, just don't show the section
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NavigateToProduct(int productId)
    {
        NavigationManager.NavigateTo($"/products/{productId}");
    }

    private string FormatPrice(decimal price)
    {
        return $"{price:N0} ₫";
    }

    private string GetDisplayPrice(Application.DTOs.Responses.ProductListResponse product)
    {
        if (product.MinPrice == 0 && product.MaxPrice == 0)
        {
            return "Liên hệ";
        }
        if (product.MinPrice == product.MaxPrice)
        {
            return FormatPrice(product.MinPrice);
        }
        return $"{FormatPrice(product.MinPrice)} - {FormatPrice(product.MaxPrice)}";
    }
}
