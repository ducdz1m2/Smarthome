    public void Dispose()
    {
        Console.WriteLine("[TechnicianChatWidget] Disposing...");
        if (_onMessageReceivedHandler != null)
        {
            SignalRService.OnChatMessageReceived -= _onMessageReceivedHandler;
            Console.WriteLine("[TechnicianChatWidget] OnChatMessageReceived event unsubscribed");
        }
        if (_isRecording)
        {
            _ = SpeechRecognitionService.CancelRecordingAsync();
        }
    }

    private async Task ToggleRecording()
    {
        if (_isRecording)
        {
            // Stop recording and transcribe
            var text = await SpeechRecognitionService.StopAndTranscribeAsync();
            _isRecording = false;
            _isTranscribing = false;
            
            if (!string.IsNullOrWhiteSpace(text))
            {
                _message = text;
                await SendMessage();
            }
        }
        else
        {
            // Start recording
            await SpeechRecognitionService.StartRecordingAsync(async (transcribedText) =>
            {
                _isRecording = false;
                _isTranscribing = false;
                
                if (!string.IsNullOrWhiteSpace(transcribedText))
                {
                    _message = transcribedText;
                    await SendMessage();
                }
                await InvokeAsync(StateHasChanged);
            });
            _isRecording = true;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task PlayTTS(string text)
    {
        if (!string.IsNullOrWhiteSpace(text))
        {
            try
            {
                await SpeechService.SpeakAsync(text);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"TTS error: {ex.Message}");
            }
        }
    }

    private async Task TriggerFileSelect()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.technician-chat-file-input').click()");
    }

    private async void OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        _selectedFile = file;
        
        if (_isImageFile(file))
        {
            var format = "image/png";
            var resizedImage = await file.RequestImageFileAsync(format, 200, 200);
            var buffer = new byte[resizedImage.Size];
            await resizedImage.OpenReadStream().ReadAsync(buffer);
            _filePreviewUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
        }
        else
        {
            _filePreviewUrl = "";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void RemoveFile()
    {
        _selectedFile = null;
        _filePreviewUrl = "";
    }

    private bool _isImageFile(IBrowserFile file)
    {
        var imageExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif", ".webp" };
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        return imageExtensions.Contains(extension);
    }

    private async Task<string?> UploadFileAsync(IBrowserFile file)
    {
        try
        {
            var httpClient = HttpClientFactory.CreateClient();
            var token = await JwtTokenHandler.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                httpClient.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream());
            content.Add(fileContent, "file", file.Name);

            var uploadUrl = $"{NavigationManager.BaseUri}api/chat/upload";
            var response = await httpClient.PostAsync(uploadUrl, content);
            
            if (response.IsSuccessStatusCode)
            {
                var responseContent = await response.Content.ReadAsStringAsync();
                using var doc = System.Text.Json.JsonDocument.Parse(responseContent);
                return doc.RootElement.TryGetProperty("fileUrl", out var fileUrlElem) ? fileUrlElem.GetString() : null;
            }
            
            return null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TechnicianChatWidget] Upload failed: {ex.Message}");
            return null;
        }
    }
